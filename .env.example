# Configuración de Email para Notificaciones

# Usuario de correo completo (Gmail o Workspace). Ej: usuario@gmail.com
EMAIL_USER=tu_correo@gmail.com

# Contraseña de aplicación (Gmail con 2FA) o contraseña SMTP del proveedor
# Obtén una para Gmail aquí: https://support.google.com/accounts/answer/185833
EMAIL_APP_PASSWORD=tu_contraseña_de_aplicación

# Email destino para notificaciones
NOTIFICATION_EMAIL=tu_correo_destino@ejemplo.com

# (Opcional) Remitente personalizado
EMAIL_FROM=Broker Lenders <tu_correo@gmail.com>

# (Opcional) Configuración SMTP personalizada (si no usas Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false