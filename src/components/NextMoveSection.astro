---
// What's your next move section
import houseIcon from "../assets/icons/house.png";
import dolarIcon from "../assets/icons/dolar.png";
import formIcon from "../assets/icons/form.png";
---

<section class="py-16 bg-white">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">What's your next move?</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Buy smart. Save more. -->
      <a href="/buy" class="bg-red-500/10 p-6 rounded-xl text-center hover:bg-red-500/40 transition-colors block">
        <div class="w-12 h-12 rounded-lg flex items-center justify-center mx-auto mb-4">
          <div
            class="w-8 h-8 bg-red-600"
            style={`mask-image: url(${houseIcon.src}); -webkit-mask-image: url(${houseIcon.src}); mask-size: contain; -webkit-mask-size: contain; mask-repeat: no-repeat; -webkit-mask-repeat: no-repeat; mask-position: center; -webkit-mask-position: center;`}
            aria-label="House icon"
          ></div>
        </div>
        <h3 class="font-semibold text-gray-900">Buy smart. Save more.</h3>
      </a>
      
      <!-- Refinance made simple. -->
      <a href="/refinance" class="bg-blue-500/10 p-6 rounded-xl text-center hover:bg-blue-500/40 transition-colors block">
        <div class="w-12 h-12 rounded-lg flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
        </div>
        <h3 class="font-semibold text-gray-900">Refinance made simple.</h3>
      </a>
      
      <!-- Transform equity into opportunity. -->
      <a href="/calculators" class="bg-green-500/10 p-6 rounded-xl text-center hover:bg-green-500/40 transition-colors block">
        <div class="w-12 h-12 rounded-lg flex items-center justify-center mx-auto mb-4">
          <div
            class="w-8 h-8 bg-green-600"
            style={`mask-image: url(${dolarIcon.src}); -webkit-mask-image: url(${dolarIcon.src}); mask-size: contain; -webkit-mask-size: contain; mask-repeat: no-repeat; -webkit-mask-repeat: no-repeat; mask-position: center; -webkit-mask-position: center;`}
            aria-label="Dollar icon"
          ></div>
        </div>
        <h3 class="font-semibold text-gray-900">Transform equity into opportunity.</h3>
      </a>
      
      <!-- Explore your VA loan benefits. -->
      <a href="/loan-options" class="bg-purple-500/10 p-6 rounded-xl text-center hover:bg-purple-500/40 transition-colors block">
        <div class="w-12 h-12 rounded-lg flex items-center justify-center mx-auto mb-4">
          <div
            class="w-8 h-8 bg-purple-600"
            style={`mask-image: url(${formIcon.src}); -webkit-mask-image: url(${formIcon.src}); mask-size: contain; -webkit-mask-size: contain; mask-repeat: no-repeat; -webkit-mask-repeat: no-repeat; mask-position: center; -webkit-mask-position: center;`}
            aria-label="Form icon"
          ></div>
        </div>
        <h3 class="font-semibold text-gray-900">Explore your VA loan benefits.</h3>
      </a>
    </div>
  </div>
</section>