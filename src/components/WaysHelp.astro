---
import calculatorIcon from "../assets/icons/calculator.png";
---

<!-- More ways we can help -->
<section class="py-18 bg-white">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-12">
			<h2 class="text-3xl font-bold text-gray-900 mb-4">More ways we can help</h2>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<!-- Card 1 -->
			<a href="/calculators/refinance-calculator" class="text-center bg-blue-600/10 text-gray-900 p-8 rounded-xl transition-all hover:bg-blue-600/30 block">
				<div class="w-16 h-16 flex items-center justify-center mx-auto mb-4">
					<img src={calculatorIcon.src} width={calculatorIcon.width} height={calculatorIcon.height} class="w-12 h-12" alt="Calculator icon" />
				</div>
				<h3 class="text-lg font-semibold">Payment calculator</h3>
			</a>

			<!-- Card 2 -->
			<a href="/calculators/mortgage-calculator" class="text-center bg-green-600/10 text-gray-900 p-8 rounded-xl transition-all hover:bg-green-600/30 block">
				<div class="w-16 h-16 flex items-center justify-center mx-auto mb-4">
					<svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
					</svg>
				</div>
				<h3 class="text-lg font-semibold">Calculate your buying power</h3>
			</a>

			<!-- Card 3 -->
			<a href="/rates" class="text-center bg-purple-600/10 text-gray-900 p-8 rounded-xl transition-all hover:bg-purple-600/30 block">
				<div class="w-16 h-16 flex items-center justify-center mx-auto mb-4">
					<svg class="w-12 h-12 text-purple-600" fill="currentColor" viewBox="0 0 24 24">
						<text x="12" y="16" text-anchor="middle" font-size="20" font-weight="bold">%</text>
					</svg>
				</div>
				<h3 class="text-lg font-semibold">See the latest rates</h3>
			</a>
		</div>
	</div>
</section>