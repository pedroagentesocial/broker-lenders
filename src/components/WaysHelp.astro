---
import calculatorIcon from "../assets/icons/calculator.png";
import dolarIcon from "../assets/icons/dolar.png";
import ratesIcon from "../assets/icons/rates.png";
---

<!-- More ways we can help -->
<section class="py-18 bg-white">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-12">
			<h2 class="text-3xl font-bold text-gray-900 mb-4">More ways we can help</h2>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<!-- Card 1 -->
			<a href="/calculators/refinance-calculator" class="text-center bg-blue-600/10 text-gray-900 p-8 rounded-xl transition-all hover:bg-blue-600/30 block">
				<div class="w-16 h-16 flex items-center justify-center mx-auto mb-4">
					<div
						class="w-12 h-12 bg-blue-600"
						style={`mask-image: url(${calculatorIcon.src}); -webkit-mask-image: url(${calculatorIcon.src}); mask-size: contain; -webkit-mask-size: contain; mask-repeat: no-repeat; -webkit-mask-repeat: no-repeat; mask-position: center; -webkit-mask-position: center;`}
						aria-label="Calculator icon"
					></div>
				</div>
				<h3 class="text-lg font-semibold">Payment calculator</h3>
			</a>

			<!-- Card 2 -->
			<a href="/calculators/mortgage-calculator" class="text-center bg-green-600/10 text-gray-900 p-8 rounded-xl transition-all hover:bg-green-600/30 block">
				<div class="w-16 h-16 flex items-center justify-center mx-auto mb-4">
					<div
						class="w-12 h-12 bg-green-600"
						style={`mask-image: url(${dolarIcon.src}); -webkit-mask-image: url(${dolarIcon.src}); mask-size: contain; -webkit-mask-size: contain; mask-repeat: no-repeat; -webkit-mask-repeat: no-repeat; mask-position: center; -webkit-mask-position: center;`}
						aria-label="Dollar icon"
					></div>
				</div>
				<h3 class="text-lg font-semibold">Calculate your buying power</h3>
			</a>

			<!-- Card 3 -->
			<a href="/rates" class="text-center bg-purple-600/10 text-gray-900 p-8 rounded-xl transition-all hover:bg-purple-600/30 block">
				<div class="w-16 h-16 flex items-center justify-center mx-auto mb-4">
					<div
						class="w-12 h-12 bg-purple-600"
						style={`mask-image: url(${ratesIcon.src}); -webkit-mask-image: url(${ratesIcon.src}); mask-size: contain; -webkit-mask-size: contain; mask-repeat: no-repeat; -webkit-mask-repeat: no-repeat; mask-position: center; -webkit-mask-position: center;`}
						aria-label="Rates icon"
					></div>
				</div>
				<h3 class="text-lg font-semibold">See the latest rates</h3>
			</a>
		</div>
	</div>
</section>