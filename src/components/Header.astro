<!-- Inline i18n payloads encoded to avoid HTML parsing issues -->
<div id="i18n-header" data-en={enB64} data-es={esB64} style="display:none"></div>

<script is:inline>
  // i18n dynamic translations for Header
  const i18nEl = document.getElementById('i18n-header');
  const decode = (val) => {
    try {
      const b64 = val || '';
      const bin = atob(b64);
      const bytes = new Uint8Array(bin.length);
      for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
      const jsonText = new TextDecoder('utf-8').decode(bytes);
      return JSON.parse(jsonText);
    } catch { return {}; }
  };
  // Ensure language links keep current pathname and query when clicked
  const updateLanguageLinkHrefs = () => {
    try {
      const header = document.querySelector('header');
      if (!header) return;
      const current = new URL(window.location.href);
      const buildHref = (lang) => {
        const url = new URL(current);
        url.searchParams.set('lang', lang);
        // Return path + query to avoid forcing origin
        const qs = url.searchParams.toString();
        return qs ? `${url.pathname}?${qs}` : url.pathname;
      };
      header.querySelectorAll('a[data-i18n="english"]').forEach(a => {
        a.setAttribute('href', buildHref('en'));
      });
      header.querySelectorAll('a[data-i18n="spanish"]').forEach(a => {
        a.setAttribute('href', buildHref('es'));
      });
    } catch (e) {
      console.warn('[i18n][header] failed to update language hrefs', e);
    }
  };
  const translations = {
    en: decode(i18nEl?.getAttribute('data-en') || ''),
    es: decode(i18nEl?.getAttribute('data-es') || ''),
  };
  const getInitialLang = () => {
    const urlLang = new URLSearchParams(window.location.search).get('lang');
    const stored = localStorage.getItem('lang');
    const attr = document.querySelector('header')?.getAttribute('data-lang');
    return (urlLang || stored || attr || 'en');
  };
  const applyTranslations = (lang) => {
    const dict = translations[lang] || translations.en;
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key]) el.textContent = dict[key];
    });
    document.querySelectorAll('[data-i18n-alt]').forEach(el => {
      const key = el.getAttribute('data-i18n-alt');
      if (key && dict[key]) el.setAttribute('alt', dict[key]);
    });
    document.querySelectorAll('[data-i18n-aria]').forEach(el => {
      const key = el.getAttribute('data-i18n-aria');
      if (key && dict[key]) el.setAttribute('aria-label', dict[key]);
    });
  };
  const updateSelectedLanguageUI = (lang) => {
    try {
      const header = document.querySelector('header');
      if (!header) return;
      const enLinks = header.querySelectorAll('a[data-i18n="english"]');
      const esLinks = header.querySelectorAll('a[data-i18n="spanish"]');
      const setActive = (els, active) => {
        els.forEach(el => {
          if (active) {
            el.classList.add('bg-gray-100', 'text-black', 'font-semibold');
            el.setAttribute('aria-current', 'true');
          } else {
            el.classList.remove('bg-gray-100', 'text-black', 'font-semibold');
            el.removeAttribute('aria-current');
          }
        });
      };
      setActive(enLinks, lang === 'en');
      setActive(esLinks, lang === 'es');
    } catch (e) {
      console.warn('[i18n][header] language UI update failed', e);
    }
  };
  const setLanguage = (lang) => {
    localStorage.setItem('lang', lang);
    // Persist also in cookie for SSR fallback
    try { document.cookie = `lang=${lang};path=/;max-age=31536000;SameSite=Lax`; } catch {}
    applyTranslations(lang);
    updateSelectedLanguageUI(lang);
    const url = new URL(window.location.href);
    url.searchParams.set('lang', lang);
    const next = url.toString();
    if (next !== window.location.href) {
      window.history.replaceState({}, '', next);
    }
    // Keep language menu links in sync with the current URL
    updateLanguageLinkHrefs();
    // Also keep header navigation links preserving current language
    preserveLangOnHeaderLinks(lang);
  };
  // Ensure all internal header links preserve the current ?lang without blocking clicks
  const preserveLangOnHeaderLinks = (currentLang) => {
    try {
      const header = document.querySelector('header');
      if (!header) return;
      // Note: remove extra space in selector to avoid missing matches
      const anchors = header.querySelectorAll('a[href^="/"]');
      anchors.forEach(a => {
        const raw = a.getAttribute('href') || '';
        // Skip language selection links (already include ?lang), hash, tel, mail, or external
        if (!raw || raw.startsWith('#') || raw.startsWith('tel:') || raw.startsWith('mailto:') || /([?&])lang=/.test(raw)) return;
        let href;
        try { href = new URL(a.href, window.location.origin); } catch { return; }
        if (href.origin !== window.location.origin) return;
        if (currentLang) {
          href.searchParams.set('lang', currentLang);
          a.setAttribute('href', href.pathname + href.search + href.hash);
        }
      });
    } catch {}
  };
  // Intercept ONLY language menu clicks within Header (English/Español) and perform full SSR navigation
  document.addEventListener('click', (e) => {
    const withinHeader = !!e.target.closest('header');
    if (!withinHeader) return;
    const a = e.target.closest('a');
    if (!a) return;
    // Only handle explicit language selection links
    const isLangLink = a.matches('a[data-i18n="english"], a[data-i18n="spanish"]');
    if (!isLangLink) return; // allow normal navigation for other header links
    const lang = a.matches('a[data-i18n="english"]') ? 'en' : 'es';
    // Persist language
    localStorage.setItem('lang', lang);
    try { document.cookie = `lang=${lang};path=/;max-age=31536000;SameSite=Lax`; } catch {}
    // Force full SSR navigation to update page content (e.g., index components)
    e.preventDefault();
    try {
      const url = new URL(window.location.href);
      url.searchParams.set('lang', lang);
      window.location.replace(url.toString());
    } catch {
      // Fallback to anchor href if URL building fails
      const href = a.getAttribute('href') || a.href;
      if (href) window.location.replace(href);
    }
    if (typeof window.__headerCloseMenu === 'function') window.__headerCloseMenu();
  });
  // Initialize
  const __initLang = getInitialLang();
  applyTranslations(__initLang);
  updateSelectedLanguageUI(__initLang);
  updateLanguageLinkHrefs();
  preserveLangOnHeaderLinks(__initLang);

  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    const openMenu = () => {
      menu.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    };
    const closeMenu = () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    };
    // Expose close for other handlers (e.g., language change)
    window.__headerCloseMenu = closeMenu;
    let isOpen = false;
    toggle.addEventListener('click', () => {
      isOpen = !isOpen;
      isOpen ? openMenu() : closeMenu();
    });
    document.addEventListener('click', (e) => {
      if (!menu.contains(e.target) && !toggle.contains(e.target)) {
        isOpen = false;
        closeMenu();
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        isOpen = false;
        closeMenu();
      }
    });
  }
  // Booking modal handlers
  const bookingModal = document.getElementById('booking-modal');
  const openBookingBtn = document.getElementById('openBooking');
  const openBookingMobileBtn = document.getElementById('openBookingMobile');
  const openBookingPanelBtn = document.getElementById('openBookingPanel');
  const closeBookingBtn = document.getElementById('closeBooking');
  const openBooking = () => {
    bookingModal?.classList.add('flex');
    bookingModal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  };
  const closeBooking = () => {
    bookingModal?.classList.remove('flex');
    bookingModal?.classList.add('hidden');
    document.body.style.overflow = '';
  };
  openBookingBtn?.addEventListener('click', openBooking);
  openBookingMobileBtn?.addEventListener('click', openBooking);
  openBookingPanelBtn?.addEventListener('click', openBooking);
  closeBookingBtn?.addEventListener('click', closeBooking);
  bookingModal?.addEventListener('click', (e) => { if (e.target === bookingModal) closeBooking(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeBooking(); });
  // React to language changes set elsewhere (e.g., Index page or calculators)
  window.addEventListener('storage', (ev) => {
    if (ev.key === 'lang' && ev.newValue) {
      applyTranslations(ev.newValue);
      updateSelectedLanguageUI(ev.newValue);
      updateLanguageLinkHrefs();
      preserveLangOnHeaderLinks(ev.newValue);
      // Update URL without full reload
      try {
        const url = new URL(window.location.href);
        url.searchParams.set('lang', ev.newValue);
        const next = url.toString();
        if (next !== window.location.href) {
          window.history.replaceState({}, '', next);
        }
      } catch {}
    }
  });
</script>
