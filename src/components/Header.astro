                <!-- Popular Section -->
                <div class="px-4 py-2">
                  <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Popular</div>
                  <div class="space-y-1">
                    <a href="/loan-options/refinance-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Refinance Options</a>
                    <a href="/loan-options/conventional-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Conventional Refinance</a>
                    <a href="/loan-options/fha-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">FHA Refinance</a>
                    <a href="/loan-options/va-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">VA Refinance</a>
