                </svg>
              </div>
              
              <!-- Second Level Dropdown -->
              <div class="static md:absolute left-0 md:right-0 top-full md:top-0 mt-1 md:mt-0 md:ml-1 lg:left-full lg:right-auto lg:ml-1 md:w-52 lg:w-64 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-auto opacity-0 invisible group-hover/submenu:opacity-100 group-hover/submenu:visible transition-all duration-200 z-50">
                <!-- Get Started -->
