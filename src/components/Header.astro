                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                </div>
                
                <!-- Popular Section -->
                <div class="px-4 py-2">
                  <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Popular</div>
                  <div class="space-y-1">
                    <a href="/loan-options/conventional-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Conventional Loans</a>
                    <a href="/loan-options/jumbo-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Jumbo Loans</a>
                    <a href="/loan-options/investment-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Investment Loans</a>
                    <a href="/loan-options/construction-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Construction Loans</a>
