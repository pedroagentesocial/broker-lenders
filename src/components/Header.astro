---
import languageIcon from "../assets/icons/lenguage.png";
// Header component
---

<header class="bg-white shadow-sm border-b border-gray-100 sticky top-0 z-50 transition-all duration-300">
  <div class="w-full mx-auto px-3 sm:px-4 lg:px-8">
    <div class="grid grid-cols-[auto,1fr,auto] xl:grid-cols-[1fr,auto] items-center h-20 md:h-24 gap-x-2 sm:gap-x-3">
      <!-- Mobile hamburger (left) -->
      <button id="mobile-menu-toggle" type="button" class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-black hover:text-red-600 hover:bg-gray-100 focus:outline-none self-center col-start-1" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="h-5 w-5 sm:h-6 sm:w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <span class="sr-only">Open main menu</span>
      </button>
      <!-- Logo (solo móvil, centrado) -->
      <div class="flex md:hidden justify-center self-center col-start-2 min-w-0">
        <div class="flex-shrink-0">
          <a href="/">
            <img src="/BL logo negro.png" alt="Broker Lenders" class="h-12 sm:h-14 w-auto hover:opacity-80 transition-opacity">
          </a>
        </div>
      </div>
      
      <!-- Desktop izquierda: logo + navegación juntos -->
      <div class="hidden md:flex items-center self-center col-start-1">
        <div class="flex-shrink-0">
          <a href="/">
            <img src="/BL logo negro.png" alt="Broker Lenders" class="h-12 sm:h-14 w-auto hover:opacity-80 transition-opacity">
          </a>
        </div>
        
      <!-- Navigation -->
      <nav class="flex md:space-x-4 lg:space-x-5 xl:space-x-4 ml-8">
        <!-- Buy Dropdown -->
        <div class="relative group">
          <button class="text-black hover:text-red-600 px-2 lg:px-3 xl:px-3 py-2 md:text-sm lg:text-base font-medium flex items-center whitespace-nowrap">
            Buy
            <svg class="ml-1 w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          
          <!-- First Level Dropdown -->
          <div class="absolute left-0 top-full mt-1 w-36 sm:w-40 md:w-40 lg:w-48 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-auto opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <!-- Buy a home with submenu -->
            <div class="relative group/submenu">
              <div class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 cursor-pointer">
                <span class="text-gray-900 font-medium">Buy a home</span>
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
              
              <!-- Second Level Dropdown -->
              <div class="static md:absolute left-0 md:right-0 top-full md:top-0 mt-1 md:mt-0 md:ml-1 lg:left-full lg:right-auto lg:ml-1 md:w-52 lg:w-64 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-auto opacity-0 invisible group-hover/submenu:opacity-100 group-hover/submenu:visible transition-all duration-200 z-50">
                <!-- Get Started -->
                <div class="px-4 py-3 border-b border-gray-100">
                  <a href="/buy" class="flex items-center justify-between text-gray-900 hover:text-red-600 font-medium">
                    Get started
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                </div>
                
                <!-- Popular Section -->
                <div class="px-4 py-2">
                  <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Popular</div>
                  <div class="space-y-1">
                    <a href="/loan-options/conventional-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Conventional Loans</a>
                    <a href="/loan-options/fha-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">FHA Loans</a>
                    <a href="/loan-options/first-time-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">First-Time Homebuyer</a>
                    <a href="/loan-options/va-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">VA Loans</a>
                    <a href="/loan-options/usda-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">USDA Loans</a>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Calculators -->
            <div class="px-4 py-3 hover:bg-gray-50">
              <a href="/calculators" class="text-gray-900 font-medium">Calculators</a>
            </div>
          </div>
        </div>
        
        <!-- Refinance Dropdown -->
        <div class="relative group">
          <button class="text-black hover:text-red-600 px-2 lg:px-3 xl:px-3 py-2 md:text-sm lg:text-base font-medium flex items-center whitespace-nowrap">
            Refinance
            <svg class="ml-1 w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          
          <!-- First Level Dropdown -->
          <div class="absolute left-0 top-full mt-1 w-36 sm:w-40 md:w-40 lg:w-48 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-auto opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
