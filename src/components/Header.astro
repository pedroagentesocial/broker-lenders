          <a href="tel:+18013070273" class="inline-flex items-center justify-center w-8 h-8 sm:w-9 sm:h-9 rounded-full border border-gray-200 text-black hover:text-red-600 hover:border-red-300" aria-label="Call">
            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </a>
        <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full bg-black text-white hover:bg-red-600 text-[11px] sm:text-xs px-2.5 sm:px-3 py-1 whitespace-nowrap">Apply
          <span class="sr-only">now</span>
        </a>
        </div>
      </div>
      <!-- Mobile menu panel -->
      <div id="mobile-menu" class="md:hidden fixed top-20 md:top-24 left-0 right-0 bg-white border-t border-gray-100 shadow-lg z-40 max-h-[70vh] overflow-y-auto transform scale-y-0 origin-top transition-transform duration-200">
        <div class="px-4 py-4 space-y-2">
          <a href="/buy" class="block px-3 py-2 rounded-lg text-gray-900 hover:bg-gray-50 hover:text-red-600">Buy</a>
          <a href="/refinance" class="block px-3 py-2 rounded-lg text-gray-900 hover:bg-gray-50 hover:text-red-600">Refinance</a>
          <a href="/rates" class="block px-3 py-2 rounded-lg text-gray-900 hover:bg-gray-50 hover:text-red-600">Rates</a>
