---
import languageIcon from "../assets/icons/lenguage.png";
import en from "../translations/header/en.json";
import es from "../translations/header/es.json";
const enB64 = Buffer.from(JSON.stringify(en)).toString('base64');
const esB64 = Buffer.from(JSON.stringify(es)).toString('base64');
// Header component
// Keep original dropdown behavior; no SSR highlight of active language
export interface Props { lang?: string }
const { lang = 'en' } = Astro.props;
---

<header class="bg-white shadow-sm border-b border-gray-100 sticky top-0 z-50 transition-all duration-300" data-lang={lang}>
  <div class="w-full mx-auto px-3 sm:px-4 lg:px-8">
    <div class="grid grid-cols-[auto,1fr,auto] xl:grid-cols-[1fr,auto] items-center h-20 md:h-24 gap-x-2 sm:gap-x-3">
      <!-- Mobile hamburger (left) -->
      <button id="mobile-menu-toggle" type="button" class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-black hover:text-red-600 hover:bg-gray-100 focus:outline-none self-center col-start-1" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="h-5 w-5 sm:h-6 sm:w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <span class="sr-only" data-i18n="open_main_menu">Open main menu</span>
      </button>
      <!-- Logo (solo móvil, centrado) -->
      <div class="flex md:hidden justify-center self-center col-start-2 min-w-0">
        <div class="flex-shrink-0">
          <a href="/">
            <img src="/logo.png" alt="Broker Lenders" data-i18n-alt="logo_alt" class="h-12 sm:h-14 w-auto hover:opacity-80 transition-opacity" decoding="async" loading="eager" fetchpriority="high" onerror="this.onerror=null;this.src='/bl-logo-negro.png'">
          </a>
          </div>
        </div>
      
      <!-- Desktop izquierda: logo + navegación juntos -->
      <div class="hidden md:flex items-center self-center col-start-1">
        <div class="flex-shrink-0">
          <a href="/">
            <img src="/logo.png" alt="Broker Lenders" data-i18n-alt="logo_alt" class="h-12 sm:h-14 w-auto hover:opacity-80 transition-opacity" decoding="async" loading="eager" fetchpriority="high" onerror="this.onerror=null;this.src='/bl-logo-negro.png'">
          </a>
        </div>
        
      <!-- Navigation -->
      <nav class="flex md:space-x-4 lg:space-x-5 xl:space-x-4 ml-8">
        <!-- Buy Dropdown -->
        <div class="relative group">
          <button class="text-black hover:text-red-600 px-2 lg:px-3 xl:px-3 py-2 md:text-sm lg:text-base font-medium flex items-center whitespace-nowrap">
            <span data-i18n="buy">Buy</span>
            <svg class="ml-1 w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          
          <!-- First Level Dropdown -->
          <div class="absolute left-0 top-full mt-1 w-36 sm:w-40 md:w-40 lg:w-48 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-visible opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <!-- Buy a home with submenu -->
            <div class="relative group/submenu">
              <div class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 cursor-pointer">
                <span class="text-gray-900 font-medium" data-i18n="buy_a_home">Buy a home</span>
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
              
              <!-- Second Level Dropdown -->
              <div class="static md:absolute md:top-0 md:left-full mt-1 md:mt-0 md:ml-1 md:w-52 lg:w-64 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-auto opacity-0 invisible group-hover/submenu:opacity-100 group-hover/submenu:visible transition-all duration-200 z-50">
                <!-- Get Started -->
                <div class="px-4 py-3 border-b border-gray-100">
                  <a href="/buy" class="flex items-center justify-between text-gray-900 hover:text-red-600 font-medium">
                    <span data-i18n="get_started">Get started</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                </div>
                
                <!-- Popular Section -->
                <div class="px-4 py-2">
                  <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2" data-i18n="popular">Popular</div>
                  <div class="space-y-1">
                    <a href="/loan-options/conventional-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="conventional_loans">Conventional Loans</a>
                    <a href="/loan-options/fha-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="fha_loans">FHA Loans</a>
                    <a href="/loan-options/first-time-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="first_time_homebuyer">First-Time Homebuyer</a>
                    <a href="/loan-options/va-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="va_loans">VA Loans</a>
                    <a href="/loan-options/usda-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="usda_loans">USDA Loans</a>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Calculators -->
            <div class="px-4 py-3 hover:bg-gray-50">
              <a href="/calculators" class="text-gray-900 font-medium" data-i18n="calculators">Calculators</a>
            </div>
          </div>
        </div>
        
        <!-- Refinance Dropdown -->
        <div class="relative group">
          <button class="text-black hover:text-red-600 px-2 lg:px-3 xl:px-3 py-2 md:text-sm lg:text-base font-medium flex items-center whitespace-nowrap">
            <span data-i18n="refinance">Refinance</span>
            <svg class="ml-1 w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          
          <!-- First Level Dropdown -->
          <div class="absolute left-0 top-full mt-1 w-36 sm:w-40 md:w-40 lg:w-48 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-visible opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <!-- Refinance your home with submenu -->
            <div class="relative group/submenu">
              <div class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 cursor-pointer">
                <span class="text-gray-900 font-medium" data-i18n="refinance_your_home">Refinance your home</span>
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
              
              <!-- Second Level Dropdown -->
              <div class="static md:absolute md:top-0 md:left-full mt-1 md:mt-0 md:ml-1 md:w-52 lg:w-64 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-auto opacity-0 invisible group-hover/submenu:opacity-100 group-hover/submenu:visible transition-all duration-200 z-50">
                <!-- Get Started -->
                <div class="px-4 py-3 border-b border-gray-100">
                  <a href="/refinance" class="flex items-center justify-between text-gray-900 hover:text-red-600 font-medium">
                    <span data-i18n="get_started">Get started</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                </div>
                
                <!-- Popular Section -->
                <div class="px-4 py-2">
                  <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2" data-i18n="popular">Popular</div>
                  <div class="space-y-1">
                    <a href="/loan-options/refinance-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="refinance_options">Refinance Options</a>
                    <a href="/loan-options/conventional-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="conventional_refinance">Conventional Refinance</a>
                    <a href="/loan-options/fha-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="fha_refinance">FHA Refinance</a>
                    <a href="/loan-options/va-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="va_refinance">VA Refinance</a>
                    <a href="/loan-options/refinance-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="cash_out_options">Cash-out Options</a>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Calculators -->
            <div class="px-4 py-3 hover:bg-gray-50">
              <a href="/calculators" class="text-gray-900 font-medium" data-i18n="calculators">Calculators</a>
            </div>
          </div>
        </div>

        <!-- Rates Dropdown -->
        <div class="relative group">
          <button class="text-black hover:text-red-600 px-2 lg:px-3 xl:px-3 py-2 md:text-sm lg:text-base font-medium flex items-center whitespace-nowrap">
            <span data-i18n="rates">Rates</span>
            <svg class="ml-1 w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          
          <!-- First Level Dropdown -->
          <div class="absolute left-0 top-full mt-1 w-36 sm:w-40 md:w-40 lg:w-48 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-visible opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <!-- Current rates with submenu -->
            <div class="relative group/submenu">
              <div class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 cursor-pointer">
                <span class="text-gray-900 font-medium" data-i18n="current_rates">Current rates</span>
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
              
              <!-- Second Level Dropdown -->
              <div class="static md:absolute md:top-0 md:left-full mt-1 md:mt-0 md:ml-1 md:w-52 lg:w-64 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-auto opacity-0 invisible group-hover/submenu:opacity-100 group-hover/submenu:visible transition-all duration-200 z-50">
                <!-- Get Started -->
                <div class="px-4 py-3 border-b border-gray-100">
                  <a href="/rates" class="flex items-center justify-between text-gray-900 hover:text-red-600 font-medium">
                    <span data-i18n="get_started">Get started</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                </div>
                
                <!-- Popular Section -->
                <div class="px-4 py-2">
                  <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2" data-i18n="popular">Popular</div>
                  <div class="space-y-1">
                    <a href="/rates?state=utah" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="utah">Utah</a>
                    <a href="/rates?state=idaho" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="idaho">Idaho</a>
                    <a href="/rates?state=nevada" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="nevada">Nevada</a>
                    <a href="/rates?state=california" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="california">California</a>
                    <a href="/rates?state=texas" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="texas">Texas</a>
                    <a href="/rates?state=florida" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="florida">Florida</a>
                    <a href="/rates?state=colorado" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="colorado">Colorado</a>
                  </div>
                </div>
              </div>
            </div>
            

          </div>
        </div>

        <!-- Loan Options Dropdown -->
        <div class="relative group">
          <button class="text-black hover:text-red-600 px-2 lg:px-3 xl:px-3 py-2 md:text-sm lg:text-base font-medium flex items-center whitespace-nowrap">
            <span data-i18n="loan_options">Loan Options</span>
            <svg class="ml-1 w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          
          <!-- First Level Dropdown -->
          <div class="absolute left-0 top-full mt-1 w-36 sm:w-40 md:w-40 lg:w-48 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-visible opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <!-- Loan programs with submenu -->
            <div class="relative group/submenu">
              <div class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 cursor-pointer">
                <span class="text-gray-900 font-medium" data-i18n="loan_programs">Loan programs</span>
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
              
              <!-- Second Level Dropdown -->
              <div class="static md:absolute md:top-0 md:left-full mt-1 md:mt-0 md:ml-1 md:w-52 lg:w-64 bg-white rounded-lg shadow-lg border border-gray-100 md:max-h-[60vh] md:overflow-auto opacity-0 invisible group-hover/submenu:opacity-100 group-hover/submenu:visible transition-all duration-200 z-50">
                <!-- Get Started -->
                <div class="px-4 py-3 border-b border-gray-100">
                  <a href="/loan-options" class="flex items-center justify-between text-gray-900 hover:text-red-600 font-medium">
                    <span data-i18n="get_started">Get started</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </a>
                </div>
                
                <!-- Popular Section -->
                <div class="px-4 py-2">
                  <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2" data-i18n="popular">Popular</div>
                  <div class="space-y-1">
                    <a href="/loan-options/conventional-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="conventional_loans">Conventional Loans</a>
                    <a href="/loan-options/jumbo-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="jumbo_loans">Jumbo Loans</a>
                    <a href="/loan-options/investment-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="investment_loans">Investment Loans</a>
                    <a href="/loan-options/construction-loan" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate" data-i18n="construction_loans">Construction Loans</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </nav>
      </div>
      
      <!-- Actions -->
      <div class="flex items-center gap-2 sm:gap-3 md:gap-4 self-center col-start-3 xl:col-start-2 justify-self-end">
        <!-- Language Selector (moved first) -->
        <div class="relative group hidden md:block">
          <button type="button" class="inline-flex items-center gap-2 text-black hover:text-red-600 px-2 py-2 focus:outline-none">
            <!-- Globe icon image -->
        <img src={languageIcon.src} alt="Language" class="w-5 h-5 object-contain inline-block shrink-0 icon-language" onerror="this.style.display='none'; const fallback=this.nextElementSibling; if(fallback) fallback.classList.remove('hidden')" />
            <!-- Fallback globe SVG if image fails -->
            <svg class="w-5 h-5 text-black hidden group-hover:text-red-600 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 12h20M12 2c3 3 3 7 3 10s0 7-3 10M12 2c-3 3-3 7-3 10s0 7 3 10"></path>
            </svg>
            <!-- Down arrow icon -->
            <svg class="w-4 h-4 text-black group-hover:text-red-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <!-- Dropdown (centered under button) -->
          <div class="absolute left-1/2 -translate-x-1/2 transform top-full mt-1 w-32 bg-white rounded-lg shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible focus-within:opacity-100 focus-within:visible transition-all duration-200 z-50">
