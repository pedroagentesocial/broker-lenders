            <div class="px-3 text-xs uppercase text-gray-500 mb-1">Language</div>
            <div class="grid grid-cols-2 gap-2 px-3">
              <a href="/?lang=en" class="block px-3 py-2 rounded-lg text-gray-900 hover:bg-gray-50 hover:text-red-600">English</a>
              <a href="/?lang=es" class="block px-3 py-2 rounded-lg text-gray-900 hover:bg-gray-50 hover:text-red-600">Español</a>
            </div>
          </div>
          <div class="pt-2 border-t border-gray-100">
