        <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex items-center px-4 py-2 rounded-full bg-black text-white hover:bg-red-600 transition-colors">Apply</a>
        <!-- Mobile mini actions (right) -->
