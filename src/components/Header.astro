                    <a href="/rates?state=idaho" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Idaho</a>
                    <a href="/rates?state=nevada" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Nevada</a>
                    <a href="/rates?state=california" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">California</a>
                    <a href="/rates?state=texas" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Texas</a>
                    <a href="/rates?state=florida" class="block w-full px-2 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded truncate">Florida</a>
