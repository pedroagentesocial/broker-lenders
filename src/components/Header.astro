      </div>
      
      <!-- Actions -->
      <div class="flex items-center gap-2 sm:gap-3 md:gap-4 self-center col-start-3 xl:col-start-2 justify-self-end">
        <!-- Language Selector (moved first) -->
        <div class="relative group hidden md:block">
          <button type="button" class="inline-flex items-center gap-2 text-black hover:text-red-600 px-2 py-2 focus:outline-none">
            <!-- Globe icon image -->
            <img src={languageIcon} alt="Language" class="w-5 h-5 object-contain inline-block shrink-0 icon-language" onerror="this.style.display='none'; const fallback=this.nextElementSibling; if(fallback) fallback.classList.remove('hidden')" />
            <!-- Fallback globe SVG if image fails -->
            <svg class="w-5 h-5 text-black hidden group-hover:text-red-600 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 12h20M12 2c3 3 3 7 3 10s0 7-3 10M12 2c-3 3-3 7-3 10s0 7 3 10"></path>
            </svg>
            <!-- Down arrow icon -->
            <svg class="w-4 h-4 text-black group-hover:text-red-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <!-- Dropdown (centered under button) -->
          <div class="absolute left-1/2 -translate-x-1/2 transform top-full mt-1 w-32 bg-white rounded-lg shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible focus-within:opacity-100 focus-within:visible transition-all duration-200 z-50">
            <a href="/?lang=en" class="block px-4 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-t">English</a>
            <a href="/?lang=es" class="block px-4 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-b">Español</a>
          </div>
        </div>
        <a href="tel:+18013070273" class="hidden md:inline-flex items-center gap-2 text-black hover:text-red-600">
           <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
