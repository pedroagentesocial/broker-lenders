            <a href="/?lang=es" class="block px-4 py-2 text-sm text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-b" data-i18n="spanish">Español</a>
          </div>
        </div>
        <a href="tel:+18013070273" class="hidden md:inline-flex items-center gap-2 text-black hover:text-red-600">
           <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
           </svg>
           (801) 307-0273
         </a>
        <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex items-center px-4 py-2 rounded-full bg-black text-white hover:bg-red-600 transition-colors" data-i18n="apply">Apply</a>
        <button id="openBooking" type="button" class="hidden md:inline-flex items-center px-4 py-2 rounded-[48px] bg-black text-white hover:bg-red-600 transition-colors" data-i18n="book">Book</button>
        <!-- Mobile mini actions (right) -->
        <div class="flex items-center gap-1 sm:gap-2 md:hidden">
          <a href="tel:+18013070273" class="inline-flex items-center justify-center w-8 h-8 sm:w-9 sm:h-9 rounded-full border border-gray-200 text-black hover:text-red-600 hover:border-red-300" aria-label="Call" data-i18n-aria="call">
            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </a>
        <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full bg-black text-white hover:bg-red-600 text-[11px] sm:text-xs px-2.5 sm:px-3 py-1 whitespace-nowrap">
          <span data-i18n="apply">Apply</span>
          <span class="sr-only">now</span>
        </a>
        <button id="openBookingMobile" type="button" class="inline-flex items-center justify-center rounded-full bg-black text-white hover:bg-red-600 text-[11px] sm:text-xs px-2.5 sm:px-3 py-1 whitespace-nowrap" data-i18n="book">Book</button>
