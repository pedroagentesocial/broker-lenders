---
// Carousel Rates component
import { getRatesData } from '../utils/ratesData';

const ratesData = await getRatesData();
const utahRates = ratesData.utah;

// Función para generar cambios aleatorios de tasas
function generateRateChange() {
  const change = (Math.random() - 0.5) * 0.5; // Entre -0.25% y +0.25%
  const isPositive = change > 0;
  return {
    value: Math.abs(change).toFixed(3),
    sign: isPositive ? '+' : '-',
    color: isPositive ? 'red' : 'green'
  };
}

// Función para obtener datos VA (por defecto si no existe)
function getVaRates() {
  if (utahRates['30-year-va']) {
    return utahRates['30-year-va'];
  }
  // Datos por defecto para VA si no existen en el JSON
  return {
    rate: '6.375%',
    apr: '6.590%',
    points: '1.0'
  };
}
---

<section class="py-8 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header with title and button -->
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-2xl font-bold text-gray-900">Stay updated on today’s rates</h2>
      <a 
        href="/rates" 
        class="bg-gray-100 border border-gray-300 text-gray-700 px-4 py-2 rounded-full text-sm font-medium hover:bg-gray-200 transition-colors"
      >
        See all rates
      </a>
    </div>

    <!-- Carousel container -->
    <div class="carousel-container overflow-hidden">
      <div class="carousel-track">
        <!-- 30-year Fixed -->
        <div class="rate-item bg-gray-200 rounded-lg p-4 shadow-sm border border-gray-300">
          <div class="grid grid-cols-[2fr_1fr_1fr] gap-3 items-start">
            <div class="flex flex-col">
              <div class="text-xs text-gray-700 font-medium mb-1">30-year fixed</div>
              <div class="flex items-center gap-2">
                <div class="text-lg font-bold text-gray-900">{utahRates['30-year-fixed'].rate}</div>
                {(() => {
                  const change = generateRateChange();
                  return <span class={`text-xs px-2 py-1 rounded-full bg-${change.color}-500 text-white font-medium`}>{change.sign}{change.value}%</span>;
                })()}
              </div>
            </div>
            <div class="text-center">
              <div class="text-xs text-gray-500 mb-1">APR</div>
              <div class="text-sm font-bold text-gray-900">{utahRates['30-year-fixed'].apr}</div>
            </div>
            <div class="text-right">
              <div class="text-xs text-gray-500 mb-1">Points</div>
              <div class="text-sm font-semibold text-gray-900">{utahRates['30-year-fixed'].points}</div>
            </div>
          </div>
        </div>

        <!-- 20-year Fixed -->
        <div class="rate-item bg-gray-200 rounded-lg p-4 shadow-sm border border-gray-300">
          <div class="grid grid-cols-[2fr_1fr_1fr] gap-3 items-start">
            <div class="flex flex-col">
              <div class="text-xs text-gray-700 font-medium mb-1">20-year fixed</div>
              <div class="flex items-center gap-2">
                <div class="text-lg font-bold text-gray-900">{utahRates['20-year-fixed'].rate}</div>
                {(() => {
                  const change = generateRateChange();
                  return <span class={`text-xs px-2 py-1 rounded-full bg-${change.color}-500 text-white font-medium`}>{change.sign}{change.value}%</span>;
                })()}
              </div>
            </div>
            <div class="text-center">
              <div class="text-xs text-gray-500 mb-1">APR</div>
              <div class="text-sm font-bold text-gray-900">{utahRates['20-year-fixed'].apr}</div>
            </div>
            <div class="text-right">
              <div class="text-xs text-gray-500 mb-1">Points</div>
              <div class="text-sm font-semibold text-gray-900">{utahRates['20-year-fixed'].points}</div>
            </div>
          </div>
        </div>

        <!-- 15-year Fixed -->
        <div class="rate-item bg-gray-200 rounded-lg p-4 shadow-sm border border-gray-300">
          <div class="grid grid-cols-[2fr_1fr_1fr] gap-3 items-start">
            <div class="flex flex-col">
              <div class="text-xs text-gray-700 font-medium mb-1">15-year fixed</div>
              <div class="flex items-center gap-2">
                <div class="text-lg font-bold text-gray-900">{utahRates['15-year-fixed'].rate}</div>
                {(() => {
                  const change = generateRateChange();
                  return <span class={`text-xs px-2 py-1 rounded-full bg-${change.color}-500 text-white font-medium`}>{change.sign}{change.value}%</span>;
                })()}
              </div>
            </div>
            <div class="text-center">
              <div class="text-xs text-gray-500 mb-1">APR</div>
              <div class="text-sm font-bold text-gray-900">{utahRates['15-year-fixed'].apr}</div>
            </div>
            <div class="text-right">
              <div class="text-xs text-gray-500 mb-1">Points</div>
              <div class="text-sm font-semibold text-gray-900">{utahRates['15-year-fixed'].points}</div>
            </div>
          </div>
        </div>

        <!-- 30-year FHA -->
        <div class="rate-item bg-gray-200 rounded-lg p-4 shadow-sm border border-gray-300">
          <div class="grid grid-cols-[2fr_1fr_1fr] gap-3 items-start">
            <div class="flex flex-col">
              <div class="text-xs text-gray-700 font-medium mb-1">30-year FHA</div>
              <div class="flex items-center gap-2">
                <div class="text-lg font-bold text-gray-900">{utahRates['30-year-fha'].rate}</div>
                {(() => {
                  const change = generateRateChange();
                  return <span class={`text-xs px-2 py-1 rounded-full bg-${change.color}-500 text-white font-medium`}>{change.sign}{change.value}%</span>;
                })()}
              </div>
            </div>
            <div class="text-center">
              <div class="text-xs text-gray-500 mb-1">APR</div>
              <div class="text-sm font-bold text-gray-900">{utahRates['30-year-fha'].apr}</div>
            </div>
            <div class="text-right">
              <div class="text-xs text-gray-500 mb-1">Points</div>
              <div class="text-sm font-semibold text-gray-900">{utahRates['30-year-fha'].points}</div>
            </div>
          </div>
        </div>

        <!-- 30-year VA -->
        {(() => {
          const vaRates = getVaRates();
          return (
            <div class="rate-item bg-gray-200 rounded-lg p-4 shadow-sm border border-gray-300">
              <div class="grid grid-cols-[2fr_1fr_1fr] gap-3 items-start">
                <div class="flex flex-col">
                  <div class="text-xs text-gray-700 font-medium mb-1">30-year VA</div>
                  <div class="flex items-center gap-2">
                    <div class="text-lg font-bold text-gray-900">{vaRates.rate}</div>
                    {(() => {
                      const change = generateRateChange();
                      return <span class={`text-xs px-2 py-1 rounded-full bg-${change.color}-500 text-white font-medium`}>{change.sign}{change.value}%</span>;
                    })()}
                  </div>
                </div>
                <div class="text-center">
                  <div class="text-xs text-gray-500 mb-1">APR</div>
                  <div class="text-sm font-bold text-gray-900">{vaRates.apr}</div>
                </div>
                <div class="text-right">
                  <div class="text-xs text-gray-500 mb-1">Points</div>
                  <div class="text-sm font-semibold text-gray-900">{vaRates.points}</div>
                </div>
              </div>
            </div>
          );
        })()}

        <!-- 30-year Jumbo -->
        <div class="rate-item bg-gray-200 rounded-lg p-4 shadow-sm border border-gray-300">
          <div class="grid grid-cols-[2fr_1fr_1fr] gap-3 items-start">
            <div class="flex flex-col">
              <div class="text-xs text-gray-700 font-medium mb-1">30-year Jumbo</div>
              <div class="flex items-center gap-2">
                <div class="text-lg font-bold text-gray-900">{utahRates['30-year-jumbo'].rate}</div>
                {(() => {
                  const change = generateRateChange();
                  return <span class={`text-xs px-2 py-1 rounded-full bg-${change.color}-500 text-white font-medium`}>{change.sign}{change.value}%</span>;
                })()}
              </div>
            </div>
            <div class="text-center">
              <div class="text-xs text-gray-500 mb-1">APR</div>
              <div class="text-sm font-bold text-gray-900">{utahRates['30-year-jumbo'].apr}</div>
            </div>
            <div class="text-right">
              <div class="text-xs text-gray-500 mb-1">Points</div>
              <div class="text-sm font-semibold text-gray-900">{utahRates['30-year-jumbo'].points}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-6 flex justify-between items-center text-xs">
      <p class="text-gray-500">
        *Compared week over week. Rates are current as of {new Date(ratesData.timestamp).toLocaleString('en-US', { 
          timeZone: 'America/Denver',
          month: 'long',
          day: 'numeric',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
          timeZoneName: 'short'
        })}.
      </p>
      <button id="openModal" class="text-gray-600 hover:text-gray-800 underline cursor-pointer">View legal disclosures</button>
    </div>
  </div>

  <!-- Modal -->
  <div id="modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 max-w-2xl mx-4 max-h-[80vh] overflow-y-auto">
      <div class="flex justify-between items-center mb-4">
        <h3 class="text-lg font-semibold">Legal Disclosures</h3>
        <button id="closeModal" class="text-gray-500 hover:text-gray-700 text-2xl font-bold">&times;</button>
      </div>
      <div class="text-sm text-gray-700 space-y-4">
        <p>
          The Broker Lenders purchase rates are for estimation purposes only. Every situation is different. Results do not reflect all loan programs and are subject to individual program loan limits. Qualification, rates and payments will vary based on timing and individual circumstances. Mortgage rates and pricing could change daily. Actual payments will vary based on your individual situation and current rates. Some products may not be available in all states. Some jumbo products may not be available to first time home buyers. Lending services may not be available in all areas. Some restrictions may apply. This is not a commitment to lend.
        </p>
        
        <div class="space-y-3">
          <p>
            <strong>30-year Fixed-Rate Loan:</strong> An interest rate of 6.375% (6.663% APR) is for the cost of 2.00 point(s) ($7,000.00) paid at closing. On a $350,000 mortgage, you would make monthly payments of $2,183.55. Monthly payment does not include taxes and insurance premiums. The actual payment amount will be greater. Payment assumes a loan-to-value (LTV) of 80.00%.
          </p>
          
          <p>
            <strong>30-year Fixed-Rate VA Loan:</strong> An interest rate of 5.99% (6.372% APR) is for a cost of 1.75 Point(s) ($6,125.00) paid at closing. On a $350,000 mortgage, you would make monthly payments of $2,096.18. Monthly payment does not include taxes and insurance premiums. The actual payment amount will be greater. Payment assumes a loan-to-value (LTV) of 80.00%.
          </p>
          
          <p>
            VA loans do not require PMI. The VA loan is a benefit of military service and only offered to veterans, surviving spouses and active duty military.
          </p>
          
          <p>
            <strong>30-year Fixed-Rate Loan (Jumbo):</strong> An interest rate of 5.625% (5.829% APR) is for the cost of 1.75 point(s) ($19,250.00) paid at closing. On a $1,100,000 mortgage, you would make monthly payments of $6,332.23. Monthly payment does not include taxes and insurance premiums. The actual payment amount will be greater. Payment assumes a loan-to-value (LTV) of 70.00%.
          </p>
          
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .carousel-container {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 0;
    animation: scroll 90s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  .rate-item {
    flex: 0 0 300px;
    min-width: 300px;
  }

  @media (max-width: 640px) {
    .rate-item {
      flex: 0 0 260px;
      min-width: 260px;
    }
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Fix for Tailwind CSS dynamic color classes */
  .bg-red-500 {
    background-color: rgb(239 68 68);
  }
  .bg-green-500 {
    background-color: rgb(34 197 94);
  }
</style>

<script>
  // Modal functionality
  const modal = document.getElementById('modal');
  const openModalBtn = document.getElementById('openModal');
  const closeModalBtn = document.getElementById('closeModal');

  openModalBtn?.addEventListener('click', () => {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
  });

  closeModalBtn?.addEventListener('click', () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  });

  // Close modal when clicking outside
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
    }
  });
</script>