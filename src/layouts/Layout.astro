---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
	title: string;
  lang?: string;
}

const { title, lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Broker Lenders - Home loans made for your lifestyle" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <!-- Early i18n sync: persist SSR lang to localStorage/cookie and URL -->
    <script is:inline>
      (() => {
        try {
          const url = new URL(window.location.href);
          const urlLang = (url.searchParams.get('lang') || '').toLowerCase();
          const ssrLang = (document.documentElement.getAttribute('lang') || 'en').toLowerCase();
          const initial = (urlLang === 'es' || urlLang === 'en') ? urlLang : ssrLang;
          // Reflect chosen lang in <html>
          try { document.documentElement.setAttribute('lang', initial); } catch {}
          // Persist to localStorage & cookie
          try { localStorage.setItem('lang', initial); } catch {}
          try { document.cookie = `lang=${initial};path=/;max-age=31536000;SameSite=Lax`; } catch {}
          // Ensure URL keeps the chosen language without reload
          try {
            const current = (url.searchParams.get('lang') || '').toLowerCase();
            if (current !== initial) {
              url.searchParams.set('lang', initial);
              window.history.replaceState({}, '', url.toString());
            }
          } catch {}
        } catch (e) {
          console.warn('[i18n][layout] early sync failed', e);
        }
      })();
    </script>
	</head>
	<body class="bg-white text-gray-900 font-sans">
		<Header lang={lang} />
		<main>
			<slot />
		</main>
		<Footer lang={lang} />
	</body>
</html>

<style>
	html {
		font-family: system-ui, sans-serif;
	}
</style>