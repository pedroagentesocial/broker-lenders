---
import Layout from '../layouts/Layout.astro';
import ImportantLegal from '../components/ImportantLegal.astro';
import en from '../translations/realtors/en.json';
import es from '../translations/realtors/es.json';

export const prerender = true;

const lang = 'en';
const dict = en;
const enB64 = Buffer.from(JSON.stringify(en)).toString('base64');
const esB64 = Buffer.from(JSON.stringify(es)).toString('base64');
const resultIcons = [
  'M13 7h8m0 0v8m0-8L11 17l-4-4-6 6',
  'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  'M8 7V3m8 4V3m-9 8h10m-12 10h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  'M9 12l2 2 4-4m5 2a9 9 0 11-18 0 9 9 0 0118 0z'
];
const callGuideItems = [
  { key: 'callGuide.hook', text: dict.callGuide.hook },
  { key: 'callGuide.problem', text: dict.callGuide.problem },
  { key: 'callGuide.solution', text: dict.callGuide.solution },
  { key: 'callGuide.offer', text: dict.callGuide.offer },
  { key: 'callGuide.close', text: dict.callGuide.close }
].map((item, index) => ({ ...item, step: index + 1 }));
---

<Layout title={dict.title} lang={lang}>
  <section class="relative h-[520px] overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/hero-realtors.jpg"
        alt="Real estate meeting"
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/55"></div>
    </div>
    <div class="relative z-10 mx-auto flex h-full max-w-7xl items-center px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl rounded-[48px] bg-black/30 p-8 lg:p-12">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.15em] text-red-600" data-i18n="hero.eyebrow">{dict.hero.eyebrow}</p>
        <h1 class="mb-5 text-4xl font-bold text-white lg:text-5xl">
          <span data-i18n="hero.headline">{dict.hero.headline}</span><br />
          <span data-i18n="hero.subheadline">{dict.hero.subheadline}</span>
        </h1>
        <p class="mb-8 text-lg text-gray-200" data-i18n="hero.description">{dict.hero.description}</p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a id="realtor-cta-demo" href="/booking?lang=en" class="inline-block rounded-[48px] bg-white px-8 py-3 font-semibold text-black transition-all duration-300 hover:shadow-[0_0_28px_rgba(255,255,255,0.85)]" data-i18n="hero.primaryCta">{dict.hero.primaryCta}</a>
          <a href="tel:+18013070273" class="inline-block rounded-[48px] border border-gray-300 px-8 py-3 font-semibold text-white transition-colors hover:bg-white hover:text-black" data-i18n="hero.secondaryCta">{dict.hero.secondaryCta}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-18">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <h2 class="mb-4 text-3xl font-bold text-gray-900" data-i18n="problem.title">{dict.problem.title}</h2>
        <p class="mx-auto max-w-3xl text-lg text-gray-600" data-i18n="problem.intro">{dict.problem.intro}</p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:auto-rows-fr">
        {dict.problem.items.map((item, index) => (
          <div class="flex h-full min-h-[200px] flex-col rounded-[42px] border-2 border-gray-200 bg-gray-50 p-5">
            <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-black text-xl font-bold text-white">
              {index + 1}
            </div>
            <p class="text-left leading-snug text-gray-800" data-i18n={`problem.items.${index}`}>{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-18">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-bold text-gray-900" data-i18n="solution.title">{dict.solution.title}</h2>
      <div class="rounded-[42px] bg-gray-50 p-6 lg:p-8">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:items-stretch">
          <div class="flex flex-col gap-6">
            <div class="rounded-[32px] bg-white p-8">
            <h3 class="mb-5 text-2xl font-bold text-gray-900" data-i18n="solution.lending.title">{dict.solution.lending.title}</h3>
            <ul class="space-y-3">
              {dict.solution.lending.items.map((item, index) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 inline-block h-2.5 w-2.5 rounded-full bg-black"></span>
                  <span class="text-gray-700" data-i18n={`solution.lending.items.${index}`}>{item}</span>
                </li>
              ))}
            </ul>
            </div>
            <div class="rounded-[32px] bg-white p-8">
              <h3 class="mb-5 text-2xl font-bold text-gray-900" data-i18n="solution.crm.title">{dict.solution.crm.title}</h3>
              <ul class="space-y-3">
                {dict.solution.crm.items.map((item, index) => (
                  <li class="flex items-start gap-3">
                    <span class="mt-1 inline-block h-2.5 w-2.5 rounded-full bg-black"></span>
                    <span class="text-gray-700" data-i18n={`solution.crm.items.${index}`}>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <div class="h-full overflow-hidden rounded-[32px]">
            <img src="/realtors1.jpg" alt="Our two-part system for realtors" class="h-full min-h-[460px] w-full rounded-[32px] object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-[40px] bg-black px-8 py-10 text-center text-white">
        <h2 class="mb-3 text-3xl font-bold" data-i18n="differentiator.title">{dict.differentiator.title}</h2>
        <p class="mx-auto max-w-4xl text-lg text-gray-200" data-i18n="differentiator.description">{dict.differentiator.description}</p>
      </div>
    </div>
  </section>

  <section class="bg-white py-18">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-bold text-gray-900" data-i18n="offers.title">{dict.offers.title}</h2>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
        <div class="flex h-full min-h-[260px] flex-col rounded-[42px] border border-gray-300 bg-white p-8 lg:col-span-12">
          <p class="mb-3 inline-flex w-fit rounded-full bg-black px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-white">Most Popular</p>
          <h3 class="mb-2 text-2xl font-bold text-gray-900" data-i18n="offers.partner.name">{dict.offers.partner.name}</h3>
          <p class="mb-6 text-sm font-semibold uppercase tracking-[0.12em] text-gray-900" data-i18n="offers.partner.price">{dict.offers.partner.price}</p>
          <ul class="space-y-3 text-gray-700">
            {dict.offers.partner.items.map((item, index) => (
              <li class="flex items-start gap-3" data-i18n={`offers.partner.items.${index}`}>
                <span class="mt-1.5 inline-block h-2.5 w-2.5 rounded-full bg-black"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="flex h-full min-h-[330px] flex-col rounded-[42px] border border-gray-200 bg-gray-50 p-8 lg:col-span-6">
          <h3 class="mb-2 text-2xl font-bold text-gray-900" data-i18n="offers.pro.name">{dict.offers.pro.name}</h3>
          <p class="mb-6 text-sm font-semibold uppercase tracking-[0.12em] text-gray-900" data-i18n="offers.pro.price">{dict.offers.pro.price}</p>
          <ul class="space-y-3 text-gray-700">
            {dict.offers.pro.items.map((item, index) => (
              <li class="flex items-start gap-3" data-i18n={`offers.pro.items.${index}`}>
                <span class="mt-1.5 inline-block h-2.5 w-2.5 rounded-full bg-black"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="flex h-full min-h-[330px] flex-col rounded-[42px] bg-black p-8 text-white lg:col-span-6">
          <h3 class="mb-2 text-2xl font-bold" data-i18n="offers.advanced.name">{dict.offers.advanced.name}</h3>
          <p class="mb-6 text-sm font-semibold uppercase tracking-[0.12em] text-gray-200" data-i18n="offers.advanced.price">{dict.offers.advanced.price}</p>
          <ul class="space-y-3 text-gray-100">
            {dict.offers.advanced.items.map((item, index) => (
              <li class="flex items-start gap-3" data-i18n={`offers.advanced.items.${index}`}>
                <span class="mt-1.5 inline-block h-2.5 w-2.5 rounded-full bg-white"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/booking?lang=en" class="inline-flex items-center rounded-[48px] bg-black px-8 py-3 font-semibold text-white transition-colors hover:bg-red-600" data-i18n="finalCta.primaryCta">
          {dict.finalCta.primaryCta}
        </a>
        <a href="tel:+18013070273" class="inline-flex items-center rounded-[48px] border border-black px-8 py-3 font-semibold text-black transition-colors hover:bg-gray-100">
          Call Now
        </a>
      </div>
    </div>
  </section>

  <section class="bg-white py-18">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-bold text-gray-900" data-i18n="results.title">{dict.results.title}</h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        {dict.results.items.map((item, index) => (
          <div class="rounded-[32px] border border-gray-200 bg-gray-50 p-6">
            <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-black text-white">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={resultIcons[index % resultIcons.length]}></path>
              </svg>
            </div>
            <p class="text-center text-lg font-semibold text-gray-800" data-i18n={`results.items.${index}`}>{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-18">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:items-start">
        <div class="overflow-hidden rounded-[36px] lg:self-start">
          <img src="/realtors2.JPG" alt="Simple call flow for realtors" class="h-[720px] w-full rounded-[36px] object-cover" />
        </div>
        <div class="flex flex-col gap-6">
          <div class="rounded-[36px] border border-gray-200 bg-gray-50 p-8 text-center">
            <h2 class="mb-5 text-2xl font-bold text-gray-900" data-i18n="callGuide.title">{dict.callGuide.title}</h2>
            <ul class="space-y-4 text-left">
              {callGuideItems.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="inline-flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-black text-sm font-bold text-white">{item.step}</span>
                  <span class="pt-1 text-gray-700" data-callguide-text="true" data-i18n={item.key}>{item.text}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="rounded-[36px] bg-black p-8 text-center text-white">
            <h2 class="mb-5 text-2xl font-bold" data-i18n="phrases.title">{dict.phrases.title}</h2>
            <div class="flex flex-wrap justify-center gap-3">
              {dict.phrases.items.map((item, index) => (
                <span class="rounded-full border border-white/30 px-4 py-2 text-sm text-gray-100" data-i18n={`phrases.items.${index}`}>{item}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-18">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="p-10 text-center lg:p-14">
        <p class="mb-6 text-3xl font-bold leading-tight text-gray-900">
          We are not only lenders.<br />
          We are the system that helps you close more deals.
        </p>
        <div class="mb-6 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a id="realtor-final-demo" href="/booking?lang=en" class="inline-block rounded-[48px] bg-black px-8 py-4 text-lg font-semibold text-white transition-colors hover:bg-red-600" data-i18n="finalCta.primaryCta">{dict.finalCta.primaryCta}</a>
          <a id="realtor-final-book" href="/booking?lang=en" class="inline-block rounded-[48px] border border-black px-8 py-4 text-lg font-semibold text-black transition-colors hover:bg-gray-100" data-i18n="finalCta.secondaryCta">{dict.finalCta.secondaryCta}</a>
        </div>
      </div>
    </div>
  </section>

  <ImportantLegal />
</Layout>

<div id="i18n-realtors" data-en={enB64} data-es={esB64} style="display:none"></div>

<script is:inline>
  (() => {
    const root = document.getElementById('i18n-realtors');
    const decode = (val) => {
      try {
        const b64 = val || '';
        const bin = atob(b64);
        const bytes = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
        const jsonText = new TextDecoder('utf-8').decode(bytes);
        return JSON.parse(jsonText);
      } catch {
        return {};
      }
    };

    const translations = {
      en: decode(root?.getAttribute('data-en') || ''),
      es: decode(root?.getAttribute('data-es') || ''),
    };

    const getValue = (obj, path) => {
      return path.split('.').reduce((acc, key) => (acc && key in acc ? acc[key] : null), obj);
    };

    const getInitialLang = () => {
      const urlLang = new URLSearchParams(window.location.search).get('lang');
      const stored = localStorage.getItem('lang');
      const raw = (urlLang || stored || 'en').toLowerCase();
      return raw === 'es' ? 'es' : 'en';
    };

    const keepLangOnCtas = (lang) => {
      const ids = ['realtor-cta-demo', 'realtor-final-demo', 'realtor-final-book'];
      ids.forEach((id) => {
        const link = document.getElementById(id);
        if (!link) return;
        try {
          const url = new URL(link.href, window.location.origin);
          if (url.origin === window.location.origin) {
            url.searchParams.set('lang', lang);
            link.href = `${url.pathname}${url.search}${url.hash}`;
          }
        } catch {}
      });
    };

    const apply = (lang) => {
      const dict = translations[lang] || translations.en;
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n');
        if (!key) return;
        const value = getValue(dict, key);
        if (typeof value === 'string') el.textContent = value;
      });
      // Keep numbered call-flow badges as the visual bullets.
      document.querySelectorAll('[data-callguide-text]').forEach((el) => {
        if (!(el instanceof HTMLElement)) return;
        el.textContent = (el.textContent || '').replace(/^\s*\d+\.\s*/, '');
      });
      if (dict.title) document.title = dict.title;
      keepLangOnCtas(lang);
    };

    const setLanguage = (lang) => {
      const next = lang === 'es' ? 'es' : 'en';
      localStorage.setItem('lang', next);
      try { document.cookie = `lang=${next}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Lax`; } catch {}
      const url = new URL(window.location.href);
      url.searchParams.set('lang', next);
      window.history.replaceState({}, '', url.toString());
      apply(next);
    };

    setLanguage(getInitialLang());

    document.addEventListener('click', (e) => {
      const target = e.target instanceof Element ? e.target.closest('a[href*="?lang="]') : null;
      if (!target) return;
      let href = null;
      try { href = new URL(target.href, window.location.origin); } catch { href = null; }
      const lang = href?.searchParams.get('lang');
      if (lang) apply(lang);
    });

    window.addEventListener('storage', (ev) => {
      if (ev.key === 'lang' && ev.newValue) apply(ev.newValue);
    });

    window.addEventListener('popstate', () => {
      apply(getInitialLang());
    });
  })();
</script>
