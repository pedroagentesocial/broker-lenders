---
import Layout from '../../layouts/Layout.astro';
import Contact from '../../components/Contact.astro';
import ImportantLegal from '../../components/ImportantLegal.astro';
import NextMoveSection from '../../components/NextMoveSection.astro';
---

<Layout title="Mortgage Calculator - Broker Lenders®">
	<!-- Breadcrumb -->
	<section class="bg-white py-4">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<nav class="flex" aria-label="Breadcrumb">
				<ol class="flex items-center space-x-4">
					<li>
						<div>
							<a href="/" class="text-gray-400 hover:text-gray-500 text-sm font-medium">
								Home
							</a>
						</div>
					</li>
					<li>
						<div class="flex items-center">
							<svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
							</svg>
							<a href="/calculators" class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700">Calculators</a>
						</div>
					</li>
					<li>
						<div class="flex items-center">
							<svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
							</svg>
							<span class="ml-4 text-sm font-medium text-gray-500">Mortgage Calculator</span>
						</div>
					</li>
				</ol>
			</nav>
		</div>
	</section>

	<!-- Main Calculator Section -->
	<section class="py-8 bg-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8">
				<h1 class="text-2xl font-bold text-gray-900 mb-3">Mortgage calculator</h1>
				<p class="text-base text-gray-600 max-w-2xl mx-auto">
					Calculate your monthly mortgage payment and see how much home you can afford. 
					Our calculator includes principal, interest, taxes, insurance, and more.
				</p>
			</div>

			<!-- 2-Column Layout Container -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
				<!-- Left Column: Calculator Form -->
				<div class="bg-gray-100 p-4 rounded-xl shadow-lg border border-gray-200">
					<form id="mortgage-form" class="space-y-4">
						<!-- Home Price -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start px-1.5 mb-0.5">
								<span class="text-xs font-medium text-gray-700">Home price</span>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="homePrice" 
									name="homePrice"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="0"
								>
							</div>
						</div>

						<!-- Down Payment -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start px-1.5 mb-0.5">
								<span class="text-xs font-medium text-gray-700">Down payment</span>
							</div>
							<!-- Input Field with Toggle Buttons -->
							<div class="flex space-x-2">
								<div class="relative flex-1">
									<span id="downPaymentSymbol" class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
									<input 
										type="text" 
										id="downPayment" 
										name="downPayment"
										class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
										placeholder="0"
									>
								</div>
								<!-- Toggle Button -->
								<div class="flex space-x-1">
									<button 
										type="button" 
										id="toggleDollar" 
										class="px-2 py-1.5 text-xs font-medium rounded-md transition-all duration-200 bg-gray-900 border border-gray-900 text-white hover:bg-gray-800"
									>
										$
									</button>
									<button 
										type="button" 
										id="togglePercent" 
										class="px-2 py-1.5 text-xs font-medium rounded-md transition-all duration-200 bg-white border border-gray-300 text-gray-600 hover:bg-gray-50"
									>
										%
									</button>
								</div>
							</div>
						</div>

						<!-- Loan Term and Interest Rate (Same Row) -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
							<!-- Loan Term -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
								<div class="flex justify-start items-center px-1.5 mb-0.5">
									<span class="text-xs font-medium text-gray-700">Loan term</span>
									<!-- Info Icon with Tooltip -->
									<div class="relative ml-2 group">
										<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
											<span class="text-white text-xs font-bold">i</span>
										</div>
										<!-- Tooltip -->
										<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-32 text-center leading-tight">
											Plazo: 30 años pagos bajos, 15 años menos interés
											<!-- Arrow pointing down -->
											<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
										</div>
									</div>
								</div>
								<!-- Select Field -->
								<select 
									id="loanTerm" 
									name="loanTerm"
									class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
								>
									<option value="15">15 years</option>
									<option value="20">20 years</option>
									<option value="30" selected>30 years</option>
								</select>
							</div>

							<!-- Interest Rate -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
								<div class="flex justify-start items-center px-1.5 mb-0.5">
									<span class="text-xs font-medium text-gray-700">Interest rate</span>
									<!-- Info Icon with Tooltip -->
									<div class="relative ml-2 group">
										<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
											<span class="text-white text-xs font-bold">i</span>
										</div>
										<!-- Tooltip -->
										<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-10 w-32 text-center leading-tight">
											Tasa de interés: mayor tasa = pagos más altos
											<!-- Arrow pointing down -->
											<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
										</div>
									</div>
								</div>
								<!-- Input Field -->
								<div class="relative">
									<input 
										type="text" 
										id="interestRate" 
										name="interestRate"
										value="5.99"
										maxlength="4"
										class="w-full pl-1.5 pr-5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
										placeholder="5.99"
									>
									<span class="absolute right-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">%</span>
								</div>
							</div>
						</div>

						<!-- ZIP Code Container -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start px-1.5 mb-0.5">
								<span class="text-xs font-medium text-gray-700">ZIP code</span>
							</div>
							<!-- Input Field -->
							<input 
								type="text" 
								id="zipCode" 
								name="zipCode"
								value=""
								class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
								placeholder="Value"
							>
						</div>

						<!-- Optional Collapsible Section -->
						<div class="pt-3">
							<button 
								type="button"
								id="optionalToggle"
								class="flex items-center justify-between w-full text-left text-sm font-medium text-gray-600 hover:text-gray-800 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 rounded-lg p-1.5"
								aria-expanded="false"
								aria-controls="optionalFields"
							>
								<span>Optional: Enter taxes & insurance</span>
								<svg 
									id="chevronIcon"
									class="w-5 h-5 transform transition-transform duration-200" 
									fill="none" 
									stroke="currentColor" 
									viewBox="0 0 24 24"
								>
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
								</svg>
							</button>
							
							<div 
								id="optionalFields" 
								class="overflow-hidden transition-all duration-300 ease-in-out"
								style="max-height: 0;"
								aria-hidden="true"
							>
								<div class="pt-3 space-y-4">
									<!-- Yearly Property Tax -->
									<div class="bg-white p-1.5 rounded-lg">
										<!-- Label positioned above input, aligned with placeholder text -->
										<div class="flex justify-start items-center px-1.5 mb-0.5">
											<span class="text-xs font-medium text-gray-700">Yearly property taxes</span>
											<!-- Info Icon with Tooltip -->
											<div class="relative ml-2 group">
												<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
													<span class="text-white text-xs font-bold">i</span>
												</div>
												<!-- Tooltip -->
												<div class="absolute top-full left-1/2 transform -translate-x-1/2 mt-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-32 text-center leading-tight">
													Impuestos anuales: varían por ciudad y valor de propiedad
													<!-- Arrow pointing up -->
													<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-b-2 border-transparent border-b-black"></div>
												</div>
											</div>
										</div>
										<!-- Input Field -->
										<div class="relative">
											<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
											<input 
												type="text" 
												id="propertyTax" 
												name="propertyTax"
												class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
												placeholder="0"
											>
										</div>
									</div>

									<!-- Yearly Home Insurance -->
									<div class="bg-white p-1.5 rounded-lg">
										<!-- Label positioned above input, aligned with placeholder text -->
										<div class="flex justify-start items-center px-1.5 mb-0.5">
											<span class="text-xs font-medium text-gray-700">Yearly homeowners insurance</span>
											<!-- Info Icon with Tooltip -->
											<div class="relative ml-2 group">
												<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
													<span class="text-white text-xs font-bold">i</span>
												</div>
												<!-- Tooltip -->
												<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-32 text-center leading-tight">
													Seguro anual: protege contra daños y desastres naturales
													<!-- Arrow pointing down -->
													<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
												</div>
											</div>
										</div>
										<!-- Input Field -->
										<div class="relative">
											<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
											<input 
												type="text" 
												id="homeInsurance" 
												name="homeInsurance"
												class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
												placeholder="0"
											>
										</div>
									</div>
								</div>
							</div>
						</div>
					</form>
					
					<!-- Calculate Button -->
					<div class="mt-4">
						<button 
							id="calculateButton"
							type="button"
							class="w-full bg-black text-white py-3 px-4 rounded-[48px] text-base font-semibold hover:bg-gray-800 transition-colors duration-200"
						>
							Calculate
						</button>
					</div>
					
					<!-- Logo and Legal Disclosures -->
					<div class="mt-4 flex items-center justify-center space-x-2 text-xs text-gray-500">
						<img 
							src="/BL logo negro.png" 
							alt="Broker Lenders Logo" 
							class="h-6 w-auto"
						>
						<span>|</span>
						<button 
							id="legalDisclosuresBtn"
							class="underline hover:text-gray-700 transition-colors cursor-pointer"
						>
							Legal disclosures
						</button>
					</div>
				</div>

				<!-- Right Column: Results and Message Cards -->
				<div class="space-y-4">
					<!-- Results Card -->
					<div id="resultsCard" class="bg-blue-600/10 px-3 py-3 rounded-xl shadow-lg text-gray-900 max-h-60 flex flex-col justify-center">
						<div class="mt-2 mb-6 text-center">
							<div class="text-sm font-bold text-gray-700 mb-2">Estimate monthly payment</div>
							<div class="text-5xl font-bold mb-2" id="monthlyPayment">$0</div>
						</div>

						<!-- Breakdown in horizontal layout -->
						<div class="grid grid-cols-3 gap-1 mb-3">
							<div class="text-center">
								<div class="text-xl font-bold mb-0.5" id="principalInterest">$0</div>
								<div class="text-[10px] text-gray-600">Principal & Interest</div>
							</div>
							<div class="text-center">
								<div class="text-xl font-bold mb-0.5" id="monthlyPropertyTax">$0</div>
								<div class="text-[10px] text-gray-600">Property tax</div>
							</div>
							<div class="text-center">
								<div class="text-xl font-bold mb-0.5" id="monthlyHomeInsurance">$0</div>
								<div class="text-[10px] text-gray-600">Home insurance</div>
							</div>
						</div>

						<!-- Button -->
						<div class="text-left">
							<button class="mt-2 mb-2 px-6 py-3 border border-gray-400 text-gray-700 bg-transparent rounded-full hover:bg-gray-100 transition-colors text-xs font-bold">
								I want real number →
							</button>
						</div>
					</div>

					<!-- Message Card -->
					<div id="messageCard" class="bg-gray-100 p-4 rounded-xl shadow-lg">
						<div class="text-center">
							<p class="text-gray-700 text-base mb-4">Ready to take the next step? Our mortgage specialists are here to help you make your dream of homeownership a reality.</p>
							<button id="callNowBtn" class="bg-black hover:bg-gray-800 text-white font-bold py-2.5 px-6 rounded-full transition-colors duration-200 flex items-center justify-center mx-auto text-sm">
								<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
								</svg>
								Call Now
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Legal Disclosures Modal -->
	<div id="legalModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
		<div class="bg-white rounded-[48px] max-w-4xl w-full max-h-[80vh] overflow-y-auto p-8 relative">
			<!-- Close Button -->
			<button 
				id="closeModal" 
				class="absolute top-6 right-6 text-gray-400 hover:text-gray-600 transition-colors"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>
			
			<!-- Modal Content -->
			<div class="pr-8">
				<h2 class="text-2xl font-bold text-gray-900 mb-6">Legal Disclosures</h2>
				
				<div class="space-y-6 text-gray-700 leading-relaxed">
					<p>
						The Broker Lenders mortgage calculator is for estimation purposes only. Results do not reflect all loan programs and are subject to individual program loan limits. Qualification, rates and payments will vary based on timing and individual circumstances. This is not a commitment to lend.
					</p>
					
					<div>
						<h3 class="text-lg font-semibold text-gray-900 mb-3">Payment Example</h3>
						<p class="mb-3">Here's a payment example based on an average home price and the most common loan type:</p>
						
						<div class="bg-gray-50 p-4 rounded-lg space-y-2">
							<p><strong>Loan amount:</strong> $300,000</p>
							<p><strong>Loan type:</strong> 30-year Fixed-Rate Loan</p>
							<p><strong>Interest rate/APR:</strong> 7.375% (7.692% APR)</p>
							<p><strong>Monthly payment:</strong> $2,072.03</p>
							<p><strong>Points:</strong> 1.875 points, costs due at closing</p>
							<p><strong>Loan-to-value (LTV):</strong> 80.00%</p>
						</div>
					</div>
					
					<div class="space-y-3">
						<p>
							One point is equal to one percent of your loan amount. Payment does not include taxes and insurance. The actual payment amount will be greater. Some state and county maximum loan amount restrictions may apply. Rates shown are valid on publication date of April 18, 2024.
						</p>
						
						<p class="text-sm">
							¹If you didn't enter taxes and insurance amounts, an estimate of your taxes is based on the state selected. This does not include all fees.
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Next Move Section -->
	<NextMoveSection />

	<!-- How to use section -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">How to use a mortgage calculator</h2>
				<p class="text-lg text-gray-600">
					Our mortgage calculator helps you estimate your monthly payments and understand the true cost of homeownership.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Enter Home Details</h3>
					<p class="text-gray-600">
						Start by entering the home price and your down payment amount. The calculator will automatically 
						update your loan amount and monthly payment estimates.
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Adjust Loan Terms</h3>
					<p class="text-gray-600">
						Choose your loan term (15, 20, or 30 years) and interest rate. Shorter terms mean higher 
						monthly payments but less interest paid over time.
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Include Additional Costs</h3>
					<p class="text-gray-600">
						Don't forget to include property taxes, home insurance, PMI, and HOA fees. These can 
						significantly impact your total monthly housing payment.
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
						</svg>
					</div>
