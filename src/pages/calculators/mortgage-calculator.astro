<script>
	
	// Mortgage Calculator Logic
	class MortgageCalculator {
		isPercentMode;
		lastCalculation;
		
		constructor() {
			this.isPercentMode = false;
			this.initializeEventListeners();
			// Cards are visible by default - no need to clear results on init
		}

		initializeEventListeners() {
			// Remove automatic calculation - only format inputs on change
			const inputs = document.querySelectorAll('#mortgage-form input, #mortgage-form select');
			inputs.forEach(input => {
				input.addEventListener('input', () => {
					this.clearFieldValidation(input.id);
					this.formatInputs();
				});
				input.addEventListener('change', () => {
					this.clearFieldValidation(input.id);
					this.formatInputs();
				});
			});

			// Toggle button event listeners
			const toggleDollar = document.getElementById('toggleDollar');
			const togglePercent = document.getElementById('togglePercent');
			
			if (toggleDollar) {
				toggleDollar.addEventListener('click', () => this.setToggleMode(false));
			}
			if (togglePercent) {
				togglePercent.addEventListener('click', () => this.setToggleMode(true));
			}

			// Calculate button event listener - now with validation
			const calculateButton = document.getElementById('calculateButton');
			console.log('Calculate button found:', calculateButton);
			if (calculateButton) {
				calculateButton.addEventListener('click', () => this.handleCalculateClick());
			}

			// Down payment input listener with validation
			const downPaymentInput = document.getElementById('downPayment');
			if (downPaymentInput) {
				downPaymentInput.addEventListener('input', () => this.handleDownPaymentChange());
				downPaymentInput.addEventListener('blur', () => this.validateDownPayment());
			}

			// Interest rate input validation
			const interestRateInput = document.getElementById('interestRate');
			if (interestRateInput) {
				interestRateInput.addEventListener('input', (e) => this.validateInterestRate(e));
			}

			// ZIP code validation
			const zipCodeInput = document.getElementById('zipCode');
			if (zipCodeInput) {
				zipCodeInput.addEventListener('input', (e) => this.validateZipCode(e));
				zipCodeInput.addEventListener('blur', (e) => this.validateZipCodeExists(e));
			}

			// Optional section toggle
			const optionalToggle = document.getElementById('optionalToggle');
			if (optionalToggle) {
				optionalToggle.addEventListener('click', () => this.toggleOptionalSection());
			}

			// Legal disclosures modal event listeners
			const legalDisclosuresBtn = document.getElementById('legalDisclosuresBtn');
			const legalModal = document.getElementById('legalModal');
			const closeModal = document.getElementById('closeModal');

			if (legalDisclosuresBtn && legalModal) {
				legalDisclosuresBtn.addEventListener('click', () => {
					legalModal.classList.remove('hidden');
				});
			}

			if (closeModal && legalModal) {
				closeModal.addEventListener('click', () => {
					legalModal.classList.add('hidden');
				});
			}

			// Close modal when clicking outside
			if (legalModal) {
				legalModal.addEventListener('click', (e) => {
					if (e.target === legalModal) {
						legalModal.classList.add('hidden');
					}
				});
			}

			// Call Now button event listener
			const callNowBtn = document.getElementById('callNowBtn');
			if (callNowBtn) {
				callNowBtn.addEventListener('click', () => {
					window.location.href = 'tel:+1234567890'; // Replace with actual phone number
				});
			}
		}

		setToggleMode(isPercent) {
			this.isPercentMode = isPercent;
			
			const toggleDollar = document.getElementById('toggleDollar');
			const togglePercent = document.getElementById('togglePercent');
			const downPaymentSymbol = document.getElementById('downPaymentSymbol');
			const downPaymentInput = document.getElementById('downPayment') as HTMLInputElement;
			
			if (toggleDollar && togglePercent && downPaymentSymbol && downPaymentInput) {
				if (isPercent) {
					// Switch to percent mode
					toggleDollar.className = 'px-3 py-2 text-sm font-medium rounded-md transition-all duration-200 bg-white border border-gray-300 text-gray-600 hover:bg-gray-50';
					togglePercent.className = 'px-3 py-2 text-sm font-medium rounded-md transition-all duration-200 bg-gray-900 border border-gray-900 text-white hover:bg-gray-800';
					downPaymentSymbol.textContent = '%';
					
					// Convert current dollar value to percentage
					const homePrice = this.parseNumber((document.getElementById('homePrice') as HTMLInputElement)?.value || '0');
					const currentAmount = this.parseNumber(downPaymentInput.value);
					if (homePrice > 0 && currentAmount > 0) {
						const percentage = (currentAmount / homePrice * 100).toFixed(1);
						downPaymentInput.value = percentage;
					} else {
						// Auto-set to 1% if value is 0 or invalid
						downPaymentInput.value = '1';
					}
				} else {
					// Switch to dollar mode
					toggleDollar.className = 'px-3 py-2 text-sm font-medium rounded-md transition-all duration-200 bg-gray-900 border border-gray-900 text-white hover:bg-gray-800';
					togglePercent.className = 'px-3 py-2 text-sm font-medium rounded-md transition-all duration-200 bg-white border border-gray-300 text-gray-600 hover:bg-gray-50';
					downPaymentSymbol.textContent = '$';
					
					// Convert current percentage to dollar value
					const homePrice = this.parseNumber((document.getElementById('homePrice') as HTMLInputElement)?.value || '0');
					const currentPercent = parseFloat(downPaymentInput.value) || 0;
					const amount = Math.round(homePrice * currentPercent / 100);
					downPaymentInput.value = amount > 0 ? this.formatNumber(amount) : '0';
				}
			}
			
			this.calculate();
		}

		handleDownPaymentChange() {
			// This method handles changes to the down payment input
			// The actual calculation will be triggered by the input event
		}

		validateDownPayment() {
			if (this.isPercentMode) {
				const downPaymentInput = document.getElementById('downPayment') as HTMLInputElement;
				if (downPaymentInput) {
					const value = parseFloat(downPaymentInput.value) || 0;
					if (value < 1) {
						downPaymentInput.value = '1';
						this.calculate();
					}
				}
			}
		}

		validateInterestRate(e) {
			const input = e.target;
			let value = input.value;
			
			// Remove any non-numeric characters except decimal point
			value = value.replace(/[^0-9.]/g, '');
			
			// Ensure only one decimal point
			const parts = value.split('.');
			if (parts.length > 2) {
				value = parts[0] + '.' + parts.slice(1).join('');
			}
			
			// Limit to 4 characters total (e.g., 5.99, 12.5, 99.9)
			if (value.length > 4) {
				value = value.substring(0, 4);
			}
			
			// Update the input value
			input.value = value;
		}

		validateZipCode(e) {
			const input = e.target;
			let value = input.value;
			
			// Remove any non-numeric characters
			value = value.replace(/[^0-9]/g, '');
			
			// Limit to 5 digits for US ZIP codes
			if (value.length > 5) {
				value = value.substring(0, 5);
			}
			
			// Update the input value
			input.value = value;
		}

		async validateZipCodeExists(e) {
			const input = e.target;
			const zipCode = input.value;
			
			// Reset border color
			input.classList.remove('border-red-500');
			input.classList.add('border-gray-300');
			
			if (zipCode.length === 5) {
				try {
					// Use a free ZIP code API to validate
					const response = await fetch(`https://api.zippopotam.us/us/${zipCode}`);
					if (!response.ok) {
						// ZIP code doesn't exist
						input.classList.remove('border-gray-300');
						input.classList.add('border-red-500');
						input.title = 'ZIP code not found';
					} else {
						input.title = '';
					}
				} catch (error) {
					// If API fails, don't show error (graceful degradation)
					console.log('ZIP code validation API unavailable');
				}
			}
		}

		toggleOptionalSection() {
			const optionalFields = document.getElementById('optionalFields');
			const chevronIcon = document.getElementById('chevronIcon');
			const toggleButton = document.getElementById('optionalToggle');
			
			if (optionalFields && chevronIcon && toggleButton) {
				const isExpanded = toggleButton.getAttribute('aria-expanded') === 'true';
				
				if (isExpanded) {
					// Close the section
					optionalFields.style.maxHeight = '0px';
					optionalFields.setAttribute('aria-hidden', 'true');
					toggleButton.setAttribute('aria-expanded', 'false');
					chevronIcon.style.transform = 'rotate(0deg)';
				} else {
					// Open the section
					optionalFields.style.maxHeight = optionalFields.scrollHeight + 'px';
					optionalFields.setAttribute('aria-hidden', 'false');
					toggleButton.setAttribute('aria-expanded', 'true');
					chevronIcon.style.transform = 'rotate(180deg)';
				}
			}
		}

		formatNumber(num) {
			return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
		}

		parseNumber(str) {
			return parseFloat(str.replace(/,/g, '')) || 0;
		}

		getDownPaymentAmount() {
			const downPaymentInput = document.getElementById('downPayment') as HTMLInputElement;
			const homePrice = this.parseNumber((document.getElementById('homePrice') as HTMLInputElement)?.value || '0');
			
			if (!downPaymentInput) return 0;
			
			if (this.isPercentMode) {
				const percentage = parseFloat(downPaymentInput.value) || 0;
				return homePrice * percentage / 100;
			} else {
				return this.parseNumber(downPaymentInput.value);
			}
		}

		// New method to handle calculate button click with validation
		handleCalculateClick() {
			console.log('handleCalculateClick called');
			
			// Clear previous validation errors
			this.clearAllValidationErrors();
			
			// Validate all required fields
			if (!this.validateAllFields()) {
				console.log('Validation failed, not calculating');
				return;
			}
			
			// Clear previous results and calculate
			this.clearResults();
			this.calculate();
		}

		// Clear field validation styling and messages
		clearFieldValidation(fieldId: string) {
			const field = document.getElementById(fieldId);
			if (field) {
				// Remove red border from container
				const container = field.closest('.bg-white');
				if (container) {
					container.classList.remove('border-red-500', 'border-2');
				}
				
				// Remove error message
				const errorMsg = document.getElementById(`${fieldId}-error`);
				if (errorMsg) {
					errorMsg.remove();
				}
			}
		}

		// Clear all validation errors
		clearAllValidationErrors() {
			const requiredFields = ['homePrice', 'downPayment', 'loanTerm', 'interestRate', 'propertyTax', 'homeInsurance', 'zipCode'];
			requiredFields.forEach(fieldId => {
				this.clearFieldValidation(fieldId);
			});
		}

		// Validate all required fields
		validateAllFields(): boolean {
			let isValid = true;
			const requiredFields = [
				{ id: 'homePrice', name: 'Home price', type: 'currency' },
				{ id: 'downPayment', name: 'Down payment', type: 'currency' },
				{ id: 'loanTerm', name: 'Loan term', type: 'select' },
				{ id: 'interestRate', name: 'Interest rate', type: 'percentage' },
				{ id: 'propertyTax', name: 'Property tax', type: 'currency' },
				{ id: 'homeInsurance', name: 'Home insurance', type: 'currency' },
				{ id: 'zipCode', name: 'ZIP code', type: 'zipcode' }
			];

			requiredFields.forEach(field => {
				const element = document.getElementById(field.id) as HTMLInputElement | HTMLSelectElement;
				if (element) {
					const value = element.value.trim();
					let fieldValid = true;
					let errorMessage = '';

					// Check if field is empty or invalid
					if (!value || (field.type !== 'select' && field.type !== 'zipcode' && (value === '0' || value === '$0'))) {
						fieldValid = false;
						errorMessage = `${field.name} is required`;
					} else {
						// Additional validation based on field type
						switch (field.type) {
							case 'currency':
								const numValue = this.parseNumber(value);
								if (field.id === 'homePrice' && numValue <= 0) {
									fieldValid = false;
									errorMessage = `${field.name} must be greater than $0`;
								} else if (field.id === 'downPayment' && numValue < 0) {
									fieldValid = false;
									errorMessage = `${field.name} cannot be negative`;
								} else if ((field.id === 'propertyTax' || field.id === 'homeInsurance') && numValue < 0) {
									fieldValid = false;
									errorMessage = `${field.name} cannot be negative`;
								}
								break;
							case 'percentage':
								const percentValue = parseFloat(value);
								if (percentValue <= 0 || percentValue > 50) {
									fieldValid = false;
									errorMessage = `${field.name} must be between 0.1% and 50%`;
								}
								break;
							case 'select':
								if (!value || value === '') {
									fieldValid = false;
									errorMessage = `Please select ${field.name.toLowerCase()}`;
								}
								break;
							case 'zipcode':
								if (!value || value.length !== 5 || !/^\d{5}$/.test(value)) {
									fieldValid = false;
									errorMessage = 'Please enter a valid 5-digit ZIP code';
								}
								break;
						}
					}

					if (!fieldValid) {
						this.showFieldError(field.id, errorMessage);
						isValid = false;
					}
				}
			});

			return isValid;
		}

		// Show error for specific field
		showFieldError(fieldId: string, message: string) {
			const field = document.getElementById(fieldId);
			if (field) {
				// Add red border to the container instead of just the input
				const container = field.closest('.bg-white');
				if (container) {
					container.classList.add('border-red-500', 'border-2');
				}
				
				// Add error message
				const errorDiv = document.createElement('div');
				errorDiv.id = `${fieldId}-error`;
				errorDiv.className = 'text-red-500 text-sm mt-1 px-2';
				errorDiv.textContent = message;
				
				// Insert error message after the field's parent container
				if (container && container.parentNode) {
					container.parentNode.insertBefore(errorDiv, container.nextSibling);
				}
			}
		}

		// Clear results display (but keep cards visible)
		clearResults() {
			const monthlyPaymentEl = document.getElementById('monthlyPayment');
			const principalInterestEl = document.getElementById('principalInterest');
			const monthlyPropertyTaxEl = document.getElementById('monthlyPropertyTax');
			const monthlyHomeInsuranceEl = document.getElementById('monthlyHomeInsurance');

			// Reset to placeholder values instead of hiding cards
			if (monthlyPaymentEl) monthlyPaymentEl.textContent = '$0';
			if (principalInterestEl) principalInterestEl.textContent = '$0';
			if (monthlyPropertyTaxEl) monthlyPropertyTaxEl.textContent = '$0';
			if (monthlyHomeInsuranceEl) monthlyHomeInsuranceEl.textContent = '$0';

			// Cards remain visible - no hiding logic needed
		}



		calculate() {
			console.log('Starting mortgage calculation...');
			
			// Get input values
			const homePrice = this.parseNumber((document.getElementById('homePrice') as HTMLInputElement)?.value || '0');
			const downPayment = this.getDownPaymentAmount();
			const loanTerm = parseInt((document.getElementById('loanTerm') as HTMLSelectElement)?.value || '30');
			const annualInterestRate = parseFloat((document.getElementById('interestRate') as HTMLInputElement)?.value || '0');
			const propertyTax = this.parseNumber((document.getElementById('propertyTax') as HTMLInputElement)?.value || '0');
			const homeInsurance = this.parseNumber((document.getElementById('homeInsurance') as HTMLInputElement)?.value || '0');

			console.log('Input values:', { homePrice, downPayment, loanTerm, annualInterestRate, propertyTax, homeInsurance });

			// Validate inputs
			if (homePrice <= 0) {
				console.log('Invalid home price');
				return;
			}

			// Calculate loan amount (Principal)
			const loanAmount = Math.max(0, homePrice - downPayment);
			console.log('Loan amount (Principal):', loanAmount);

			// Convert annual interest rate to monthly decimal rate
			const monthlyInterestRate = (annualInterestRate / 100) / 12;
			const numberOfPayments = loanTerm * 12;

			console.log('Monthly interest rate:', monthlyInterestRate);
			console.log('Number of payments:', numberOfPayments);

			// Calculate monthly principal and interest using the standard mortgage formula
			// M = P [ r(1 + r)^n ] / [ (1 + r)^n – 1 ]
			let monthlyPrincipalAndInterest = 0;
			
			if (loanAmount > 0) {
				if (monthlyInterestRate > 0) {
					// Standard mortgage formula for interest-bearing loans
					const numerator = loanAmount * (monthlyInterestRate * Math.pow(1 + monthlyInterestRate, numberOfPayments));
					const denominator = Math.pow(1 + monthlyInterestRate, numberOfPayments) - 1;
					monthlyPrincipalAndInterest = numerator / denominator;
				} else {
					// For 0% interest loans, simply divide principal by number of payments
					monthlyPrincipalAndInterest = loanAmount / numberOfPayments;
				}
			}

			console.log('Monthly Principal & Interest:', monthlyPrincipalAndInterest);

			// Calculate total interest paid over the life of the loan
			const totalPrincipalAndInterestPaid = monthlyPrincipalAndInterest * numberOfPayments;
			const totalInterestPaid = totalPrincipalAndInterestPaid - loanAmount;

			console.log('Total interest paid over loan life:', totalInterestPaid);

			// Calculate monthly amounts for other costs
			const monthlyPropertyTax = propertyTax / 12;
			const monthlyHomeInsurance = homeInsurance / 12;

			// Calculate total monthly payment (PITI - Principal, Interest, Taxes, Insurance)
			const totalMonthlyPayment = monthlyPrincipalAndInterest + monthlyPropertyTax + monthlyHomeInsurance;

			console.log('Total monthly payment (PITI):', totalMonthlyPayment);

			// Calculate additional useful metrics
			const totalAmountPaid = (totalMonthlyPayment * numberOfPayments);
			const loanToValueRatio = (loanAmount / homePrice) * 100;
			const downPaymentPercentage = (downPayment / homePrice) * 100;

			console.log('Additional metrics:', {
				totalAmountPaid,
				loanToValueRatio,
				downPaymentPercentage
			});

			// Update display elements
			const monthlyPaymentEl = document.getElementById('monthlyPayment');
			const principalInterestEl = document.getElementById('principalInterest');
			const monthlyPropertyTaxEl = document.getElementById('monthlyPropertyTax');
			const monthlyHomeInsuranceEl = document.getElementById('monthlyHomeInsurance');

			// Format and display results with proper currency formatting
			if (monthlyPaymentEl) {
				// Animate the monthly payment with speedometer effect
				this.animateValue(monthlyPaymentEl, 0, Math.round(totalMonthlyPayment), 1500);
			}
			if (principalInterestEl) {
				principalInterestEl.textContent = '$' + this.formatNumber(Math.round(monthlyPrincipalAndInterest));
			}
			if (monthlyPropertyTaxEl) {
				monthlyPropertyTaxEl.textContent = '$' + this.formatNumber(Math.round(monthlyPropertyTax));
			}
			if (monthlyHomeInsuranceEl) {
				monthlyHomeInsuranceEl.textContent = '$' + this.formatNumber(Math.round(monthlyHomeInsurance));
			}

			// Store calculation results for potential future use
			this.lastCalculation = {
				homePrice,
				downPayment,
				loanAmount,
				loanTerm,
				annualInterestRate,
				monthlyPrincipalAndInterest,
				monthlyPropertyTax,
				monthlyHomeInsurance,
				totalMonthlyPayment,
				totalInterestPaid,
				totalAmountPaid,
				loanToValueRatio,
				downPaymentPercentage
			};

			console.log('Calculation completed successfully');

			// Format input values for better user experience
			this.formatInputs();
		}

		formatInputs() {
			const moneyInputs = ['homePrice', 'propertyTax', 'homeInsurance'];
			moneyInputs.forEach(id => {
				const input = document.getElementById(id) as HTMLInputElement;
				if (input) {
					const value = this.parseNumber(input.value);
					if (value > 0) {
						input.value = this.formatNumber(value);
					}
				}
			});

			// Handle down payment formatting separately
			if (!this.isPercentMode) {
				const downPaymentInput = document.getElementById('downPayment') as HTMLInputElement;
				if (downPaymentInput) {
					const value = this.parseNumber(downPaymentInput.value);
					if (value > 0) {
						downPaymentInput.value = this.formatNumber(value);
					}
				}
			}
		}

		// Animate value from start to end with speedometer effect
		animateValue(element: HTMLElement, start: number, end: number, duration: number) {
			const startTime = performance.now();
			const startValue = start;
			const endValue = end;
			
			const animate = (currentTime: number) => {
				const elapsed = currentTime - startTime;
				const progress = Math.min(elapsed / duration, 1);
				
				// Easing function for speedometer effect (ease-out)
				const easeOut = 1 - Math.pow(1 - progress, 3);
				
				const currentValue = Math.round(startValue + (endValue - startValue) * easeOut);
				element.textContent = '$' + this.formatNumber(currentValue);
				
				if (progress < 1) {
					requestAnimationFrame(animate);
				}
			};
			
			requestAnimationFrame(animate);
		}
	}

	// Initialize calculator when DOM is loaded
	document.addEventListener('DOMContentLoaded', () => {
		console.log('DOM loaded, creating calculator');
		new MortgageCalculator();

		// FAQ Accordion functionality
		const faqButtons = document.querySelectorAll('.faq-button');
		faqButtons.forEach((button) => {
			const btn = button as HTMLButtonElement;
			btn.addEventListener('click', function(this: HTMLButtonElement) {
				const content = this.nextElementSibling as HTMLElement;
				const icon = this.querySelector('.faq-icon') as HTMLElement;
				
				if (content && icon) {
					if (content.classList.contains('hidden')) {
						content.classList.remove('hidden');
						icon.style.transform = 'rotate(180deg)';
					} else {
						content.classList.add('hidden');
						icon.style.transform = 'rotate(0deg)';
					}
				}
			});
		});
	});
</script>