</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('legalModal');
    const openBtn = document.getElementById('legalDisclosuresBtn');
    const closeBtn = document.getElementById('closeModal');
    openBtn?.addEventListener('click', () => {
      modal?.classList.remove('hidden');
    });
    closeBtn?.addEventListener('click', () => {
      modal?.classList.add('hidden');
    });
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        modal?.classList.add('hidden');
      }
    });

    const fmt = (n) => {
      const v = Math.max(0, Math.round(n || 0));
      return '$' + v.toLocaleString('en-US');
    };
    const getNumber = (el) => {
      const v = el && el.value ? el.value.replace(/[^0-9.]/g, '') : '0';
      return parseFloat(v || '0') || 0;
    };
    const dpSymbol = document.getElementById('downPaymentSymbol');
    const toggleDollar = document.getElementById('toggleDollar');
    const togglePercent = document.getElementById('togglePercent');
    const purchaseEl = document.getElementById('purchasePrice') || document.getElementById('homePrice');
    const dpEl = document.getElementById('downPayment');
    const irEl = document.getElementById('interestRate');
    const rentEl = document.getElementById('monthlyRent');
    const yearsRange = document.getElementById('equityYears');
    const equityYearsLabel = document.getElementById('equityYearsLabel');
    const costYearsLabel = document.getElementById('costYearsLabel');
    const equityBar = document.getElementById('equityBar');
    const equityBuyLabel = document.getElementById('equityBuyLabel');
    const equityRentLabel = document.getElementById('equityRentLabel');
    const rentBar = document.getElementById('rentBar');
    const btnMonthly = document.getElementById('costModeMonthly');
    const btnAnnual = document.getElementById('costModeAnnual');
    const btnTotal = document.getElementById('costModeTotal');
    const costRentAmount = document.getElementById('costRentAmount');
    const costBuyAmount = document.getElementById('costBuyAmount');
    const costDiffAmount = document.getElementById('costDiffAmount');
    const calcBtn = document.getElementById('calculateButton');

    let mode = 'monthly';
    let dpMode = (dpSymbol && dpSymbol.textContent && dpSymbol.textContent.trim() === '%') ? 'percent' : 'dollar';
    const appreciationRate = 0.0318;
    const propertyTaxRate = 0.0124;
    const maintenanceRate = 0.0108;
    const hoaAnnualDefault = 1200;
    const homeInsAnnualDefault = 1200;
    const pmiAnnualRate = 0.005;
    const closingCostRate = 0.043;
    const rentGrowthRate = 0.03;

    const compute = () => {
      const price = getNumber(purchaseEl);
      const dpInput = getNumber(dpEl);
      const isPercent = dpSymbol && dpSymbol.textContent && dpSymbol.textContent.trim() === '%';
      const downPayment = isPercent ? price * (dpInput / 100) : dpInput;
      const loanAmount = Math.max(0, price - downPayment);
      let annualRate = getNumber(irEl);
      if (annualRate <= 0) { annualRate = 1; irEl && (irEl.value = String(annualRate)); }
      if (annualRate > 10) { annualRate = 10; irEl && (irEl.value = String(annualRate)); }
      const r = (annualRate / 100) / 12;
      const n = 30 * 12;
      let monthlyPI = 0;
      if (loanAmount > 0) {
        if (r > 0) {
          const num = loanAmount * (r * Math.pow(1 + r, n));
          const den = Math.pow(1 + r, n) - 1;
          monthlyPI = num / den;
        } else {
          monthlyPI = loanAmount / n;
        }
      }
      const years = parseInt(yearsRange ? yearsRange.value : '0') || 0;
      const k = years * 12;
      let remaining = loanAmount;
      if (r > 0) {
        const numR = loanAmount * (Math.pow(1 + r, n) - Math.pow(1 + r, k));
        const denR = Math.pow(1 + r, n) - 1;
        remaining = numR / denR;
      } else {
        remaining = Math.max(0, loanAmount - monthlyPI * k);
      }
      const futureValue = price * Math.pow(1 + appreciationRate, years);
      const equity = Math.max(0, futureValue - remaining);
      equityYearsLabel && (equityYearsLabel.textContent = String(years));
      costYearsLabel && (costYearsLabel.textContent = String(years));
      if (equityBuyLabel) {
        equityBuyLabel.innerHTML = 'Buy<sup>2</sup> ' + fmt(equity);
      }
      const rentMonthly = getNumber(rentEl);
      const cumRent = 0;
      equityRentLabel && (equityRentLabel.textContent = 'Rent $0');
      const scaleCap = 1000000;
      const scaleMax = Math.max(scaleCap, equity);
      const pctBuy = Math.min(100, Math.max(0, (equity / scaleMax) * 100));
      const pctRent = 0;
      equityBar && (equityBar.style.height = pctBuy + '%');
      rentBar && (rentBar.style.height = pctRent + '%');
      const priceAtYear = futureValue;
      const yearlyPropertyTax = priceAtYear * propertyTaxRate;
      const yearlyMaintenance = priceAtYear * maintenanceRate;
      const yearlyHOA = hoaAnnualDefault;
      const yearlyHomeIns = homeInsAnnualDefault;
      const ltv = remaining / Math.max(priceAtYear, 1);
      const yearlyPMI = ltv > 0.8 ? remaining * pmiAnnualRate : 0;
      const closingCosts = loanAmount * closingCostRate;
      const securityDeposit = getNumber(rentEl);
      const rentMonthlyAtYear = getNumber(rentEl) * Math.pow(1 + rentGrowthRate, years);
      const buyMonthlyAtYear = monthlyPI + (yearlyPropertyTax + yearlyMaintenance + yearlyHOA + yearlyHomeIns + yearlyPMI) / 12;
      let rentVal = rentMonthlyAtYear;
      let buyVal = buyMonthlyAtYear;
      if (mode === 'annual') {
        rentVal = rentMonthlyAtYear * 12;
        buyVal = buyMonthlyAtYear * 12;
      } else if (mode === 'total') {
        rentVal = rentMonthlyAtYear * 12 * years + securityDeposit;
        buyVal = buyMonthlyAtYear * 12 * years + closingCosts + downPayment;
      }
      costRentAmount && (costRentAmount.textContent = fmt(rentVal));
      costBuyAmount && (costBuyAmount.textContent = fmt(buyVal));
      costDiffAmount && (costDiffAmount.textContent = fmt(Math.abs(buyVal - rentVal)));

      const costPropertyTax = document.getElementById('costPropertyTax');
      const costClosingCosts = document.getElementById('costClosingCosts');
      const costPMI = document.getElementById('costPMI');
      const costHomeIns = document.getElementById('costHomeIns');
      const costHOA = document.getElementById('costHOA');
      const costMaintenance = document.getElementById('costMaintenance');
      const newCostPropertyTax = document.getElementById('newCostPropertyTax');
      const newCostClosingCosts = document.getElementById('newCostClosingCosts');
      const newCostPMI = document.getElementById('newCostPMI');
      const newCostHomeIns = document.getElementById('newCostHomeIns');
      const newCostHOA = document.getElementById('newCostHOA');
      const newCostMaintenance = document.getElementById('newCostMaintenance');
      costPropertyTax && (costPropertyTax.textContent = fmt(yearlyPropertyTax));
      costClosingCosts && (costClosingCosts.textContent = fmt(closingCosts));
      costPMI && (costPMI.textContent = fmt(yearlyPMI));
      costHomeIns && (costHomeIns.textContent = fmt(yearlyHomeIns));
      costHOA && (costHOA.textContent = fmt(yearlyHOA));
      costMaintenance && (costMaintenance.textContent = fmt(yearlyMaintenance));
      newCostPropertyTax && (newCostPropertyTax.textContent = fmt(yearlyPropertyTax));
      newCostClosingCosts && (newCostClosingCosts.textContent = fmt(closingCosts));
      newCostPMI && (newCostPMI.textContent = fmt(yearlyPMI));
      newCostHomeIns && (newCostHomeIns.textContent = fmt(yearlyHomeIns));
      newCostHOA && (newCostHOA.textContent = fmt(yearlyHOA));
      newCostMaintenance && (newCostMaintenance.textContent = fmt(yearlyMaintenance));
    };

    const activatePercent = () => {
      togglePercent && togglePercent.classList.add('bg-gray-900','border','border-gray-900','text-white');
      togglePercent && togglePercent.classList.remove('bg-white','text-gray-600');
      toggleDollar && toggleDollar.classList.add('bg-white','text-gray-600');
      toggleDollar && toggleDollar.classList.remove('bg-gray-900','text-white');
    };
    const activateDollar = () => {
      toggleDollar && toggleDollar.classList.add('bg-gray-900','border','border-gray-900','text-white');
      toggleDollar && toggleDollar.classList.remove('bg-white','text-gray-600');
      togglePercent && togglePercent.classList.add('bg-white','text-gray-600');
      togglePercent && togglePercent.classList.remove('bg-gray-900','text-white');
    };

    togglePercent && togglePercent.addEventListener('click', () => {
      const price = getNumber(purchaseEl);
      const current = getNumber(dpEl);
      if (dpMode === 'dollar' && price > 0) {
        const pct = (current / price) * 100;
        dpEl && (dpEl.value = String(Math.round(pct * 100) / 100));
      }
      dpSymbol && (dpSymbol.textContent = '%');
      dpMode = 'percent';
      activatePercent();
      compute();
    });

    toggleDollar && toggleDollar.addEventListener('click', () => {
      const price = getNumber(purchaseEl);
      const current = getNumber(dpEl);
      if (dpMode === 'percent') {
        const amt = price * (current / 100);
        dpEl && (dpEl.value = String(Math.round(amt)));
      }
      dpSymbol && (dpSymbol.textContent = '$');
      dpMode = 'dollar';
      activateDollar();
      compute();
    });

    if (dpMode === 'percent') activatePercent(); else activateDollar();

    const updateModeButtons = () => {
      const setSelected = (btn) => {
        btn && btn.classList.add('bg-black','text-white');
        btn && btn.classList.remove('bg-white','text-black');
      };
      const setUnselected = (btn) => {
        btn && btn.classList.add('bg-white','text-black');
        btn && btn.classList.remove('bg-black','text-white');
      };
      if (mode === 'monthly') {
        setSelected(btnMonthly); setUnselected(btnAnnual); setUnselected(btnTotal);
      } else if (mode === 'annual') {
        setSelected(btnAnnual); setUnselected(btnMonthly); setUnselected(btnTotal);
      } else {
        setSelected(btnTotal); setUnselected(btnMonthly); setUnselected(btnAnnual);
      }
    };

    btnMonthly && btnMonthly.addEventListener('click', () => { mode = 'monthly'; updateModeButtons(); compute(); });
    btnAnnual && btnAnnual.addEventListener('click', () => { mode = 'annual'; updateModeButtons(); compute(); });
    btnTotal && btnTotal.addEventListener('click', () => { mode = 'total'; updateModeButtons(); compute(); });

    yearsRange && yearsRange.addEventListener('input', compute);
    calcBtn && calcBtn.addEventListener('click', compute);
    [purchaseEl, dpEl, irEl, rentEl].forEach((el) => {
      el && el.addEventListener('input', compute);
      el && el.addEventListener('change', compute);
    });
    updateModeButtons();
    compute();

    const faqButtons = document.querySelectorAll('.faq-button');
    faqButtons.forEach((button) => {
      const btn = button;
      btn.addEventListener('click', function() {
        const content = this.nextElementSibling;
        const icon = this.querySelector('.faq-icon');
        
        if (content && icon) {
          if (content.classList.contains('hidden')) {
            content.classList.remove('hidden');
            icon.style.transform = 'rotate(180deg)';
          } else {
            content.classList.add('hidden');
            icon.style.transform = 'rotate(0deg)';
          }
        }
      });
    });
  });
</script>
