---
import Layout from '../../layouts/Layout.astro';
import Contact from '../../components/Contact.astro';
import ImportantLegal from '../../components/ImportantLegal.astro';
import NextMoveSection from '../../components/NextMoveSection.astro';
import enDict from '../../translations/mortgage-payoff-calculator/en.json';
import esDict from '../../translations/mortgage-payoff-calculator/es.json';
const enB64 = Buffer.from(JSON.stringify(enDict)).toString('base64');
const esB64 = Buffer.from(JSON.stringify(esDict)).toString('base64');

export const prerender = true;
// Build estático: i18n en cliente; render en inglés
const lang = 'en';
const dict = enDict;
---

<!-- i18n payload for Mortgage Payoff Calculator -->
<div id="i18n-mpc" data-en={enB64} data-es={esB64} style="display:none"></div>
<script is:inline>
  (() => {
    const payloadEl = document.getElementById('i18n-mpc');
    const decode = (val) => {
      try {
        const b64 = val || '';
        const bin = atob(b64);
        const bytes = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
        const jsonText = new TextDecoder('utf-8').decode(bytes);
        return JSON.parse(jsonText);
      } catch { return {}; }
    };
    const translations = {
      en: decode(payloadEl?.getAttribute('data-en') || ''),
      es: decode(payloadEl?.getAttribute('data-es') || ''),
    };
    const getInitialLang = () => {
      const urlLang = new URLSearchParams(window.location.search).get('lang');
      const stored = localStorage.getItem('lang');
      return (urlLang || stored || 'en');
    };
    const resolvePath = (obj, path) => {
      try {
        const parts = (path || '').split('.');
        let cur = obj;
        for (const p of parts) {
          if (cur && typeof cur === 'object' && p in cur) cur = cur[p]; else return null;
        }
        return typeof cur === 'string' ? cur : null;
      } catch { return null; }
    };
    const preserveLangOnLocalLinks = (lang) => {
      try {
        const localLinks = document.querySelectorAll('a[href^="/"]');
        localLinks.forEach(a => {
          const raw = a.getAttribute('href') || '';
          if (!raw || raw.startsWith('#') || raw.startsWith('tel:') || raw.startsWith('mailto:') || /([?&])lang=/.test(raw)) return;
          let href;
          try { href = new URL(a.href, window.location.origin); } catch { return; }
          if (href.origin !== window.location.origin) return;
          if (lang) {
            href.searchParams.set('lang', lang);
            a.setAttribute('href', href.pathname + href.search + href.hash);
          }
        });
      } catch {}
    };
    const applyTranslations = (lang) => {
      const dict = translations[lang] || translations.en;
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        const val = resolvePath(dict, key);
        if (typeof val === 'string') {
          if (val.includes('<')) { el.innerHTML = val; } else { el.textContent = val; }
        }
      });
      if (typeof dict.page_title === 'string') document.title = dict.page_title;
      preserveLangOnLocalLinks(lang);
    };
    const __initLang = getInitialLang();
    applyTranslations(__initLang);
    document.addEventListener('click', (e) => {
      const a = e.target.closest('a[href*="?lang="]');
      if (!a) return;
      let href;
      try { href = new URL(a.href, window.location.origin); } catch { return; }
      const newLang = href.searchParams.get('lang');
      if (newLang) {
        applyTranslations(newLang);
        preserveLangOnLocalLinks(newLang);
      }
    });
    window.addEventListener('popstate', () => {
      const urlLang = new URLSearchParams(window.location.search).get('lang');
      const lang = (urlLang || localStorage.getItem('lang') || 'en');
      applyTranslations(lang);
      preserveLangOnLocalLinks(lang);
    });
    window.addEventListener('storage', (ev) => {
      if (ev.key === 'lang' && ev.newValue) {
        applyTranslations(ev.newValue);
        preserveLangOnLocalLinks(ev.newValue);
      }
    });
  })();
</script>

<Layout title={dict.page_title} lang={lang}>
	<!-- Breadcrumb -->
	<section class="bg-white py-4">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<nav class="flex" aria-label="Breadcrumb">
				<ol class="flex items-center space-x-4">
					<li>
						<div>
							<a href={`/?lang=${lang}`} class="text-gray-400 hover:text-gray-500 text-sm font-medium" data-i18n="breadcrumb.home">
								{dict.breadcrumb.home}
							</a>
						</div>
					</li>
					<li>
						<div class="flex items-center">
							<svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
							</svg>
							<a href={`/calculators?lang=${lang}`} class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" data-i18n="breadcrumb.calculators">{dict.breadcrumb.calculators}</a>
						</div>
					</li>
					<li>
						<div class="flex items-center">
							<svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
							</svg>
							<span class="ml-4 text-sm font-medium text-gray-500" data-i18n="breadcrumb.current">{dict.breadcrumb.current}</span>
						</div>
					</li>
				</ol>
			</nav>
		</div>
	</section>

	<!-- Main Calculator Section -->
	<section class="py-8 bg-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8">
				<h1 id="mpc-hero-title" class="text-2xl font-bold text-gray-900 mb-3" data-i18n="hero.title">{dict.hero.title}</h1>
				<p id="mpc-hero-desc" class="text-base text-gray-600 max-w-2xl mx-auto" data-i18n="hero.description">
					{dict.hero.description}
				</p>
			</div>

			<!-- 2-Column Layout Container -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
				<!-- Left Column: Calculator Form -->
				<div class="bg-gray-100 p-4 rounded-xl shadow-lg border border-gray-200">
					<form id="mortgage-form" class="space-y-4">
						<!-- Current Mortgage Balance -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
                            <div class="flex justify-start items-center px-1.5 mb-0.5">
                                <span class="text-xs font-medium text-gray-700" data-i18n="form.labels.current_mortgage_balance">{dict.form.labels.current_mortgage_balance}</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight">
										Example: $250,000 - Enter the remaining balance on your current mortgage
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="currentMortgageBalance" 
									name="currentMortgageBalance"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="0"
								>
							</div>
						</div>

						<!-- Years Left on Your Loan -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
                                <span class="text-xs font-medium text-gray-700" data-i18n="form.labels.years_left">{dict.form.labels.years_left}</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight">
										Example: 25 years - How many years are remaining on your current mortgage
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<input 
								type="text" 
								id="yearsLeft" 
								name="yearsLeft"
								class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
								placeholder="25"
							>
						</div>

						<!-- Current Home Value -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
                                <span class="text-xs font-medium text-gray-700" data-i18n="form.labels.current_home_value">{dict.form.labels.current_home_value}</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight">
										Example: $350,000 - Current estimated market value of your home
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="currentHomeValue" 
									name="currentHomeValue"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="0"
								>
							</div>
						</div>

						<!-- Credit Profile and ZIP Code (Same Row) -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
							<!-- Credit Profile -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
								<div class="flex justify-start px-1.5 mb-0.5">
									<span class="text-xs font-medium text-gray-700">Credit profile</span>
								</div>
								<!-- Select Field -->
								<select 
									id="creditProfile" 
									name="creditProfile"
									class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm credit-profile-select"
								>
                                    <option value="" selected disabled class="text-gray-400" data-i18n="form.options.select_range">{dict.form.options.select_range}</option>
                                    <option value="less-than-580" class="text-gray-900" data-i18n="form.options.less_than_580">{dict.form.options.less_than_580}</option>
                                    <option value="580-619" class="text-gray-900" data-i18n="form.options.580_619">{dict.form.options['580_619']}</option>
                                    <option value="620-659" class="text-gray-900" data-i18n="form.options.620_659">{dict.form.options['620_659']}</option>
                                    <option value="660-719" class="text-gray-900" data-i18n="form.options.660_719">{dict.form.options['660_719']}</option>
                                    <option value="720-759" class="text-gray-900" data-i18n="form.options.720_759">{dict.form.options['720_759']}</option>
                                    <option value="760-plus" class="text-gray-900" data-i18n="form.options.760_plus">{dict.form.options['760_plus']}</option>
								</select>
							</div>

							<!-- ZIP Code -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
                                <div class="flex justify-start px-1.5 mb-0.5">
                                    <span class="text-xs font-medium text-gray-700" data-i18n="form.labels.zip_code">{dict.form.labels.zip_code}</span>
								</div>
								<!-- Input Field -->
								<input 
									type="text" 
									id="zipCode" 
									name="zipCode"
									value=""
									class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
                                    placeholder={dict.form.placeholders.value}
								>
							</div>
						</div>
					</form>
					
					<!-- Calculate Button -->
					<div class="mt-4">
						<button 
							id="calculateButton"
							type="button"
							class="w-full bg-black text-white py-3 px-4 rounded-[48px] text-base font-semibold hover:bg-gray-800 transition-colors duration-200"
						>
                            <span data-i18n="form.buttons.calculate">{dict.form.buttons.calculate}</span>
						</button>
					</div>
					
					<!-- Logo and Legal Disclosures -->
					<div class="mt-4 flex items-center justify-center space-x-2 text-xs text-gray-500">
                        <img 
                            src="/logo.png" 
                            alt="Broker Lenders Logo" 
                            class="h-6 w-auto"
                        >
						<span>|</span>
						<button 
							id="legalDisclosuresBtn"
							class="underline hover:text-gray-700 transition-colors cursor-pointer"
						>
                            <span data-i18n="form.buttons.legal_disclosures">{dict.form.buttons.legal_disclosures}</span>
						</button>
					</div>
				</div>

				<!-- Right Column: Results and Message Cards -->
				<div class="space-y-4">
					<!-- Results Card -->
					<div id="resultsCard" class="bg-green-600/10 px-8 py-8 rounded-xl shadow-lg text-gray-900 min-h-80 flex flex-col justify-center">
                        <div class="mt-4 mb-8 text-center">
                            <div class="text-sm font-bold text-gray-700 mb-4" data-i18n="results.heading">{dict.results.heading}</div>
							<div class="text-8xl font-bold mb-4" id="yearsSaved">0</div>
						</div>

						<!-- Buttons -->
                        <div class="flex gap-4 justify-center">
                            <button class="px-10 py-5 border border-gray-400 text-gray-700 bg-transparent rounded-full hover:bg-gray-100 transition-colors text-base font-bold" data-i18n="cta.apply_now">{dict.cta?.apply_now || 'Apply now'}</button>
                            <button class="px-10 py-5 border border-gray-400 text-gray-700 bg-transparent rounded-full hover:bg-gray-100 transition-colors text-base font-bold" data-i18n="cta.see_rate">{dict.cta?.see_rate || "See today's rate"}</button>
                        </div>
					</div>


				</div>
			</div>
		</div>
	</section>

	<!-- Legal Disclosures Modal -->
	<div id="legalModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
		<div class="bg-white rounded-[48px] max-w-4xl w-full max-h-[80vh] overflow-y-auto p-8 relative">
			<!-- Close Button -->
			<button 
				id="closeModal" 
				class="absolute top-6 right-6 text-gray-400 hover:text-gray-600 transition-colors"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>
			
			<!-- Modal Content -->
			<div class="pr-8">
                <h2 class="text-2xl font-bold text-gray-900 mb-6" data-i18n="modal.title">{dict.modal?.title || 'Legal Disclosures'}</h2>
				
				<div class="space-y-6 text-gray-700 leading-relaxed">
					<p>
						This Broker Lenders refinance calculator is for estimation purposes only. Results do not reflect all loan programs and are subject to individual program loan limits. Qualification, rates and payments will vary based on timing and individual circumstances. This is not a commitment to lend.
					</p>
					
					<div>
                        <h3 class="text-lg font-semibold text-gray-900 mb-3" data-i18n="modal.payment_example_title">{dict.modal?.payment_example_title || 'Payment Example'}</h3>
                        <p class="mb-3" data-i18n="modal.payment_example_intro">{dict.modal?.payment_example_intro || "Here's a payment example based on an average home price and the most common loan type:"}</p>
						
						<div class="bg-gray-50 p-4 rounded-lg space-y-2">
                            <p><strong data-i18n="modal.labels.loan_amount">{(dict.modal && dict.modal.labels && dict.modal.labels.loan_amount) || 'Loan amount:'}</strong> $300,000</p>
                            <p><strong data-i18n="modal.labels.loan_type">{(dict.modal && dict.modal.labels && dict.modal.labels.loan_type) || 'Loan type:'}</strong> 30-year Fixed-Rate Loan</p>
                            <p><strong data-i18n="modal.labels.interest_apr">{(dict.modal && dict.modal.labels && dict.modal.labels.interest_apr) || 'Interest rate/APR:'}</strong> 7.375% (7.692% APR)</p>
                            <p><strong data-i18n="modal.labels.monthly_payment">{(dict.modal && dict.modal.labels && dict.modal.labels.monthly_payment) || 'Monthly payment:'}</strong> $2,072.03</p>
                            <p><strong data-i18n="modal.labels.points">{(dict.modal && dict.modal.labels && dict.modal.labels.points) || 'Points:'}</strong> 1.875 points, costs due at closing</p>
                            <p><strong data-i18n="modal.labels.ltv">{(dict.modal && dict.modal.labels && dict.modal.labels.ltv) || 'Loan-to-value (LTV):'}</strong> 80.00%</p>
						</div>
					</div>
					
					<div class="space-y-3">
                        <p data-i18n="modal.paragraph2">
                            {dict.modal?.paragraph2 || 'One point is equal to one percent of your loan amount. Payment does not include taxes and insurance. The actual payment amount will be greater. Some state and county maximum loan amount restrictions may apply. Rates shown are valid on publication date of April 18, 2024.'}
                        </p>
						
                        <p class="text-sm" data-i18n="modal.footer.note">
                            {dict.modal?.footer?.note || "¹If you didn't enter taxes and insurance amounts, an estimate of your taxes is based on the state selected. This does not include all fees."}
                        </p>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Next Move Section -->
<NextMoveSection lang={lang} />

	<!-- How to use section -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-gray-900 mb-4" data-i18n="howToUse.title">{dict.howToUse.title}</h2>
				<p class="text-lg text-gray-600" data-i18n="howToUse.description">
					{dict.howToUse.description}
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3" data-i18n="howToUse.cards.enter_details.title">{dict.howToUse.cards.enter_details.title}</h3>
					<p class="text-gray-600" data-i18n="howToUse.cards.enter_details.text">
						{dict.howToUse.cards.enter_details.text}
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3" data-i18n="howToUse.cards.extra_payment.title">{dict.howToUse.cards.extra_payment.title}</h3>
					<p class="text-gray-600" data-i18n="howToUse.cards.extra_payment.text">
						{dict.howToUse.cards.extra_payment.text}
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a4 4 0 118 0v4m-4 8a2 2 0 11-4 0 2 2 0 014 0z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3" data-i18n="howToUse.cards.time_savings.title">{dict.howToUse.cards.time_savings.title}</h3>
					<p class="text-gray-600" data-i18n="howToUse.cards.time_savings.text">
						{dict.howToUse.cards.time_savings.text}
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
