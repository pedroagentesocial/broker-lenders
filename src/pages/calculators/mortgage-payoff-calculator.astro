</Layout>

<script>
	
	// Mortgage Payoff Calculator Logic
	class MortgageCalculator {
		lastCalculation: any;
		
		constructor() {
			this.initializeEventListeners();
			// Cards are visible by default - no need to clear results on init
		}

		initializeEventListeners() {
			// Remove automatic calculation - only format inputs on change
			const inputs = document.querySelectorAll('#mortgage-form input, #mortgage-form select');
			inputs.forEach(input => {
				input.addEventListener('input', () => {
					this.clearFieldValidation(input.id);
					this.formatInputs();
				});
				input.addEventListener('change', () => {
					this.clearFieldValidation(input.id);
					this.formatInputs();
				});
			});

			// Calculate button event listener - now with validation
			const calculateButton = document.getElementById('calculateButton');
			console.log('Calculate button found:', calculateButton);
			if (calculateButton) {
				calculateButton.addEventListener('click', () => this.handleCalculateClick());
			}

			// ZIP code validation
			const zipCodeInput = document.getElementById('zipCode');
			if (zipCodeInput) {
				zipCodeInput.addEventListener('input', (e: any) => this.validateZipCode(e));
				zipCodeInput.addEventListener('blur', (e: any) => this.validateZipCodeExists(e));
			}

			// Legal disclosures modal event listeners
			const legalDisclosuresBtn = document.getElementById('legalDisclosuresBtn');
			const legalModal = document.getElementById('legalModal');
			const closeModal = document.getElementById('closeModal');

			if (legalDisclosuresBtn && legalModal) {
				legalDisclosuresBtn.addEventListener('click', () => {
					legalModal.classList.remove('hidden');
				});
			}

			if (closeModal && legalModal) {
				closeModal.addEventListener('click', () => {
					legalModal.classList.add('hidden');
				});
			}

			// Close modal when clicking outside
			if (legalModal) {
				legalModal.addEventListener('click', (e: any) => {
					if (e.target === legalModal) {
						legalModal.classList.add('hidden');
					}
				});
			}

			// Call Now button event listener
			const callNowBtn = document.getElementById('callNowBtn');
			if (callNowBtn) {
				callNowBtn.addEventListener('click', () => {
					window.location.href = 'tel:+1234567890'; // Replace with actual phone number
				});
			}
		}

		validateZipCode(e: any) {
			const input = e.target;
			let value = input.value;
			
			// Remove any non-numeric characters
			value = value.replace(/[^0-9]/g, '');
			
			// Limit to 5 digits for US ZIP codes
			if (value.length > 5) {
				value = value.substring(0, 5);
			}
			
			// Update the input value
			input.value = value;
		}

		async validateZipCodeExists(e: any) {
			const input = e.target;
			const zipCode = input.value;
			
			// Reset border color
			input.classList.remove('border-red-500');
			input.classList.add('border-gray-300');
			
			if (zipCode.length === 5) {
				try {
					// Use a free ZIP code API to validate
					const response = await fetch(`https://api.zippopotam.us/us/${zipCode}`);
					if (!response.ok) {
						// ZIP code doesn't exist
						input.classList.remove('border-gray-300');
						input.classList.add('border-red-500');
						input.title = 'ZIP code not found';
					} else {
						input.title = '';
					}
				} catch (error) {
					// If API fails, don't show error (graceful degradation)
					console.log('ZIP code validation API unavailable');
				}
			}
		}

		formatNumber(num: any) {
			return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
		}

		parseNumber(str: any) {
			return parseFloat(str.replace(/,/g, '')) || 0;
		}

		// New method to handle calculate button click with validation
		handleCalculateClick() {
			console.log('handleCalculateClick called');
			
			// Clear previous validation errors
			this.clearAllValidationErrors();
			
			// Validate all required fields
			if (!this.validateAllFields()) {
				console.log('Validation failed, not calculating');
				return;
			}
			
			// Clear previous results and calculate
			this.clearResults();
			this.calculate();
		}

		// Clear field validation styling and messages
		clearFieldValidation(fieldId: string) {
			const field = document.getElementById(fieldId);
			if (field) {
				// Remove red border from container
				const container = field.closest('.bg-white');
				if (container) {
					container.classList.remove('border-red-500', 'border-2');
				}
				
				// Remove error message
				const errorMsg = document.getElementById(`${fieldId}-error`);
				if (errorMsg) {
					errorMsg.remove();
				}
			}
		}

		// Clear all validation errors
		clearAllValidationErrors() {
			const requiredFields = ['currentMortgageBalance', 'yearsLeft', 'currentHomeValue', 'creditProfile', 'zipCode'];
			requiredFields.forEach(fieldId => {
				this.clearFieldValidation(fieldId);
			});
		}

		// Validate all required fields
		validateAllFields(): boolean {
			let isValid = true;
			const requiredFields = [
				{ id: 'currentMortgageBalance', name: 'Current mortgage balance', type: 'currency' },
				{ id: 'yearsLeft', name: 'Years left on your loan', type: 'number' },
				{ id: 'currentHomeValue', name: 'Current home value', type: 'currency' },
				{ id: 'creditProfile', name: 'Credit profile', type: 'select' },
				{ id: 'zipCode', name: 'ZIP code', type: 'zipcode' }
			];

			requiredFields.forEach(field => {
				const element = document.getElementById(field.id) as HTMLInputElement | HTMLSelectElement;
				if (element) {
					const value = element.value.trim();
					let fieldValid = true;
					let errorMessage = '';

					// Check if field is empty or invalid
					if (!value || (field.type !== 'select' && field.type !== 'zipcode' && (value === '0' || value === '$0'))) {
						fieldValid = false;
						errorMessage = `${field.name} is required`;
					} else {
						// Additional validation based on field type
						switch (field.type) {
							case 'currency':
								const numValue = this.parseNumber(value);
								if (numValue <= 0) {
									fieldValid = false;
									errorMessage = `${field.name} must be greater than $0`;
								}
								break;
							case 'number':
								const yearValue = parseFloat(value);
								if (yearValue <= 0 || yearValue > 50) {
									fieldValid = false;
									errorMessage = `${field.name} must be between 1 and 50 years`;
								}
								break;
							case 'select':
								if (!value || value === '') {
									fieldValid = false;
									errorMessage = `Please select ${field.name.toLowerCase()}`;
								}
								break;
							case 'zipcode':
								if (!value || value.length !== 5 || !/^\d{5}$/.test(value)) {
									fieldValid = false;
									errorMessage = 'Please enter a valid 5-digit ZIP code';
								}
								break;
						}
					}

					if (!fieldValid) {
						this.showFieldError(field.id, errorMessage);
						isValid = false;
					}
				}
			});

			return isValid;
		}

		// Show error for specific field
		showFieldError(fieldId: string, message: string) {
			const field = document.getElementById(fieldId);
			if (field) {
				// Add red border to the container instead of just the input
				const container = field.closest('.bg-white');
				if (container) {
					container.classList.add('border-red-500', 'border-2');
				}
				
				// Add error message
				const errorDiv = document.createElement('div');
				errorDiv.id = `${fieldId}-error`;
				errorDiv.className = 'text-red-500 text-sm mt-1 px-2';
				errorDiv.textContent = message;
				
				// Insert error message after the field's parent container
				if (container && container.parentNode) {
					container.parentNode.insertBefore(errorDiv, container.nextSibling);
				}
			}
		}

		// Clear results display (but keep cards visible)
		clearResults() {
			const yearsSavedEl = document.getElementById('yearsSaved');

			// Reset to placeholder values without "years" text initially
			if (yearsSavedEl) yearsSavedEl.textContent = '0';

			// Cards remain visible - no hiding logic needed
		}



		calculate() {
			console.log('Starting mortgage payoff calculation...');
			
			// Get input values
			const currentMortgageBalance = this.parseNumber((document.getElementById('currentMortgageBalance') as HTMLInputElement)?.value || '0');
			const yearsLeft = parseFloat((document.getElementById('yearsLeft') as HTMLInputElement)?.value || '0');
			const currentHomeValue = this.parseNumber((document.getElementById('currentHomeValue') as HTMLInputElement)?.value || '0');
			const creditProfile = (document.getElementById('creditProfile') as HTMLSelectElement)?.value || '';

			console.log('Input values:', { currentMortgageBalance, yearsLeft, currentHomeValue, creditProfile });

			// Validate inputs
			if (currentMortgageBalance <= 0 || yearsLeft <= 0 || currentHomeValue <= 0) {
				console.log('Invalid input values');
				return;
			}

			// Estimate interest rate based on credit profile (realistic 2024 rates)
			let estimatedRate = 7.0; // Default rate
			switch (creditProfile) {
				case 'less-than-580':
					estimatedRate = 10.0; // 9.5-10.5% range
					break;
				case '580-619':
					estimatedRate = 9.0; // 8.5-9.5% range
					break;
				case '620-659':
					estimatedRate = 8.0; // 7.5-8.5% range
					break;
				case '660-719':
					estimatedRate = 7.0; // 6.5-7.5% range
					break;
				case '720-759':
					estimatedRate = 6.5; // 6.0-7.0% range
					break;
				case '760-plus':
					estimatedRate = 6.0; // 5.5-6.5% range
					break;
			}

			console.log('Estimated interest rate:', estimatedRate);

			// Convert annual interest rate to monthly decimal rate
			const monthlyInterestRate = (estimatedRate / 100) / 12;
			const numberOfPayments = yearsLeft * 12;

			console.log('Monthly interest rate:', monthlyInterestRate);
			console.log('Number of payments:', numberOfPayments);

			// Calculate current monthly payment using the standard mortgage formula
			let currentMonthlyPayment = 0;
			
			if (currentMortgageBalance > 0) {
				if (monthlyInterestRate > 0) {
					// Standard mortgage formula for interest-bearing loans
					const numerator = currentMortgageBalance * (monthlyInterestRate * Math.pow(1 + monthlyInterestRate, numberOfPayments));
					const denominator = Math.pow(1 + monthlyInterestRate, numberOfPayments) - 1;
					currentMonthlyPayment = numerator / denominator;
				} else {
					// For 0% interest loans, simply divide principal by number of payments
					currentMonthlyPayment = currentMortgageBalance / numberOfPayments;
				}
			}

			console.log('Current Monthly Payment:', currentMonthlyPayment);

			// Calculate total interest paid over the life of the loan
			const totalPaid = currentMonthlyPayment * numberOfPayments;
			const totalInterestPaid = totalPaid - currentMortgageBalance;

			console.log('Total interest paid over loan life:', totalInterestPaid);

			// Calculate equity and loan-to-value ratio
			const currentEquity = currentHomeValue - currentMortgageBalance;
			const loanToValueRatio = (currentMortgageBalance / currentHomeValue) * 100;

			console.log('Additional metrics:', {
				currentEquity,
				loanToValueRatio,
				totalPaid
			});

			// Calculate potential years saved with refinancing to 15-year mortgage
			let potentialYearsSaved = 0;
			
			// Check if mortgage is underwater (balance > home value)
			const isUnderwater = currentMortgageBalance > currentHomeValue;
			
			if (!isUnderwater) {
				if (yearsLeft > 15) {
					// Standard refinancing scenario: refinance to 15-year term
					// Assume refinancing rate is 0.25-0.5% lower than current rate
					const refinanceRate = Math.max(estimatedRate - 0.375, 5.5); // 0.375% reduction, minimum 5.5%
					const refinanceMonthlyRate = (refinanceRate / 100) / 12;
					const refinancePayments = 15 * 12; // 15 years
					
					// Calculate new monthly payment for 15-year term
					let newMonthlyPayment = 0;
					if (refinanceMonthlyRate > 0) {
						const numerator = currentMortgageBalance * (refinanceMonthlyRate * Math.pow(1 + refinanceMonthlyRate, refinancePayments));
						const denominator = Math.pow(1 + refinanceMonthlyRate, refinancePayments) - 1;
						newMonthlyPayment = numerator / denominator;
					} else {
						newMonthlyPayment = currentMortgageBalance / refinancePayments;
					}
					
					// Years saved = current term - 15 years
					potentialYearsSaved = yearsLeft - 15;
					
					console.log('Refinancing scenario:', {
						currentRate: estimatedRate,
						refinanceRate: refinanceRate,
						currentYearsLeft: yearsLeft,
						newTerm: 15,
						yearsSaved: potentialYearsSaved,
						currentPayment: currentMonthlyPayment,
						newPayment: newMonthlyPayment
					});
					
				} else if (yearsLeft > 5) {
					// Already have less than 15 years: calculate savings with extra payments
					// Assume 15% extra payment can reduce term significantly
					const extraPaymentPercent = 0.15;
					const extraMonthlyPayment = currentMonthlyPayment * (1 + extraPaymentPercent);
					
					// Calculate how many payments needed with extra payment
					let remainingBalance = currentMortgageBalance;
					let paymentsWithExtra = 0;
					const principal = currentMonthlyPayment - (currentMortgageBalance * monthlyInterestRate);
					const extraPrincipal = extraMonthlyPayment - (currentMortgageBalance * monthlyInterestRate);
					
					// Simplified calculation: extra payments reduce term by approximately 20-25%
					const estimatedReduction = yearsLeft * 0.22; // 22% reduction
					potentialYearsSaved = Math.min(Math.floor(estimatedReduction), yearsLeft - 2);
					
					console.log('Extra payments scenario:', {
						currentYearsLeft: yearsLeft,
						extraPaymentPercent: extraPaymentPercent * 100,
						estimatedYearsSaved: potentialYearsSaved
					});
					
				} else {
					// Less than 5 years left: minimal savings possible
					potentialYearsSaved = Math.min(1, Math.floor(yearsLeft * 0.15));
				}
			} else {
				// Underwater mortgage: limited refinancing options
				// Focus on extra payments to build equity
				if (yearsLeft > 10) {
					potentialYearsSaved = Math.min(2, Math.floor(yearsLeft * 0.1));
				} else {
					potentialYearsSaved = 0;
				}
				
				console.log('Underwater mortgage detected:', {
					balance: currentMortgageBalance,
					homeValue: currentHomeValue,
					limitedSavings: potentialYearsSaved
				});
			}
			
			// Ensure realistic bounds
			potentialYearsSaved = Math.max(0, Math.min(potentialYearsSaved, yearsLeft - 1));

			// Update display elements
			const yearsSavedEl = document.getElementById('yearsSaved');

			// Format and display results
			if (yearsSavedEl) {
				// Animate the years saved display with speedometer effect
				this.animateCounter(yearsSavedEl, potentialYearsSaved);
			}

			// Store calculation results for potential future use
			this.lastCalculation = {
				currentMortgageBalance,
				yearsLeft,
				currentHomeValue,
				creditProfile,
				estimatedRate,
				currentMonthlyPayment,
				totalInterestPaid,
				currentEquity,
				loanToValueRatio,
				totalPaid
			};

			console.log('Calculation completed successfully');

			// Format input values for better user experience
			this.formatInputs();
		}

		formatInputs() {
			const moneyInputs = ['currentMortgageBalance', 'currentHomeValue'];
			moneyInputs.forEach(id => {
				const input = document.getElementById(id) as HTMLInputElement;
				if (input) {
					const value = this.parseNumber(input.value);
					if (value > 0) {
						input.value = this.formatNumber(value);
					}
				}
			});
		}

		// Animate counter with smooth, elegant speedometer effect
		animateCounter(element: HTMLElement, targetValue: number) {
			const startTime = performance.now();
			const duration = 3800; // 3.8 seconds for a more relaxed, premium feel
			const startValue = 0;
			const pauseDuration = 400; // Small pause before showing "years"
			
			const animate = (currentTime: number) => {
				const elapsed = currentTime - startTime;
				const progress = Math.min(elapsed / duration, 1);
				
				// Smooth cubic-bezier easing for premium feel (ease-in-out with custom curve)
				const smoothEase = progress < 0.5 
					? 4 * progress * progress * progress 
					: 1 - Math.pow(-2 * progress + 2, 3) / 2;
				
				// Apply additional smoothing for more organic progression
				const organicProgress = smoothEase * (2 - smoothEase);
				
				const currentValue = Math.round(startValue + (targetValue - startValue) * organicProgress);
				
				// Show just the number during animation
				if (progress < 1) {
					element.textContent = currentValue.toString();
					requestAnimationFrame(animate);
				} else {
					// Small pause before showing "years" for elegance
					setTimeout(() => {
						// Smooth fade-in effect for "years" text
						element.style.transition = 'opacity 0.5s ease-in-out';
						element.style.opacity = '0.7';
						element.textContent = `${targetValue} years`;
						
						// Return to full opacity
						setTimeout(() => {
							element.style.opacity = '1';
						}, 100);
					}, pauseDuration);
				}
			};
			
			requestAnimationFrame(animate);
		}

		// Animate value from start to end with speedometer effect
		animateValue(element: HTMLElement, start: number, end: number, duration: number) {
			const startTime = performance.now();
			const startValue = start;
			const endValue = end;
			
			const animate = (currentTime: number) => {
				const elapsed = currentTime - startTime;
				const progress = Math.min(elapsed / duration, 1);
				
				// Easing function for speedometer effect (ease-out)
				const easeOut = 1 - Math.pow(1 - progress, 3);
				
				const currentValue = Math.round(startValue + (endValue - startValue) * easeOut);
				element.textContent = '$' + this.formatNumber(currentValue);
				
				if (progress < 1) {
					requestAnimationFrame(animate);
				}
			};
			
			requestAnimationFrame(animate);
		}
	}

	// Initialize calculator when DOM is loaded
	document.addEventListener('DOMContentLoaded', () => {
		console.log('DOM loaded, creating calculator');
		new MortgageCalculator();

		// FAQ Accordion functionality
		const faqButtons = document.querySelectorAll('.faq-button');
		
		faqButtons.forEach(button => {
			button.addEventListener('click', function(this: HTMLButtonElement) {
				const content = this.nextElementSibling;
				const icon = this.querySelector('.faq-icon') as HTMLElement;
				
				if (content && content.classList.contains('hidden')) {
					content.classList.remove('hidden');
					if (icon) icon.style.transform = 'rotate(180deg)';
				} else if (content) {
					content.classList.add('hidden');
					if (icon) icon.style.transform = 'rotate(0deg)';
				}
			});
		});
	});
</script>