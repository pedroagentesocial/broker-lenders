---
import Layout from '../../layouts/Layout.astro';
import Contact from '../../components/Contact.astro';
import ImportantLegal from '../../components/ImportantLegal.astro';
import NextMoveSection from '../../components/NextMoveSection.astro';
---

<Layout title="Mortgage Payoff Calculator - Broker Lenders®">
	<!-- Breadcrumb -->
	<section class="bg-white py-4">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<nav class="flex" aria-label="Breadcrumb">
				<ol class="flex items-center space-x-4">
					<li>
						<div>
							<a href="/" class="text-gray-400 hover:text-gray-500 text-sm font-medium">
								Home
							</a>
						</div>
					</li>
					<li>
						<div class="flex items-center">
							<svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
							</svg>
							<a href="/calculators" class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700">Calculators</a>
						</div>
					</li>
					<li>
						<div class="flex items-center">
							<svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
							</svg>
							<span class="ml-4 text-sm font-medium text-gray-500">Mortgage Payoff Calculator</span>
						</div>
					</li>
				</ol>
			</nav>
		</div>
	</section>

	<!-- Main Calculator Section -->
	<section class="py-8 bg-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8">
				<h1 class="text-2xl font-bold text-gray-900 mb-3">Mortgage payoff calculator</h1>
				<p class="text-base text-gray-600 max-w-2xl mx-auto">
					Calculate how much you can save by making extra payments on your mortgage. 
					See how additional payments can reduce your loan term and total interest paid.
				</p>
			</div>

			<!-- 2-Column Layout Container -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
				<!-- Left Column: Calculator Form -->
				<div class="bg-gray-100 p-4 rounded-xl shadow-lg border border-gray-200">
					<form id="mortgage-form" class="space-y-4">
						<!-- Current Mortgage Balance -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
								<span class="text-xs font-medium text-gray-700">Current mortgage balance</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight">
										Example: $250,000 - Enter the remaining balance on your current mortgage
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="currentMortgageBalance" 
									name="currentMortgageBalance"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="0"
								>
							</div>
						</div>

						<!-- Years Left on Your Loan -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
								<span class="text-xs font-medium text-gray-700">Years left on your loan</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight">
										Example: 25 years - How many years are remaining on your current mortgage
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<input 
								type="text" 
								id="yearsLeft" 
								name="yearsLeft"
								class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
								placeholder="25"
							>
						</div>

						<!-- Current Home Value -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
								<span class="text-xs font-medium text-gray-700">Current home value</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight">
										Example: $350,000 - Current estimated market value of your home
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="currentHomeValue" 
									name="currentHomeValue"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="0"
								>
							</div>
						</div>

						<!-- Credit Profile and ZIP Code (Same Row) -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
							<!-- Credit Profile -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
								<div class="flex justify-start px-1.5 mb-0.5">
									<span class="text-xs font-medium text-gray-700">Credit profile</span>
								</div>
								<!-- Select Field -->
								<select 
									id="creditProfile" 
									name="creditProfile"
									class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm credit-profile-select"
								>
									<option value="" selected disabled class="text-gray-400">Select Range</option>
									<option value="less-than-580" class="text-gray-900">Less than 580</option>
									<option value="580-619" class="text-gray-900">580-619</option>
									<option value="620-659" class="text-gray-900">620-659</option>
									<option value="660-719" class="text-gray-900">660-719</option>
									<option value="720-759" class="text-gray-900">720-759</option>
									<option value="760-plus" class="text-gray-900">760+</option>
								</select>
							</div>

							<!-- ZIP Code -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
								<div class="flex justify-start px-1.5 mb-0.5">
									<span class="text-xs font-medium text-gray-700">ZIP code</span>
								</div>
								<!-- Input Field -->
								<input 
									type="text" 
									id="zipCode" 
									name="zipCode"
									value=""
									class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="Value"
								>
							</div>
						</div>
					</form>
					
					<!-- Calculate Button -->
					<div class="mt-4">
						<button 
							id="calculateButton"
							type="button"
							class="w-full bg-black text-white py-3 px-4 rounded-[48px] text-base font-semibold hover:bg-gray-800 transition-colors duration-200"
						>
							Calculate
						</button>
					</div>
					
					<!-- Logo and Legal Disclosures -->
					<div class="mt-4 flex items-center justify-center space-x-2 text-xs text-gray-500">
						<img 
							src="/BL logo negro.png" 
							alt="Broker Lenders Logo" 
							class="h-6 w-auto"
						>
						<span>|</span>
						<button 
							id="legalDisclosuresBtn"
							class="underline hover:text-gray-700 transition-colors cursor-pointer"
						>
							Legal disclosures
						</button>
					</div>
				</div>

				<!-- Right Column: Results and Message Cards -->
				<div class="space-y-4">
					<!-- Results Card -->
					<div id="resultsCard" class="bg-green-600/10 px-8 py-8 rounded-xl shadow-lg text-gray-900 min-h-80 flex flex-col justify-center">
						<div class="mt-4 mb-8 text-center">
							<div class="text-sm font-bold text-gray-700 mb-4">You can shorten your term by up to</div>
							<div class="text-8xl font-bold mb-4" id="yearsSaved">0</div>
						</div>

						<!-- Buttons -->
						<div class="flex gap-4 justify-center">
							<button class="px-10 py-5 border border-gray-400 text-gray-700 bg-transparent rounded-full hover:bg-gray-100 transition-colors text-base font-bold">
								Apply now
							</button>
							<button class="px-10 py-5 border border-gray-400 text-gray-700 bg-transparent rounded-full hover:bg-gray-100 transition-colors text-base font-bold">
								See today's rate
							</button>
						</div>
					</div>


				</div>
			</div>
		</div>
	</section>

	<!-- Legal Disclosures Modal -->
	<div id="legalModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
		<div class="bg-white rounded-[48px] max-w-4xl w-full max-h-[80vh] overflow-y-auto p-8 relative">
			<!-- Close Button -->
			<button 
				id="closeModal" 
				class="absolute top-6 right-6 text-gray-400 hover:text-gray-600 transition-colors"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>
			
			<!-- Modal Content -->
			<div class="pr-8">
				<h2 class="text-2xl font-bold text-gray-900 mb-6">Legal Disclosures</h2>
				
				<div class="space-y-6 text-gray-700 leading-relaxed">
					<p>
						This Broker Lenders refinance calculator is for estimation purposes only. Results do not reflect all loan programs and are subject to individual program loan limits. Qualification, rates and payments will vary based on timing and individual circumstances. This is not a commitment to lend.
					</p>
					
					<div>
						<h3 class="text-lg font-semibold text-gray-900 mb-3">Payment Example</h3>
						<p class="mb-3">Here's a payment example based on an average home price and the most common loan type:</p>
						
						<div class="bg-gray-50 p-4 rounded-lg space-y-2">
							<p><strong>Loan amount:</strong> $300,000</p>
							<p><strong>Loan type:</strong> 30-year Fixed-Rate Loan</p>
							<p><strong>Interest rate/APR:</strong> 7.375% (7.692% APR)</p>
							<p><strong>Monthly payment:</strong> $2,072.03</p>
							<p><strong>Points:</strong> 1.875 points, costs due at closing</p>
							<p><strong>Loan-to-value (LTV):</strong> 80.00%</p>
						</div>
					</div>
					
					<div class="space-y-3">
						<p>
							One point is equal to one percent of your loan amount. Payment does not include taxes and insurance. The actual payment amount will be greater. Some state and county maximum loan amount restrictions may apply. Rates shown are valid on publication date of April 18, 2024.
						</p>
						
						<p class="text-sm">
							¹If you didn't enter taxes and insurance amounts, an estimate of your taxes is based on the state selected. This does not include all fees.
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Next Move Section -->
	<NextMoveSection />

	<!-- How to use section -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">How to use a mortgage payoff calculator</h2>
				<p class="text-lg text-gray-600">
					Our mortgage payoff calculator helps you see how extra payments can save you money and time.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Enter Current Loan Details</h3>
					<p class="text-gray-600">
						Start by entering your current home value, remaining loan balance, interest rate, and loan term. 
						This establishes your baseline payment schedule.
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Add Extra Payment Amount</h3>
					<p class="text-gray-600">
						Enter the additional amount you plan to pay each month toward your principal. 
						Even small extra payments can make a significant difference.
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a4 4 0 118 0v4m-4 8a2 2 0 11-4 0 2 2 0 014 0z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">See Time Savings</h3>
					<p class="text-gray-600">
						The calculator shows how many years and months you'll save by making extra payments. 
						Paying off your mortgage early means freedom from monthly payments sooner.
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Calculate Interest Savings</h3>
					<p class="text-gray-600">
						See exactly how much you'll save in total interest payments over the life of your loan. 
						These savings can be substantial, often tens of thousands of dollars.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Tips Section -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">Mortgage payoff calculator tips</h2>
				<p class="text-lg text-gray-600">
					Maximize your mortgage payoff strategy with these helpful insights.
				</p>
			</div>

			<div class="space-y-8">
				<div class="bg-blue-50 p-6 rounded-xl">
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Start Small</h3>
					<p class="text-gray-700">
						Even an extra $50-100 per month can save you thousands in interest and years off your loan term. 
						Start with what you can afford and increase payments when possible.
					</p>
				</div>

				<div class="bg-green-50 p-6 rounded-xl">
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Apply Windfalls Strategically</h3>
					<p class="text-gray-700">
						Use tax refunds, bonuses, or other unexpected money toward your mortgage principal. 
						These lump-sum payments can dramatically reduce your loan balance and interest costs.
					</p>
				</div>

				<div class="bg-yellow-50 p-6 rounded-xl">
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Consider Your Other Debts</h3>
					<p class="text-gray-700">
						Before making extra mortgage payments, ensure you've paid off higher-interest debt like credit cards. 
						Also, make sure you have an emergency fund and are contributing to retirement savings.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<div class="bg-white py-16">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
				<!-- Columna Izquierda -->
				<div>
					<h2 class="text-5xl font-bold text-gray-900 mb-4">
						Mortgage payoff calculator FAQs
					</h2>
					<p class="text-sm text-gray-600">
						Don't see your question here? We love helping people understand how payoff calculations work and what yours could be. Just talk to us.
					</p>
				</div>
				
				<!-- Columna Derecha -->
				<div class="space-y-4">
					<!-- FAQ Item 1 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:bg-gray-50">
							<span class="font-medium text-gray-900">How does a mortgage payoff calculator work?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4 text-gray-600">
							A mortgage payoff calculator uses your current loan balance, remaining term, and interest rate to show how extra payments can reduce your loan term and total interest paid. It calculates the potential time and money savings from different payment strategies.
						</div>
					</div>

					<!-- FAQ Item 2 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:bg-gray-50">
							<span class="font-medium text-gray-900">What are the benefits of making extra mortgage payments?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4 text-gray-600">
							Extra payments reduce your principal balance faster, which means less interest paid over time and a shorter loan term. Even small additional payments can save thousands of dollars and years off your mortgage.
						</div>
					</div>

					<!-- FAQ Item 3 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:bg-gray-50">
							<span class="font-medium text-gray-900">Should I make extra payments or invest the money instead?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4 text-gray-600">
							This depends on your mortgage rate versus potential investment returns. If your mortgage rate is higher than expected investment returns, paying extra makes sense. Also consider your risk tolerance, emergency fund, and other high-interest debt.
						</div>
					</div>

					<!-- FAQ Item 4 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:bg-gray-50">
							<span class="font-medium text-gray-900">How much extra should I pay toward my mortgage?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4 text-gray-600">
							Start with what you can comfortably afford without straining your budget. Even an extra $50-100 per month can make a significant difference. Use our calculator to see how different amounts affect your payoff timeline and savings.
						</div>
					</div>

					<!-- FAQ Item 5 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:bg-gray-50">
							<span class="font-medium text-gray-900">Is refinancing better than making extra payments?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4 text-gray-600">
							Refinancing to a lower rate or shorter term can provide guaranteed savings, while extra payments offer flexibility. Consider refinancing if rates have dropped significantly or if you want to switch to a 15-year loan for faster payoff.
						</div>
					</div>

					<!-- FAQ Item 6 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:bg-gray-50">
							<span class="font-medium text-gray-900">Are there tax implications to paying off my mortgage early?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4 text-gray-600">
							Paying off your mortgage early means less mortgage interest to deduct on your taxes. However, the tax deduction is typically worth less than the interest you save by paying off the loan early, especially with current tax law changes.
						</div>
					</div>

					<!-- FAQ Item 7 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:bg-gray-50">
							<span class="font-medium text-gray-900">What's the best strategy for paying off my mortgage early?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4 text-gray-600">
							The best strategy depends on your situation. Options include making bi-weekly payments, adding extra to your monthly payment, applying windfalls like bonuses or tax refunds, or refinancing to a shorter term. Start with what fits your budget and goals.
						</div>
					</div>

					<!-- FAQ Item 8 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:bg-gray-50">
							<span class="font-medium text-gray-900">When should I avoid making extra mortgage payments?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4 text-gray-600">
							Avoid extra payments if you have high-interest debt (credit cards), lack an emergency fund, aren't maximizing employer 401(k) matching, or have a very low mortgage rate where investing might yield better returns.
