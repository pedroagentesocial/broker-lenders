---
import Layout from '../../layouts/Layout.astro';
import Contact from '../../components/Contact.astro';
import ImportantLegal from '../../components/ImportantLegal.astro';
import NextMoveSection from '../../components/NextMoveSection.astro';
---

<Layout title="Refinance Calculator - Broker Lenders®">
	<!-- Breadcrumb -->
	<section class="bg-white py-4">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<nav class="flex" aria-label="Breadcrumb">
				<ol class="flex items-center space-x-4">
					<li>
						<div>
							<a href="/" class="text-gray-400 hover:text-gray-500 text-sm font-medium">
								Home
							</a>
						</div>
					</li>
					<li>
						<div class="flex items-center">
							<svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
							</svg>
							<a href="/calculators" class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700">Calculators</a>
						</div>
					</li>
					<li>
						<div class="flex items-center">
							<svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
							</svg>
							<span class="ml-4 text-sm font-medium text-gray-500">Refinance Calculator</span>
						</div>
					</li>
				</ol>
			</nav>
		</div>
	</section>

	<!-- Main Calculator Section -->
	<section class="py-8 bg-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8">
				<h1 class="text-2xl font-bold text-gray-900 mb-3">Refinance calculator</h1>
				<p class="text-base text-gray-600 max-w-2xl mx-auto">
					See if refinancing makes sense for you and calculate potential savings. 
					Compare your current mortgage with new loan options to find the best deal.
				</p>
			</div>

			<!-- 2-Column Layout Container -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
				<!-- Left Column: Calculator Form -->
				<div class="bg-gray-100 p-4 rounded-xl shadow-lg border border-gray-200">
					<form id="mortgage-form" class="space-y-4">
						<!-- Current Mortgage Balance -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
								<span class="text-xs font-medium text-gray-700">Current mortgage balance</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight">
										Example: $250,000 - Enter the remaining balance on your current mortgage
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="currentMortgageBalance" 
									name="currentMortgageBalance"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="0"
								>
							</div>
						</div>

						<!-- Current Monthly Payment -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
								<span class="text-xs font-medium text-gray-700">Current monthly payment</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight">
										Example: $1,850 - Enter your current monthly mortgage payment (principal + interest)
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="currentMonthlyPayment" 
									name="currentMonthlyPayment"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="0"
								>
							</div>
						</div>

						<!-- Current Home Value -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
								<span class="text-xs font-medium text-gray-700">Current home value</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight">
										Example: $400,000 - Enter the current estimated value of your home
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="currentHomeValue" 
									name="currentHomeValue"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="0"
								>
							</div>
						</div>

						<!-- Credit Profile and ZIP Code (Same Row) -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
							<!-- Credit Profile -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
								<div class="flex justify-start px-1.5 mb-0.5">
									<span class="text-xs font-medium text-gray-700">Credit profile</span>
								</div>
								<!-- Select Field -->
								<select 
									id="creditProfile" 
									name="creditProfile"
									class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm credit-profile-select"
								>
									<option value="" selected disabled class="text-gray-400">Select Range</option>
									<option value="less-than-580" class="text-gray-900">Less than 580</option>
									<option value="580-619" class="text-gray-900">580-619</option>
									<option value="620-659" class="text-gray-900">620-659</option>
									<option value="660-719" class="text-gray-900">660-719</option>
									<option value="720-plus" class="text-gray-900">720+</option>
								</select>
							</div>

							<!-- ZIP Code -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
								<div class="flex justify-start px-1.5 mb-0.5">
									<span class="text-xs font-medium text-gray-700">ZIP code</span>
								</div>
								<!-- Input Field -->
								<input 
									type="text" 
									id="zipCode" 
									name="zipCode"
									value=""
									class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="Value"
								>
							</div>
						</div>


					</form>
					
					<!-- Calculate Button -->
					<div class="mt-4">
						<button 
							id="calculateButton"
							type="button"
							class="w-full bg-black text-white py-3 px-4 rounded-[48px] text-base font-semibold hover:bg-gray-800 transition-colors duration-200"
						>
							Calculate
						</button>
					</div>
					
					<!-- Logo and Legal Disclosures -->
					<div class="mt-4 flex items-center justify-center space-x-2 text-xs text-gray-500">
						<img 
							src="/BL logo negro.png" 
							alt="Broker Lenders Logo" 
							class="h-6 w-auto"
						>
						<span>|</span>
						<button 
							id="legalDisclosuresBtn"
							class="underline hover:text-gray-700 transition-colors cursor-pointer"
						>
							Legal disclosures
						</button>
					</div>
				</div>

				<!-- Right Column: Results and Message Cards -->
				<div class="space-y-4">
					<!-- Results Card -->
					<div id="resultsCard" class="bg-purple-600/10 px-8 py-8 rounded-xl shadow-lg text-gray-900 min-h-80 flex flex-col justify-between">
						<div class="text-left space-y-4">
							<div class="text-sm font-bold text-gray-700">You could save</div>
							<div class="text-8xl font-bold speedometer-value" id="monthlySavings">$0</div>
							<div class="text-sm font-medium text-gray-600 opacity-0 transition-opacity duration-500" id="eachMonthLabel">each month</div>
						</div>

						<!-- Button -->
						<div class="text-left mt-2">
							<button class="px-8 py-4 border border-gray-400 text-gray-700 bg-transparent rounded-full hover:bg-gray-100 transition-colors text-sm font-bold">
								Apply now →
							</button>
						</div>
					</div>


				</div>
			</div>
		</div>
	</section>

	<!-- Legal Disclosures Modal -->
	<div id="legalModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
		<div class="bg-white rounded-[48px] max-w-4xl w-full max-h-[80vh] overflow-y-auto p-8 relative">
			<!-- Close Button -->
			<button 
				id="closeModal" 
				class="absolute top-6 right-6 text-gray-400 hover:text-gray-600 transition-colors"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>
			
			<!-- Modal Content -->
			<div class="pr-8">
				<h2 class="text-2xl font-bold text-gray-900 mb-6">Legal Disclosures</h2>
				
				<div class="space-y-6 text-gray-700 leading-relaxed">
					<p>
						The Broker Lenders refinance calculator is for estimation purposes only. Results do not reflect all loan programs and are subject to individual program loan limits. Qualification, rates and payments will vary based on timing and individual circumstances. This is not a commitment to lend.
					</p>
					
					<div>
						<h3 class="text-lg font-semibold text-gray-900 mb-3">Payment Example</h3>
						<p class="mb-3">Here's a payment example based on an average home price and the most common loan type:</p>
						
						<div class="bg-gray-50 p-4 rounded-lg space-y-2">
							<p><strong>Loan amount:</strong> $300,000</p>
							<p><strong>Loan type:</strong> 30-year Fixed-Rate Loan</p>
							<p><strong>Interest rate/APR:</strong> 7.375% (7.692% APR)</p>
							<p><strong>Monthly payment:</strong> $2,072.03</p>
							<p><strong>Points:</strong> 1.875 points, costs due at closing</p>
							<p><strong>Loan-to-value (LTV):</strong> 80.00%</p>
						</div>
					</div>
					
					<div class="space-y-3">
						<p>
							One point is equal to one percent of your loan amount. Payment does not include taxes and insurance. The actual payment amount will be greater. Some state and county maximum loan amount restrictions may apply. Rates shown are valid on publication date of April 18, 2024.
						</p>
						
						<p class="text-sm">
							¹If you didn't enter taxes and insurance amounts, an estimate of your taxes is based on the state selected. This does not include all fees.
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Next Move Section -->
	<NextMoveSection />

	<!-- How to use section -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">How to use a refinance calculator</h2>
				<p class="text-lg text-gray-600">
					Our refinance calculator helps you determine if refinancing your current mortgage makes financial sense.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Enter Current Home Value</h3>
					<p class="text-gray-600">
						Start by entering your home's current market value and remaining loan balance. 
						This helps determine your equity and refinancing options.
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Compare New Loan Terms</h3>
					<p class="text-gray-600">
						Enter the new interest rate and loan term you're considering. 
						Lower rates or shorter terms can lead to significant savings.
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Factor in Closing Costs</h3>
					<p class="text-gray-600">
						Consider refinancing costs like appraisal fees, title insurance, and origination fees. 
						These affect your break-even timeline.
					</p>
				</div>

				<div class="bg-gray-50 p-6 rounded-xl shadow-sm">
					<div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
						<svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
						</svg>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Calculate Your Savings</h3>
					<p class="text-gray-600">
						See your potential monthly savings and total interest savings over the life of the loan. 
						Determine if refinancing is worth it for your situation.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Tips Section -->
	<section class="py-16 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">Refinance calculator tips</h2>
				<p class="text-lg text-gray-600">
					Make the most of your refinancing decision with these helpful insights.
				</p>
			</div>

			<div class="space-y-8">
				<div class="bg-blue-50 p-6 rounded-xl">
					<h3 class="text-xl font-semibold text-gray-900 mb-3">When to Refinance</h3>
					<p class="text-gray-700">
						Generally, refinancing makes sense when you can lower your interest rate by at least 0.5-1%. 
						Also consider refinancing to switch from an adjustable to fixed rate, or to access home equity.
					</p>
				</div>

				<div class="bg-green-50 p-6 rounded-xl">
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Break-Even Analysis</h3>
					<p class="text-gray-700">
						Calculate how long it will take to recoup your closing costs through monthly savings. 
						If you plan to stay in your home longer than the break-even period, refinancing likely makes sense.
					</p>
				</div>

				<div class="bg-yellow-50 p-6 rounded-xl">
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Cash-Out Refinancing</h3>
					<p class="text-gray-700">
						If your home has appreciated significantly, you might consider cash-out refinancing to access 
						equity for home improvements, debt consolidation, or other major expenses.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Refinance Calculator FAQs Section -->
	<section class="py-16 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
				<!-- Left Column: Title and Description -->
				<div>
					<h2 class="text-3xl font-bold text-gray-900 mb-4">
						Refinance Calculator FAQs
					</h2>
					<p class="text-lg text-gray-600 leading-relaxed">
						Don't see your question here? We love helping people understand how refinancing works and what yours could be. Just talk to us.
					</p>
				</div>

				<!-- Right Column: FAQ Items -->
				<div class="space-y-4">
					<!-- FAQ Item 1 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-inset">
							<span class="font-medium text-gray-900">When should I consider refinancing my mortgage?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4">
							<p class="text-gray-600">
								Consider refinancing when interest rates drop significantly (typically 0.5-1% below your current rate), when your credit score has improved, when you want to change loan terms, or when you need to access home equity. Also consider refinancing to remove PMI or switch from an adjustable to fixed-rate mortgage.
							</p>
						</div>
					</div>

					<!-- FAQ Item 2 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-inset">
							<span class="font-medium text-gray-900">How much can I save by refinancing?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4">
							<p class="text-gray-600">
								Savings depend on your current rate, new rate, loan balance, and how long you stay in the home. A 1% rate reduction on a $300,000 loan could save you about $300/month. However, you must factor in closing costs (typically 2-5% of loan amount) and break-even time to determine if refinancing makes financial sense.
							</p>
						</div>
					</div>

					<!-- FAQ Item 3 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-inset">
							<span class="font-medium text-gray-900">What are the costs associated with refinancing?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
							</svg>
						</button>
						<div class="faq-content hidden px-6 pb-4">
							<p class="text-gray-600">
								Refinancing costs typically include application fees, appraisal fees, title insurance, attorney fees, and origination fees. Total costs usually range from 2-5% of your loan amount. Some lenders offer "no-cost" refinancing, but this usually means higher interest rates or rolling costs into the loan balance.
							</p>
						</div>
					</div>

					<!-- FAQ Item 4 -->
					<div class="border border-gray-200 rounded-lg">
						<button class="faq-button w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-inset">
							<span class="font-medium text-gray-900">What is cash-out refinancing?</span>
							<svg class="faq-icon w-5 h-5 text-gray-500 transform transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
