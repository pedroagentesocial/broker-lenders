---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
const lang = 'en';
const embedId = 'D9UtsRtn1b45RbmOyilz_' + Date.now();
---

<Layout title="Book a Meeting - Broker Lenders" lang={lang}>
  <section class="bg-white min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-6">Book / Agendar</h1>
      <div class="relative w-full" style="min-height:70vh">
        <div id="booking-loader" class="absolute inset-0 flex items-center justify-center">
          <div class="flex flex-col items-center gap-3">
            <div class="animate-spin h-6 w-6 rounded-full border-2 border-gray-300 border-t-black"></div>
            <div class="text-sm text-gray-600">Cargando calendario…</div>
          </div>
        </div>
        <div id="booking-script-embed" class="w-full h-full">
          <iframe src="https://api.msgsndr.com/widget/booking/D9UtsRtn1b45RbmOyilz" style="width: 100%; border: none; overflow: hidden;" scrolling="no" id={embedId}></iframe><br>
          <script src="https://api.msgsndr.com/js/form_embed.js" type="text/javascript"></script>
        </div>
        <div id="booking-fallback" class="hidden absolute inset-0 flex items-center justify-center">
          <a href="https://api.msgsndr.com/widget/booking/D9UtsRtn1b45RbmOyilz" target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-[48px] bg-black text-white hover:bg-red-600 transition-colors">Abrir calendario</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  const bookingLoader = document.getElementById('booking-loader');
  const bookingFallback = document.getElementById('booking-fallback');
  const bookingScriptWrap = document.getElementById('booking-script-embed');
  const embedFrame = document.getElementById({embedId});
  let loaded = false;
  embedFrame?.addEventListener('load', () => {
    loaded = true;
    bookingLoader?.classList.add('hidden');
  });
  setTimeout(() => {
    if (!loaded) {
      bookingLoader?.classList.add('hidden');
      if (bookingScriptWrap) bookingScriptWrap.classList.add('opacity-0');
      bookingFallback?.classList.remove('hidden');
    }
  }, 8000);
</script>
