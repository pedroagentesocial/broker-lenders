---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
const lang = 'en';
const previewId = 'ghl_preview_' + Date.now();
---

<Layout title="Book a Meeting - Broker Lenders" lang={lang}>
  <section class="bg-white min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-6">Book / Agendar</h1>
      <div class="relative w-full" style="min-height:70vh">
        <div id="booking-loader" class="absolute inset-0 flex items-center justify-center">
          <div class="flex flex-col items-center gap-3">
            <div class="animate-spin h-6 w-6 rounded-full border-2 border-gray-300 border-t-black"></div>
            <div class="text-sm text-gray-600">Cargando calendario…</div>
            <a href="https://app.gohighlevel.com/v2/preview/geT0LqyQmsFgoEGri1xP?notrack=true" target="_blank" rel="noopener noreferrer" class="mt-2 px-4 py-2 rounded-[48px] bg-black text-white hover:bg-red-600 transition-colors">Abrir ahora</a>
          </div>
        </div>
        <div id="booking-frame-wrap" class="w-full h-full">
          <iframe id={previewId} src="https://app.gohighlevel.com/v2/preview/geT0LqyQmsFgoEGri1xP?notrack=true" style="width: 100%; height: 70vh; border: none; overflow: hidden;" loading="lazy"></iframe>
        </div>
        <div id="booking-fallback" class="hidden absolute inset-0 flex items-center justify-center">
          <a href="https://app.gohighlevel.com/v2/preview/geT0LqyQmsFgoEGri1xP?notrack=true" target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-[48px] bg-black text-white hover:bg-red-600 transition-colors">Abrir calendario</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  const loader = document.getElementById('booking-loader');
  const fb = document.getElementById('booking-fallback');
  const frame = document.getElementById(previewId);
  let ok = false;
  frame?.addEventListener('load', () => {
    ok = true;
    if (loader) { loader.classList.add('hidden'); loader.style.display = 'none'; }
  });
  setTimeout(() => {
    if (loader) { loader.classList.add('hidden'); loader.style.display = 'none'; }
  }, 3000);
  setTimeout(() => {
    if (!ok) {
      if (loader) { loader.classList.add('hidden'); loader.style.display = 'none'; }
      fb?.classList.remove('hidden');
    }
  }, 10000);
</script>
