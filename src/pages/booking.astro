---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
const lang = 'en';
const previewId = 'ghl_preview_' + Date.now();
---

<Layout title="Book a Meeting - Broker Lenders" lang={lang}>
  <section class="bg-white min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-6">Book / Agendar</h1>
      <div class="w-full" style="min-height:70vh">
        <iframe id={previewId} src="https://app.gohighlevel.com/v2/preview/geT0LqyQmsFgoEGri1xP?notrack=true" style="width: 100%; height: 80vh; border: none; overflow: auto;" loading="lazy"></iframe>
      </div>
    </div>
  </section>
</Layout>

<script is:inline></script>
