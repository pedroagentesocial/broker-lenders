---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
const lang = 'en';
const embedId = 'D9UtsRtn1b45RbmOyilz_' + Date.now();
---

<Layout title="Book a Meeting - Broker Lenders" lang={lang}>
  <section class="bg-white min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-6">Book / Agendar</h1>
      <div class="w-full" style="min-height:70vh">
        <div id="booking-script-embed" class="w-full h-full">
          <iframe src="https://api.agentesocial.com/widget/booking/D9UtsRtn1b45RbmOyilz" style="width: 100%;border:none;overflow: hidden;" scrolling="no" id={embedId}></iframe><br>
          <script src="https://api.agentesocial.com/js/form_embed.js" type="text/javascript"></script>
        </div>
        <iframe id="booking-legacy" src="https://api.agentesocial.com/widget/bookings/citas-FVaRm" title="Booking" class="w-full h-full hidden" loading="lazy" referrerpolicy="no-referrer"></iframe>
        <div id="booking-fallback" class="hidden w-full h-full flex items-center justify-center">
          <a href="https://api.msgsndr.com/widget/booking/D9UtsRtn1b45RbmOyilz" target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-[48px] bg-black text-white hover:bg-red-600 transition-colors">Open Calendar</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  (function(){
    const bookingFallback = document.getElementById('booking-fallback');
    const embedFrame = document.getElementById({embedId});
    const legacyFrame = document.getElementById('booking-legacy');
    const bookingScriptWrap = document.getElementById('booking-script-embed');
    let embedLoaded = false;
    embedFrame?.addEventListener('load', () => { embedLoaded = true; });
    setTimeout(() => {
      const rect = embedFrame?.getBoundingClientRect();
      const ok = embedLoaded || (rect && rect.height > 100);
      if (!ok && bookingScriptWrap && legacyFrame) {
        bookingScriptWrap.classList.add('hidden');
        legacyFrame.classList.remove('hidden');
        let legacyLoaded = false;
        legacyFrame.addEventListener('load', () => { legacyLoaded = true; });
        setTimeout(() => {
          const r2 = legacyFrame.getBoundingClientRect();
          const ok2 = legacyLoaded || (r2 && r2.height > 100);
          if (!ok2 && bookingFallback) {
            legacyFrame.classList.add('hidden');
            bookingFallback.classList.remove('hidden');
          }
        }, 5000);
      }
    }, 5000);
  })();
</script>
