---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
const lang = 'en';
const embedId = 'D9UtsRtn1b45RbmOyilz_' + Date.now();
const vendorId = 'D9UtsRtn1b45RbmOyilz_vendor_' + Date.now();
---

<Layout title="Book a Meeting - Broker Lenders" lang={lang}>
  <section class="bg-white min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-6">Book / Agendar</h1>
      <div class="relative w-full" style="min-height:70vh">
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="flex flex-col items-center gap-3">
            <div class="animate-spin h-6 w-6 rounded-full border-2 border-gray-300 border-t-black"></div>
            <div class="text-sm text-gray-600">Redirigiendo al calendario…</div>
            <a href="https://api.agentesocial.com/get/bookings/citas-pruebas" target="_blank" rel="noopener noreferrer" class="mt-2 px-4 py-2 rounded-[48px] bg-black text-white hover:bg-red-600 transition-colors">Abrir ahora</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  try { window.location.replace('https://api.agentesocial.com/get/bookings/citas-pruebas'); } catch {}
</script>
