      </div>
      
      <!-- Contenido con scroll -->
      <div class="px-8 py-6 overflow-y-auto max-h-[60vh]">
        <div class="space-y-4 text-gray-700 leading-relaxed">
          <p>Every situation is different. These figures are for estimation purposes only and may not reflect the exact terms of your loan. This is not a commitment to lend.</p>
          
          <p><strong>30-year Fixed-Rate Loan:</strong> Payment assumes a loan-to-value (LTV) of 80.00%.</p>
          
          <p><strong>20-year Fixed-Rate Loan:</strong> Payment assumes a loan-to-value (LTV) of 80.00%.</p>
          
          <p><strong>30-year FHA Fixed-Rate Loan:</strong> Payment assumes a loan-to-value (LTV) of 80.00%.</p>
          
          <p>Payment includes a one-time upfront mortgage insurance premium at 1.75% of the base loan amount and a monthly mortgage insurance premium (MIP) calculated at 0.5% of the base loan amount. For mortgages with a loan-to-value (LTV) ratio of 80.00%, the 0.5% monthly MIP will be paid for the first 11 years of the mortgage term. Thereafter, the monthly loan payment will consist of equal monthly principal and interest payments until the end of the loan.</p>
          
          <p><strong>30-year Fixed-Rate Jumbo Loan:</strong> Payment assumes a loan-to-value (LTV) of 70.00%.</p>
          
          <p><strong>30-year Fixed-Rate VA Loan:</strong> Payment assumes a loan-to-value (LTV) of 80.00%.</p>
          
          <p>VA loans do not require PMI. The VA loan is a benefit of military service and only offered to veterans, surviving spouses and active duty military.</p>
          
          <h3 class="text-lg font-semibold text-gray-900 mt-6">Assumptions</h3>
          
          <p>For all rates shown, unless otherwise noted, we assumed:</p>
          
          <ul class="list-disc pl-6 space-y-2">
            <li>You're buying a single-family home that's your primary residence.</li>
            <li>Closing costs will be paid up front, not rolled into the loan.</li>
            <li>Your debt-to-income ratio is less than 43%.</li>
            <li>Your credit score is 740.</li>
            <li>You'll have an escrow account for payment of taxes and insurance.</li>
            <li>One point is equal to one percent of the loan amount.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- JavaScript para el modal y estados -->
  <script define:vars={{ ratesData }}>
    // Convertir datos de Astro al formato esperado por el JavaScript
    const stateRates = {};
    
    // Mapeo de estados y tipos de préstamos
    const stateMapping = {
      'utah': 'utah',
      'idaho': 'idaho', 
      'nevada': 'nevada',
      'california': 'california',
      'texas': 'texas',
      'florida': 'florida',
      'colorado': 'colorado'
    };
    
    const loanTypeMapping = {
      '30-year-fixed': '30-fixed',
      '20-year-fixed': '20-fixed',
      '15-year-fixed': '15-fixed',
      '30-year-fha': 'fha',
      '30-year-jumbo': 'jumbo'
    };
    
    // Convertir datos del JSON al formato esperado
    Object.keys(stateMapping).forEach(stateKey => {
      const stateName = stateMapping[stateKey];
      stateRates[stateName] = {};
      
      Object.keys(loanTypeMapping).forEach(loanKey => {
        const loanType = loanTypeMapping[loanKey];
        const rateData = ratesData.states[stateKey][loanKey];
        
        // Calcular pago mensual basado en el monto del préstamo
        let loanAmount = 350000; // Default para préstamos normales
        if (loanKey === '30-year-jumbo') {
          loanAmount = 1100000; // Monto para jumbo
        }
        
        const monthlyPayment = calculateMonthlyPayment(loanAmount, parseFloat(rateData.rate), loanKey);
        
        stateRates[stateName][loanType] = {
          rate: rateData.rate,
          apr: rateData.apr,
          points: computePointsDisplay(rateData.points, loanAmount),
          payment: `$${monthlyPayment.toLocaleString()}`
        };
      });
      
      // Agregar datos de VA (usando 30-year-fixed como base con ajuste)
      const vaBaseRate = ratesData.states[stateKey]['30-year-fixed'];
      stateRates[stateName]['va'] = {
        rate: (parseFloat(vaBaseRate.rate) - 0.25).toFixed(3) + '%', // VA típicamente 0.25% menos
        apr: (parseFloat(vaBaseRate.apr) - 0.25).toFixed(3) + '%',
        points: computePointsDisplay(1.0, 350000),
        payment: `$${calculateMonthlyPayment(350000, parseFloat(vaBaseRate.rate) - 0.25, '30-year-fixed').toLocaleString()}`
      };
    });
    
    // Función para calcular pago mensual
    function calculateMonthlyPayment(principal, annualRate, loanType) {
      let years = 30;
      if (loanType === '15-year-fixed') years = 15;
      if (loanType === '20-year-fixed') years = 20;
      
      const monthlyRate = annualRate / 100 / 12;
      const numberOfPayments = years * 12;
      
      const monthlyPayment = principal * (monthlyRate * Math.pow(1 + monthlyRate, numberOfPayments)) / 
                            (Math.pow(1 + monthlyRate, numberOfPayments) - 1);
      
      return Math.round(monthlyPayment);
    }

    // Nueva función para calcular y formatear puntos
    function computePointsDisplay(pointsPercent, loanAmount) {
      const p = typeof pointsPercent === 'string' ? parseFloat(pointsPercent) : pointsPercent;
      const dollars = Math.round(loanAmount * p / 100);
      return `${p.toFixed(2)} ($${dollars.toLocaleString()})`;
    }

    // Función para actualizar las tasas
    function updateRates(state) {
      const container = document.getElementById('ratesContent');
      if (container) {
        container.classList.add('opacity-0');
      }
      const rates = stateRates[state];
      document.getElementById('rate-30-fixed').textContent = rates['30-fixed'].rate;
      document.getElementById('apr-30-fixed').textContent = rates['30-fixed'].apr;
      document.getElementById('points-30-fixed').textContent = rates['30-fixed'].points;
      document.getElementById('payment-30-fixed').textContent = rates['30-fixed'].payment;
      
      document.getElementById('rate-20-fixed').textContent = rates['20-fixed'].rate;
      document.getElementById('apr-20-fixed').textContent = rates['20-fixed'].apr;
      document.getElementById('points-20-fixed').textContent = rates['20-fixed'].points;
      document.getElementById('payment-20-fixed').textContent = rates['20-fixed'].payment;
      
      document.getElementById('rate-fha').textContent = rates.fha.rate;
      document.getElementById('apr-fha').textContent = rates.fha.apr;
      document.getElementById('points-fha').textContent = rates.fha.points;
      document.getElementById('payment-fha').textContent = rates.fha.payment;
      
      document.getElementById('rate-va').textContent = rates.va.rate;
      document.getElementById('apr-va').textContent = rates.va.apr;
      document.getElementById('points-va').textContent = rates.va.points;
      document.getElementById('payment-va').textContent = rates.va.payment;
      
      document.getElementById('rate-jumbo').textContent = rates.jumbo.rate;
      document.getElementById('apr-jumbo').textContent = rates.jumbo.apr;
      document.getElementById('points-jumbo').textContent = rates.jumbo.points;
      document.getElementById('payment-jumbo').textContent = rates.jumbo.payment;
      
      if (container) {
        setTimeout(() => {
          container.classList.remove('opacity-0');
        }, 150);
      }
    }

    // Función para actualizar estilos de botones
    function updateButtonStyles(activeState) {
      const buttons = document.querySelectorAll('.state-btn');
      buttons.forEach(button => {
        if (button.dataset.state === activeState) {
          button.className = 'state-btn px-4 py-2 bg-black text-white border border-gray-300 rounded-full text-sm font-medium hover:bg-gray-800 transition-colors';
        } else {
          button.className = 'state-btn px-4 py-2 bg-white border border-gray-300 rounded-full text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors';
        }
      });
    }

    // FAQ Accordion functionality
    document.addEventListener('DOMContentLoaded', function() {
      // Inicializar botones de estado
      const stateButtons = document.querySelectorAll('.state-btn');
      stateButtons.forEach(button => {
        button.addEventListener('click', function() {
          const state = this.dataset.state;
          updateRates(state);
          updateButtonStyles(state);
          // Mantener el estado seleccionado en el URL
          const url = new URL(window.location.href);
          url.searchParams.set('state', state);
          window.history.replaceState({}, '', url);
        });
      });

      // Leer el estado inicial desde el parámetro ?state del URL
      const params = new URLSearchParams(window.location.search);
      const initialStateParam = params.get('state');
      const validStates = ['utah','idaho','nevada','california','texas','florida','colorado'];
      const initialState = validStates.includes(initialStateParam) ? initialStateParam : 'utah';
      updateRates(initialState);
      updateButtonStyles(initialState);

      // FAQ functionality
      const faqButtons = document.querySelectorAll('.faq-button');
      
      faqButtons.forEach(button => {
        button.addEventListener('click', function() {
          const content = this.nextElementSibling;
          const icon = this.querySelector('.faq-icon');
          
          if (content.classList.contains('hidden')) {
            content.classList.remove('hidden');
            icon.style.transform = 'rotate(180deg)';
          } else {
            content.classList.add('hidden');
            icon.style.transform = 'rotate(0deg)';
          }
        });
      });
    });

    // Modal functionality
    const openModal = document.getElementById('openModal');
    const closeModal = document.getElementById('closeModal');
    const modal = document.getElementById('legalModal');

    if (openModal && closeModal && modal) {
      openModal.addEventListener('click', () => {
        modal.classList.remove('hidden');
      });

      closeModal.addEventListener('click', () => {
        modal.classList.add('hidden');
      });

      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.add('hidden');
        }
      });
    }
  </script>
</Layout>


  <script>
    async function hydrateRates() {
      try {
        const res = await fetch('/rates-data.json', { cache: 'no-store' });
        if (!res.ok) return;
        const data = await res.json();
        // Actualizar timestamp dinámico
        const footerTs = document.querySelector('.text-xs.text-gray-600:last-child');
        if (footerTs && data.timestamp) {
          const d = new Date(data.timestamp);
          const formatted = d.toLocaleString('en-US', { timeZone: 'UTC', hour: '2-digit', minute: '2-digit', hour12: true, month: 'long', day: 'numeric', year: 'numeric' }) + ' UTC';
          footerTs.textContent = `Rates are current as of ${formatted}`;
        }
        // Rehidratar stateRates usando data del archivo público
        window.__ratesData = data;
        if (typeof window.rebuildRates === 'function') {
          window.rebuildRates(data);
        }
      } catch (e) {
        console.warn('Failed to fetch static rates-data.json:', e);
      }
    }
    document.addEventListener('DOMContentLoaded', hydrateRates);
  </script>
</Layout>