                </a>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Right side - Image -->
        <div>
          <img 
            src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=conventional%20loan%20happy%20family%20in%20new%20home%2C%20bright%20natural%20light%2C%20professional%20photography&image_size=landscape_4_3" 
            alt="Happy family in new home" 
            class="w-full h-96 object-cover rounded-2xl"
          />
