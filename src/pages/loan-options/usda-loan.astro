---
import Layout from '../../layouts/Layout.astro';
import WaysHelp from '../../components/WaysHelp.astro';
import FAQSectionUSDA from '../../components/FAQSectionUSDA.astro';
import Contact from '../../components/Contact.astro';
import ImportantLegal from '../../components/ImportantLegal.astro';
---

<Layout title="USDA Loan - Broker Lenders">
  <!-- Breadcrumb Section -->
  <div class="bg-white py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm">
        <a href="/" class="text-gray-700 hover:text-gray-900">Home</a>
        <span class="mx-2 text-gray-500">/</span>
        <a href="/loan-options" class="text-gray-700 hover:text-gray-900">Loan options</a>
        <span class="mx-2 text-gray-500">/</span>
        <span class="text-gray-700">USDA loan</span>
      </nav>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
        <!-- Left side - Content -->
        <div class="flex flex-col justify-center">
          <div class="bg-gray-100 rounded-[48px] p-8 lg:p-10 h-96 flex flex-col justify-center">
            <div class="space-y-6">
              <h1 class="text-4xl lg:text-5xl font-bold text-gray-900">
                USDA loan
              </h1>
              <p class="text-lg text-gray-600">
                Rural development loans with no down payment for eligible properties in qualifying areas. Make homeownership affordable in rural communities.
              </p>
              <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center justify-center w-fit">
                Get started
              </a>
            </div>
          </div>
        </div>
        
        <!-- Right side - Image -->
        <div>
          <img 
            src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=beautiful%20rural%20home%2C%20countryside%20setting%2C%20farmhouse%20style%2C%20rolling%20hills%20background%2C%20professional%20photography%2C%20warm%20lighting&image_size=landscape_4_3" 
            alt="Rural home" 
            class="w-full h-96 object-cover rounded-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Why choose Broker Lenders for your USDA loan -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-stretch">
        <!-- Left: Image -->
        <div class="h-full">
          <img 
            src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=rural%20home%20buyers%20meeting%20with%20mortgage%20advisor%2C%20modern%20office%2C%20smiling%2C%20documents%20on%20table%2C%20bright%20natural%20light%2C%20professional%20photography&image_size=landscape_4_3" 
            alt="Rural homebuyers with mortgage advisor" 
            class="w-full h-full object-cover rounded-2xl"
          />
        </div>
        
        <!-- Right: Content -->
        <div class="flex flex-col justify-center h-full">
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Why choose Broker Lenders for your USDA loan?</h2>
           
           <div class="space-y-6 mb-8">
             <div class="flex items-start space-x-4">
               <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                 <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                   <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                 </svg>
               </div>
               <div>
                 <h3 class="font-semibold text-gray-900">Rural property expertise</h3>
                 <p class="text-gray-600">We understand USDA eligibility requirements and can help identify qualifying rural properties.</p>
               </div>
             </div>
             
             <div class="flex items-start space-x-4">
               <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                 <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                   <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                 </svg>
               </div>
               <div>
                 <h3 class="font-semibold text-gray-900">Zero down payment specialists</h3>
                 <p class="text-gray-600">We help you take advantage of USDA's 100% financing option with no down payment required.</p>
               </div>
             </div>
             
             <div class="flex items-start space-x-4">
               <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                 <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                   <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                 </svg>
               </div>
               <div>
                 <h3 class="font-semibold text-gray-900">Competitive rural loan rates</h3>
                 <p class="text-gray-600">Access to multiple lenders ensuring you get the best USDA loan rates available for rural properties.</p>
               </div>
             </div>
           </div>
           
            <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-black text-white hover:bg-red-600 hover:text-white px-6 py-3 rounded-[48px] font-semibold transition-colors w-fit">
               Get started
             </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Answers when you need them. Real people when it matters. -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
        <!-- Left side - Content -->
        <div class="bg-gray-100 p-8 lg:p-12 rounded-2xl flex flex-col justify-center">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            Answers when you need them.
          </h2>
          <h3 class="text-xl font-semibold text-gray-700 mb-6">
            Real people when it matters.
          </h3>
          <p class="text-gray-600 mb-8">
            Talk to a USDA loan specialist about rural eligibility, property requirements, and income limits.
          </p>
          <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center justify-center w-fit">
            Get started
          </a>
        </div>
        
        <!-- Right side - Image -->
        <div>
          <img 
            src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=rural%20home%2C%20farmhouse%20style%2C%20countryside%20setting%2C%20professional%20photography%2C%20warm%20lighting&image_size=landscape_4_3" 
            alt="Rural home" 
            class="w-full h-96 object-cover rounded-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Ways Help Section (replaces Estimate and explore) -->
  <WaysHelp />

  <!-- FAQ Section -->
  <FAQSectionUSDA />

  <!-- Contact Section (replaces Don't wonder...) -->
  <Contact />

  <!-- Final CTA -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">
        Achieve your rural homeownership dreams with a USDA loan
      </h2>
      <div class="flex items-center justify-center gap-4">
        <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center justify-center">
          Get started
        </a>
        <a href="tel:8013070273" class="bg-white text-black border border-black px-6 py-3 rounded-[48px] font-semibold transition-colors inline-flex items-center justify-center hover:bg-black hover:text-white">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (801) 307-0273
        </a>
      </div>
    </div>
  </section>

  <!-- Legal disclaimer -->
  <ImportantLegal />

</Layout>