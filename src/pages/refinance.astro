---
import Layout from '../layouts/Layout.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import ImportantLegal from '../components/ImportantLegal.astro';
import NextMoveSection from '../components/NextMoveSection.astro';
import WaysHelp from '../components/WaysHelp.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="Refinance Your Home - Broker Lenders">
	<!-- Hero Section -->
	<section class="bg-white py-12 lg:py-20">
		<div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-stretch">
				<!-- Left side - Content -->
				<div class="order-2 lg:order-1 flex">
					<div class="bg-gray-50 p-8 rounded-[48px] flex flex-col justify-center w-full min-h-[500px]">
						<h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold text-gray-900 mb-6">
							Refinance today and unlock new possibilities
						</h1>
						<p class="text-lg text-gray-600 mb-8">
							Lower your rate, reduce your payment, or tap into your home's equity. We'll help you find the right refinance option for your goals.
						</p>
						<div class="flex flex-col sm:flex-row gap-4">
							<a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors">
								Apply for a refinance
							</a>
                            <a href="/rates" class="border-2 border-black text-gray-900 px-8 py-3 rounded-[48px] font-semibold hover:bg-gray-50 hover:border-red-600 transition-colors">
                                See my options
                            </a>
						</div>
					</div>
				</div>
				
				<!-- Right side - Image -->
				<div class="order-1 lg:order-2 flex">
					<div class="relative w-full min-h-[500px]">
						<img 
							src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=happy%20african%20american%20man%20taking%20selfie%20at%20home%2C%20smiling%2C%20modern%20interior%2C%20natural%20lighting%2C%20professional%20photography&image_size=landscape_4_3" 
							alt="Happy man taking selfie at home" 
							class="w-full h-full object-cover rounded-2xl"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- NextMoveSection Component -->
	<NextMoveSection />

	<!-- Get a fresh start section -->
	<section class="py-18 bg-white">
		<div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">Your new start begins now.</h2>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- Card 1 -->
				<a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="bg-gray-50 p-8 rounded-[48px] text-center flex flex-col h-full transition-all cursor-pointer block border-2 border-transparent hover:border-gray-300 hover:scale-105">
					<h3 class="text-xl font-bold text-gray-900 mb-4">Start now</h3>
					<p class="text-gray-600 mb-6 flex-grow">Tap into your home's equity for home improvements, debt consolidation, or other financial goals.</p>
					<div class="flex justify-center mt-auto">
						<div class="w-12 h-12 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors group border border-gray-200">
							<svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</div>
					</div>
				</a>

				<!-- Card 2 -->
				<a href="/calculators/refinance-calculator" class="bg-gray-50 p-8 rounded-[48px] text-center flex flex-col h-full transition-all cursor-pointer block border-2 border-transparent hover:border-gray-300 hover:scale-105">
					<h3 class="text-xl font-bold text-gray-900 mb-4">Start saving</h3>
					<p class="text-gray-600 mb-6 flex-grow">Reduce your monthly mortgage payment by securing a lower interest rate or extending your loan term.</p>
					<div class="flex justify-center mt-auto">
						<div class="w-12 h-12 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors group border border-gray-200">
							<svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</div>
					</div>
				</a>

				<!-- Card 3 -->
				<a href="/calculators" class="bg-gray-50 p-8 rounded-[48px] text-center flex flex-col h-full transition-all cursor-pointer block border-2 border-transparent hover:border-gray-300 hover:scale-105">
					<h3 class="text-xl font-bold text-gray-900 mb-4">Find my home budget</h3>
					<p class="text-gray-600 mb-6 flex-grow">Use our calculator to see how much you could save with a refinance based on current rates.</p>
					<div class="flex justify-center mt-auto">
						<div class="w-12 h-12 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors group border border-gray-200">
							<svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</div>
					</div>
				</a>
			</div>
		</div>
	</section>

	<!-- A refi journey that's simple -->
	<section class="py-18 bg-white">
		<div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
				<!-- Left side - Content -->
				<div class="flex">
					<div class="p-8 flex flex-col justify-between w-full min-h-[500px]">
						<div>
							<h2 class="text-3xl font-bold text-gray-900 mb-12">Start smart, buy confidently</h2>
							
							<div class="space-y-10">
								<!-- Step 1 -->
								<div class="flex items-start">
									<div class="w-8 h-8 bg-black rounded-full flex items-center justify-center mr-4 mt-1 flex-shrink-0">
										<span class="text-white text-sm font-semibold">1</span>
									</div>
									<div>
										<h3 class="font-semibold text-gray-900 mb-2">Start your refi in 5 min</h3>
										<p class="text-gray-600">Get pre-qualified with a soft credit check that won't affect your score.</p>
									</div>
								</div>
								
								<!-- Step 2 -->
								<div class="flex items-start">
									<div class="w-8 h-8 bg-black rounded-full flex items-center justify-center mr-4 mt-1 flex-shrink-0">
										<span class="text-white text-sm font-semibold">2</span>
									</div>
									<div>
										<h3 class="font-semibold text-gray-900 mb-2">Apply in less than 10 minutes</h3>
										<p class="text-gray-600">Complete your full application online with our streamlined process.</p>
									</div>
								</div>
								
								<!-- Step 3 -->
								<div class="flex items-start">
									<div class="w-8 h-8 bg-black rounded-full flex items-center justify-center mr-4 mt-1 flex-shrink-0">
										<span class="text-white text-sm font-semibold">3</span>
									</div>
									<div>
										<h3 class="font-semibold text-gray-900 mb-2">Get approved and close fast</h3>
										<p class="text-gray-600">Our team works quickly to get you approved and closed in as little as 14 days.</p>
									</div>
								</div>
							</div>
						</div>
						
						<div class="mt-12">
							<a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-block">
								I'm ready
							</a>
						</div>
					</div>
				</div>
				
				<!-- Right side - Image -->
				<div class="flex">
					<div class="relative w-full min-h-[500px]">
						<img 
							src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=happy%20family%20with%20baby%20at%20home%2C%20modern%20interior%2C%20natural%20lighting%2C%20professional%20photography&image_size=landscape_4_3" 
							alt="Happy family with baby at home" 
							class="w-full h-full object-cover rounded-2xl"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- WaysHelp Component -->
	<WaysHelp />

	<!-- TestimonialsSection Component -->
	<TestimonialsSection />

	<!-- Contact Component -->
	<Contact />

	<!-- More refinance options than ever -->
	<section class="py-18 bg-white">
		<div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold text-gray-900 mb-4">More refinance options than ever</h2>
				<p class="text-gray-600 text-lg max-w-3xl mx-auto">
					Whether you want to lower your rate, reduce your payment, or access your home's equity, we have refinance solutions tailored to your needs.
				</p>
			</div>
			<div class="flex justify-center items-center gap-4">
              <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="bg-black text-white px-8 h-12 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center justify-center align-middle">
                Get started
              </a>
			  <a href="tel:+1-801-307-0273" class="bg-white text-black px-8 h-12 rounded-[48px] font-semibold border-2 border-black hover:bg-gray-100 hover:border-red-600 transition-colors inline-flex items-center justify-center align-middle">
			    <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
			    </svg>
			    (801) 307-0273
			  </a>
			</div>
		</div>
	</section>

	<!-- Important Legal -->
	<ImportantLegal />
</Layout>