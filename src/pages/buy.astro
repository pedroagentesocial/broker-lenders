---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
import { ensureLangInUrl } from '../utils/langHandler.js';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import ImportantLegal from '../components/ImportantLegal.astro';
import RewardsCard from '../components/RewardsCard.astro';
import WaysHelp from '../components/WaysHelp.astro';
import Contact from '../components/Contact.astro';
import IdahoImg from '../assets/Idaho.jpg';
import ColoradoImg from '../assets/Colorado.jpg';
import FloridaImg from '../assets/Florida.jpg';
import TexasImg from '../assets/Texas.jpg';
import NevadaImg from '../assets/Nevada.jpg';

// Prerender estático: el cliente resuelve idioma
const lang = 'en';

// SSR debug: show how language is resolved
console.log('[i18n][buy][SSR] resolve', {
  href: Astro.url.href,
  param: Astro.url.searchParams.get('lang'),
  resolvedLang: lang,
});

// Load translations via static imports to ensure reliability
const dicts = {
  en: (await import('../translations/buy/en.json')).default,
  es: (await import('../translations/buy/es.json')).default,
};
const translations = dicts.en;

// SSR debug: show which dict loaded and sample keys
try {
  console.log('[i18n][buy][SSR] dict loaded', {
    lang,
    title: translations.title,
    heroTitle: translations.hero?.title,
    heroSubtitle: translations.hero?.subtitle,
    ctaPrimary: translations.hero?.ctaPrimary,
  });
} catch (e) {
  console.warn('[i18n][buy][SSR] dict log error', e);
}

const images = [
  { src: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1200&h=800&fit=crop", label: "Utah", alt: "Delicate Arch en Utah" },
  { src: IdahoImg.src, label: "Idaho", alt: "Sawtooth Mountains en Idaho" },
  { src: NevadaImg.src, label: "Nevada", alt: "Nevada landscape" },
  { src: "https://images.unsplash.com/photo-1501594907352-04cda38ebc29?w=1200&h=800&fit=crop", label: "California", alt: "Golden Gate Bridge en California" },
  { src: TexasImg.src, label: "Texas", alt: "El Álamo en Texas" },
  { src: FloridaImg.src, label: "Florida", alt: "Miami Beach en Florida" },
  { src: ColoradoImg.src, label: "Colorado", alt: "Rocky Mountains en Colorado" }
];

// Inline payload for client-side i18n
const enB64 = Buffer.from(JSON.stringify(dicts.en)).toString('base64');
const esB64 = Buffer.from(JSON.stringify(dicts.es)).toString('base64');
---

<Layout title={translations.title} lang={lang}>
  <!-- Inline i18n payload for Buy page -->
  <div id="i18n-buy" data-en={enB64} data-es={esB64} style="display:none"></div>
  <script is:inline>
    (() => {
      const root = document.getElementById('i18n-buy');
      const decode = (val) => {
        try {
          const b64 = val || '';
          const bin = atob(b64);
          const bytes = new Uint8Array(bin.length);
          for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
          const jsonText = new TextDecoder('utf-8').decode(bytes);
          return JSON.parse(jsonText);
        } catch { return {}; }
      };
      const translations = {
        en: decode(root?.getAttribute('data-en') || ''),
        es: decode(root?.getAttribute('data-es') || ''),
      };
      const getInitialLang = () => {
        const urlLang = new URLSearchParams(window.location.search).get('lang');
        const stored = localStorage.getItem('lang');
        // Prefer cookie (SSR source) over localStorage to avoid English fallback
        let cookieLang = null;
        try {
          const m = document.cookie.match(/(?:^|;\s*)lang=([^;]+)/);
          cookieLang = m && m[1] ? m[1].toLowerCase() : null;
        } catch {}
        const raw = (urlLang || cookieLang || stored || 'en').toLowerCase();
        return raw === 'es' ? 'es' : 'en';
      };
      const preserveLangOnLinks = (lang) => {
        const ids = ['#hero-cta-secondary', '#card-rates-link', '#card-budget-link', '#smarter-cta', '#final-cta-secondary'];
        ids.forEach(selector => {
          const a = document.querySelector(selector);
          if (!a) return;
          try {
            const href = new URL(a.href, window.location.origin);
            if (href.origin === window.location.origin) {
              href.searchParams.set('lang', lang);
              a.href = href.pathname + href.search + href.hash;
            }
          } catch {}
        });
        // External apply link also keeps lang
        const extIds = ['#hero-cta-primary', '#card-ready-link', '#final-cta-primary'];
        extIds.forEach(selector => {
          const a = document.querySelector(selector);
          if (!a) return;
          try {
            const href = new URL(a.href, window.location.origin);
            href.searchParams.set('lang', lang);
            a.href = href.toString();
          } catch {
            // Fallback for non-absolute external hrefs
            const url = new URL(a.href, window.location.href);
            url.searchParams.set('lang', lang);
            a.href = url.toString();
          }
        });
      };
      const applyTranslations = (lang) => {
        const dict = translations[lang] || translations.en;
        // Document title
        if (dict?.title) document.title = dict.title;
        // Hero
        const h1 = document.getElementById('hero-titleblock');
        if (h1 && dict.hero?.title && dict.hero?.subtitle) {
          h1.innerHTML = `${dict.hero.title}<br>${dict.hero.subtitle}`;
        }
        const desc = document.getElementById('hero-desc');
        if (desc && dict.hero?.description) desc.textContent = dict.hero.description;
        const ctaPrimary = document.getElementById('hero-cta-primary');
        if (ctaPrimary && dict.hero?.ctaPrimary) {
          ctaPrimary.textContent = dict.hero.ctaPrimary;
          ctaPrimary.setAttribute('href', `https://pedrolira.my1003app.com/318973/register?lang=${lang}`);
        }
        const ctaSecondary = document.getElementById('hero-cta-secondary');
        if (ctaSecondary && dict.hero?.ctaSecondary) {
          ctaSecondary.textContent = dict.hero.ctaSecondary;
        }
        // Cards
        const cardReadyTitle = document.getElementById('card-ready-title');
        const cardReadyDesc = document.getElementById('card-ready-desc');
        if (cardReadyTitle && dict.cards?.readyToOwn?.title) cardReadyTitle.textContent = dict.cards.readyToOwn.title;
        if (cardReadyDesc && dict.cards?.readyToOwn?.description) cardReadyDesc.textContent = dict.cards.readyToOwn.description;
        const cardRatesTitle = document.getElementById('card-rates-title');
        const cardRatesDesc = document.getElementById('card-rates-desc');
        if (cardRatesTitle && dict.cards?.exploreRates?.title) cardRatesTitle.textContent = dict.cards.exploreRates.title;
        if (cardRatesDesc && dict.cards?.exploreRates?.description) cardRatesDesc.textContent = dict.cards.exploreRates.description;
        const cardBudgetTitle = document.getElementById('card-budget-title');
        const cardBudgetDesc = document.getElementById('card-budget-desc');
        if (cardBudgetTitle && dict.cards?.buildBudget?.title) cardBudgetTitle.textContent = dict.cards.buildBudget.title;
        if (cardBudgetDesc && dict.cards?.buildBudget?.description) cardBudgetDesc.textContent = dict.cards.buildBudget.description;
        // Smarter savings
        const smarterTitleBlock = document.getElementById('smarter-titleblock');
        const smarterDesc = document.getElementById('smarter-desc');
        const smarterCta = document.getElementById('smarter-cta');
        if (smarterTitleBlock && dict.smarterSavings?.title && dict.smarterSavings?.subtitle) {
          smarterTitleBlock.innerHTML = `${dict.smarterSavings.title}<br>${dict.smarterSavings.subtitle}`;
        }
        if (smarterDesc && dict.smarterSavings?.description) smarterDesc.textContent = dict.smarterSavings.description;
        if (smarterCta && dict.smarterSavings?.cta) smarterCta.textContent = dict.smarterSavings.cta;
        // Final CTA
        const finalTitleBlock = document.getElementById('final-titleblock');
        const finalCtaPrimary = document.getElementById('final-cta-primary');
        const finalCtaSecondary = document.getElementById('final-cta-secondary');
        if (finalTitleBlock && dict.finalCta?.title && dict.finalCta?.subtitle) {
          finalTitleBlock.innerHTML = `${dict.finalCta.title}<br>${dict.finalCta.subtitle}`;
        }
        if (finalCtaPrimary && dict.finalCta?.ctaPrimary) finalCtaPrimary.textContent = dict.finalCta.ctaPrimary;
        if (finalCtaSecondary && dict.finalCta?.ctaSecondary) finalCtaSecondary.textContent = dict.finalCta.ctaSecondary;
        // Preserve lang on links
        preserveLangOnLinks(lang);
      };
      const setLanguage = (lang) => {
        try {
          const next = (lang === 'es') ? 'es' : 'en';
          // Persist in localStorage
          localStorage.setItem('lang', next);
          // Persist in cookie for SSR
          try { document.cookie = `lang=${next}; path=/; max-age=${60*60*24*365}`; } catch {}
          // Persist in URL query
          const url = new URL(window.location.href);
          url.searchParams.set('lang', next);
          // Use replaceState to avoid full reload but keep URL in sync
          window.history.replaceState({}, '', url.toString());
          applyTranslations(next);
        } catch (e) {
          console.warn('[i18n][buy] setLanguage failed', e);
        }
      };
      // Initialize: persist and apply so child components read consistent lang
      setLanguage(getInitialLang());
      // React to Header language clicks (persist and apply)
      document.addEventListener('click', (e) => {
        const a = (e.target instanceof Element) ? e.target.closest('a[href*="?lang="]') : null;
        if (!a) return;
        let href;
        try { href = new URL(a.href, window.location.origin); } catch { return; }
        const lang = href.searchParams.get('lang');
        if (lang) setLanguage(lang);
      });
      // Respond to storage language changes
      window.addEventListener('storage', (ev) => {
        if (ev.key === 'lang' && ev.newValue) applyTranslations(ev.newValue);
      });
      // Handle back/forward navigation
      window.addEventListener('popstate', () => {
        const urlLang = new URLSearchParams(window.location.search).get('lang');
        let cookieLang = null;
        try {
          const m = document.cookie.match(/(?:^|;\s*)lang=([^;]+)/);
          cookieLang = m && m[1] ? m[1].toLowerCase() : null;
        } catch {}
        const lang = (urlLang || cookieLang || localStorage.getItem('lang') || 'en');
        applyTranslations(lang);
        preserveLangOnLinks(lang);
      });
    })();
  </script>
  	<!-- Hero Section -->
	<section class="relative pb-0 h-[500px]">
		<!-- Background Image -->
		<div class="absolute inset-0">
			<div id="buyHeroCarousel" class="relative w-full h-full">
				{images.map((img, i) => (
					<figure class={`absolute inset-0 transition-opacity duration-700 ${i === 0 ? 'opacity-100' : 'opacity-0'}`} data-index={i}>
						<img src={img.src} alt={img.alt} class="w-full h-full object-cover" onerror="this.src='/HeroBuy.jpg'; this.onerror=null;" />
						<figcaption class="absolute bottom-4 left-4 px-3 py-1 rounded-full bg-black/40 text-white text-xs font-medium backdrop-blur-sm">{img.label}</figcaption>
					</figure>
				))}
			</div>
			<!-- Overlay for text readability -->
			<div class="absolute inset-0 bg-black/30"></div>
			<!-- Dots -->
			<div id="buyHeroCarouselDots" class="absolute bottom-4 right-4 flex gap-2 z-10">
				{images.map((_, i) => (
					<button class={`w-2.5 h-2.5 rounded-full border border-white ${i === 0 ? 'bg-white' : 'bg-white/30'}`} data-dot={i} aria-label={`Slide ${i + 1}`}></button>
				))}
			</div>
		</div>
		
		<!-- Content -->
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-center justify-center">
			<div class="max-w-2xl bg-black/30 rounded-[48px] p-8 lg:p-12">
				<h1 id="hero-titleblock" class="text-4xl lg:text-5xl font-bold text-white mb-6">
					{translations.hero.title}<br>
					{translations.hero.subtitle}
				</h1>
				<p id="hero-desc" class="text-lg text-gray-200 mb-8">
					{translations.hero.description}
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
                    <a id="hero-cta-primary" href={`https://pedrolira.my1003app.com/318973/register?lang=${lang}`} target="_blank" class="bg-white text-black px-8 py-3 rounded-[48px] font-semibold hover:bg-gray-100 transition-colors inline-block">
                        {translations.hero.ctaPrimary}
                    </a>
                    <a id="hero-cta-secondary" href={`/rates?lang=${lang}`} class="border border-gray-300 text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-white hover:text-black transition-colors inline-block">
                        {translations.hero.ctaSecondary}
                    </a>
				</div>
			</div>
		</div>
</section>

<script is:inline>
  const slides = Array.from(document.querySelectorAll('#buyHeroCarousel figure'));
  const dots = Array.from(document.querySelectorAll('#buyHeroCarouselDots button'));
  let current = 0;
  let timer;
  function show(index) {
    slides.forEach((s, i) => {
      s.style.opacity = i === index ? '1' : '0';
      s.style.pointerEvents = i === index ? 'auto' : 'none';
    });
    dots.forEach((d, i) => {
      if (i === index) {
        d.classList.add('bg-white');
        d.classList.remove('bg-white/30');
      } else {
        d.classList.remove('bg-white');
        d.classList.add('bg-white/30');
      }
    });
    current = index;
  }
  function next() { show((current + 1) % slides.length); }
  function start() { stop(); timer = setInterval(next, 4500); }
  function stop() { if (timer) clearInterval(timer); }
  dots.forEach((d, i) => d.addEventListener('click', () => { show(i); start(); }));
  show(0); start();
  const container = document.getElementById('buyHeroCarousel');
  container.addEventListener('mouseenter', stop);
  container.addEventListener('mouseleave', start);
</script>


	<!-- Three Cards Section -->
	<section class="pt-10 pb-18 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- Ready to own your home? -->
                <a id="card-ready-link" href={`https://pedrolira.my1003app.com/318973/register?lang=${lang}`} target="_blank" class="bg-gray-50 p-8 rounded-[48px] text-center flex flex-col h-full transition-all cursor-pointer block border-2 border-transparent hover:border-gray-300 hover:scale-105">
                    <h3 id="card-ready-title" class="text-xl font-bold text-gray-900 mb-4">{translations.cards.readyToOwn.title}</h3>
                    <p id="card-ready-desc" class="text-gray-600 mb-6 flex-grow">{translations.cards.readyToOwn.description}</p>
                    <div class="flex justify-center mt-auto">
						<div class="w-12 h-12 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors group border border-gray-200">
							<svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</div>
					</div>
				</a>

				<!-- Explore your rate options -->
                <a id="card-rates-link" href={`/rates?lang=${lang}`} class="bg-gray-50 p-8 rounded-[48px] text-center flex flex-col h-full transition-all cursor-pointer block border-2 border-transparent hover:border-gray-300 hover:scale-105">
                    <h3 id="card-rates-title" class="text-xl font-bold text-gray-900 mb-4">{translations.cards.exploreRates.title}</h3>
                    <p id="card-rates-desc" class="text-gray-600 mb-6 flex-grow">{translations.cards.exploreRates.description}</p>
                    <div class="flex justify-center mt-auto">
						<div class="w-12 h-12 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors group border border-gray-200">
							<svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</div>
					</div>
				</a>

				<!-- Build your budget -->
                <a id="card-budget-link" href={`/calculators/mortgage-calculator?lang=${lang}`} class="bg-gray-50 p-8 rounded-[48px] text-center flex flex-col h-full transition-all cursor-pointer block border-2 border-transparent hover:border-gray-300 hover:scale-105">
                    <h3 id="card-budget-title" class="text-xl font-bold text-gray-900 mb-4">{translations.cards.buildBudget.title}</h3>
                    <p id="card-budget-desc" class="text-gray-600 mb-6 flex-grow">{translations.cards.buildBudget.description}</p>
                    <div class="flex justify-center mt-auto">
						<div class="w-12 h-12 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors group border border-gray-200">
							<svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</div>
					</div>
				</a>
			</div>
		</div>
	</section>

	<!-- Smarter savings section -->
	<section class="py-18 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="bg-gray-50 rounded-[48px] p-12 lg:p-16">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<!-- Left side - Content -->
					<div>
						<h2 id="smarter-titleblock" class="text-3xl font-bold text-gray-900 mb-6">
							{translations.smarterSavings.title}<br>
							{translations.smarterSavings.subtitle}
						</h2>
						<p id="smarter-desc" class="text-gray-600 mb-8 text-lg">
							{translations.smarterSavings.description}
						</p>
					<div class="mb-8">
						<a id="smarter-cta" href={`/calculators?lang=${lang}`} class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-block">
							{translations.smarterSavings.cta}
						</a>
					</div>
					</div>
					
					<!-- Right side - Image -->
					<div>
						<div class="relative">
							<img 
								src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=modern%20house%20exterior%2C%20beautiful%20home%20with%20landscaping%2C%20professional%20real%20estate%20photography&image_size=landscape_4_3" 
								alt="Beautiful home exterior" 
								class="w-full h-80 object-cover rounded-2xl shadow-lg"
							/>
						</div>
					</div>


					</div>
				</div>
			</div>
		</div>
  </section>

  <!-- Get rewarded section -->
  <RewardsCard />

	<!-- More ways we can help -->
	<WaysHelp />

	<!-- Testimonials Section -->
	<TestimonialsSection />

	<!-- Not sure what's best section -->
	<Contact />

  <!-- Final CTA Section -->
  <section class="py-18 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h2 id="final-titleblock" class="text-3xl font-bold text-gray-900 mb-8">{translations.finalCta.title}<br>{translations.finalCta.subtitle}</h2>
				<div class="flex justify-center gap-4">
                    <a id="final-cta-primary" href={`https://pedrolira.my1003app.com/318973/register?lang=${lang}`} target="_blank" class="bg-black text-white px-8 py-4 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors text-lg inline-block">
                        {translations.finalCta.ctaPrimary}
                    </a>
                    <a id="final-cta-secondary" href={`/rates?lang=${lang}`} class="bg-white text-black border border-black px-8 py-4 rounded-[48px] font-semibold transition-colors text-lg inline-block">
                        {translations.finalCta.ctaSecondary}
                    </a>
				</div>
			</div>
		</div>
  </section>

  <!-- Important Legal Disclosures -->
  <ImportantLegal />
</Layout>