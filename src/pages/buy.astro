---
import Layout from '../layouts/Layout.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import ImportantLegal from '../components/ImportantLegal.astro';
import RewardsCard from '../components/RewardsCard.astro';
import WaysHelp from '../components/WaysHelp.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="Buy a Home - Broker Lenders">
	<!-- Hero Section -->
	<section class="relative pb-0 h-[500px]">
		<!-- Background Image -->
		<div class="absolute inset-0">
			<img 
				src="/HeroBuy.jpg" 
				alt="Happy family at home" 
				class="w-full h-full object-cover"
				style="width: 1920px; height: 660px;"
			/>
			<!-- Overlay for text readability -->
			<!-- <div class="absolute inset-0 bg-black bg-opacity-10"></div> -->
		</div>
		
		<!-- Content -->
		<div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-start pt-32">
			<div class="max-w-2xl bg-black/30 rounded-[48px] p-8 lg:p-12">
				<h1 class="text-4xl lg:text-5xl font-bold text-white mb-6">
					Thinking of buying?<br>
					Let's make it happen
				</h1>
				<p class="text-lg text-gray-200 mb-8">
					From pre-approval to closing, we'll guide you through every step of the home buying process.
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
					<a href="https://pedrolira.my1003app.com/318973/register" target="_blank" class="bg-white text-black px-8 py-3 rounded-[48px] font-semibold hover:bg-gray-100 transition-colors inline-block">
						Find out now
					</a>
					<a href="/rates" class="border border-gray-300 text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-white hover:text-black transition-colors inline-block">
						Find my rate
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Three Cards Section -->
	<section class="pt-[224px] pb-18 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<!-- Ready to own your home? -->
				<a href="https://pedrolira.my1003app.com/318973/register" target="_blank" class="bg-gray-50 p-8 rounded-[48px] text-center flex flex-col h-full transition-all cursor-pointer block border-2 border-transparent hover:border-gray-300 hover:scale-105">
					<h3 class="text-xl font-bold text-gray-900 mb-4">Ready to own your home?</h3>
					<p class="text-gray-600 mb-6 flex-grow">Get pre-approved and start your home buying journey with confidence.</p>
					<div class="flex justify-center mt-auto">
						<div class="w-12 h-12 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors group border border-gray-200">
							<svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</div>
					</div>
				</a>

				<!-- Explore your rate options -->
				<a href="/rates" class="bg-gray-50 p-8 rounded-[48px] text-center flex flex-col h-full transition-all cursor-pointer block border-2 border-transparent hover:border-gray-300 hover:scale-105">
					<h3 class="text-xl font-bold text-gray-900 mb-4">Explore your rate options</h3>
					<p class="text-gray-600 mb-6 flex-grow">Compare rates and find the best loan option for your situation.</p>
					<div class="flex justify-center mt-auto">
						<div class="w-12 h-12 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors group border border-gray-200">
							<svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</div>
					</div>
				</a>

				<!-- Build your budget -->
				<a href="/calculators/mortgage-calculator" class="bg-gray-50 p-8 rounded-[48px] text-center flex flex-col h-full transition-all cursor-pointer block border-2 border-transparent hover:border-gray-300 hover:scale-105">
					<h3 class="text-xl font-bold text-gray-900 mb-4">Build your budget</h3>
					<p class="text-gray-600 mb-6 flex-grow">Use our calculator to determine what you can afford.</p>
					<div class="flex justify-center mt-auto">
						<div class="w-12 h-12 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors group border border-gray-200">
							<svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</div>
					</div>
				</a>
			</div>
		</div>
	</section>

	<!-- Smarter savings section -->
	<section class="py-18 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="bg-gray-50 rounded-[48px] p-12 lg:p-16">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<!-- Left side - Content -->
					<div>
						<h2 class="text-3xl font-bold text-gray-900 mb-6">
							Smarter savings with<br>
							Broker Lenders Preferred Pricing
						</h2>
						<p class="text-gray-600 mb-8 text-lg">
							Get exclusive rates and save thousands on your home purchase with our preferred pricing program.
						</p>
						<div class="mb-8">
							<a href="/calculators" class="bg-black text-white px-8 py-3 rounded-lg font-semibold hover:bg-red-600 hover:text-white transition-colors inline-block">
								Calculate my savings
							</a>
						</div>
					</div>
					
					<!-- Right side - Image -->
					<div>
						<div class="relative">
							<img 
								src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=modern%20house%20exterior%2C%20beautiful%20home%20with%20landscaping%2C%20professional%20real%20estate%20photography&image_size=landscape_4_3" 
								alt="Beautiful home exterior" 
								class="w-full h-80 object-cover rounded-2xl shadow-lg"
							/>
						</div>
					</div>


					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Get rewarded section -->
	<RewardsCard />

	<!-- More ways we can help -->
	<WaysHelp />

	<!-- Testimonials Section -->
	<TestimonialsSection />

	<!-- Not sure what's best section -->
	<Contact />

	<!-- Final CTA Section -->
	<section class="py-18 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h2 class="text-3xl font-bold text-gray-900 mb-8">Thousands have made it home with us.<br>You can too.</h2>
				<div class="flex justify-center gap-4">
					<a href="https://pedrolira.my1003app.com/318973/register" target="_blank" class="bg-black text-white px-8 py-4 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors text-lg inline-block">
						I'm ready to buy
					</a>
					<a href="/rates" class="bg-white text-black border border-black px-8 py-4 rounded-[48px] font-semibold transition-colors text-lg inline-block">
						See today's rates
					</a>
				</div>
			</div>
		</div>
	</section>
	
	<!-- Important Legal Disclosures -->
	<ImportantLegal />
</Layout>