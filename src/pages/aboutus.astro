---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import ImportantLegal from '../components/ImportantLegal.astro';
---

<Layout title="About Us - Broker Lenders">
  <!-- Breadcrumb Section -->
  <div class="bg-white py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm">
        <a href="/" class="text-gray-700 hover:text-gray-900">Home</a>
        <span class="mx-2 text-gray-500">/</span>
        <span class="text-gray-700">About Us</span>
      </nav>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
        <!-- Left side - Content -->
        <div class="flex flex-col justify-center">
          <div class="space-y-6">
            <h1 class="text-4xl lg:text-5xl font-bold text-gray-900">
              About Broker Lenders
            </h1>
            <p class="text-lg text-gray-600">
              We're dedicated to making homeownership accessible and affordable for everyone. With years of experience in the mortgage industry, we've helped thousands of families achieve their dream of owning a home.
            </p>
            <div class="flex items-center gap-4">
              <a href="tel:8013070273" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                Call (801) 307-0273
              </a>
              <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="bg-white text-black border border-black px-6 py-3 rounded-[48px] font-semibold transition-colors inline-flex items-center justify-center hover:bg-black hover:text-white">
                Get started
              </a>
            </div>
          </div>
        </div>
        
        <!-- Right side - Image -->
        <div>
          <img 
            src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=professional%20mortgage%20team%20in%20modern%20office%2C%20diverse%20group%20of%20people%2C%20smiling%2C%20bright%20natural%20light%2C%20professional%20photography&image_size=landscape_4_3" 
            alt="Broker Lenders Team" 
            class="w-full h-96 object-cover rounded-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Our Mission Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-stretch">
        <!-- Left: Image -->
        <div class="h-full">
          <img 
            src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=happy%20family%20in%20new%20home%2C%20keys%20in%20hand%2C%20celebrating%2C%20bright%20natural%20light%2C%20professional%20photography&image_size=landscape_4_3" 
            alt="Happy family with new home" 
            class="w-full h-full object-cover rounded-2xl"
          />
        </div>
        
        <!-- Right: Content -->
        <div class="flex flex-col justify-center h-full">
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Our Mission</h2>
          <p class="text-gray-600 mb-8">
            At Broker Lenders, our mission is simple: to make the dream of homeownership a reality for everyone. We believe that everyone deserves a place to call home, and we're committed to providing the guidance, support, and financing solutions needed to make that happen.
          </p>
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Accessible Financing</h3>
                <p class="text-gray-600">We work with multiple lenders to find the best rates and terms for your unique situation.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Personalized Service</h3>
                <p class="text-gray-600">Every client gets personalized attention and guidance throughout the entire process.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Expert Guidance</h3>
                <p class="text-gray-600">Our experienced team provides expert advice and clear explanations every step of the way.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Values Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Core Values</h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          These principles guide everything we do and how we serve our clients every day.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-gray-50 p-8 rounded-2xl text-center">
          <div class="w-16 h-16 bg-green-500 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Integrity</h3>
          <p class="text-gray-600">We believe in honest, transparent communication and always act in our clients' best interests.</p>
        </div>
        
        <div class="bg-gray-50 p-8 rounded-2xl text-center">
          <div class="w-16 h-16 bg-green-500 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Excellence</h3>
          <p class="text-gray-600">We strive for excellence in everything we do, from customer service to finding the best loan solutions.</p>
        </div>
        
        <div class="bg-gray-50 p-8 rounded-2xl text-center">
          <div class="w-16 h-16 bg-green-500 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Community</h3>
          <p class="text-gray-600">We're committed to building strong communities by helping families achieve homeownership.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-stretch">
        <!-- Left: Content -->
        <div class="flex flex-col justify-center">
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Why Homeowners Choose Broker Lenders</h2>
          <p class="text-gray-600 mb-8">
            With thousands of successful closings and countless satisfied clients, we've built a reputation for excellence in mortgage lending. Our commitment to personalized service and competitive rates sets us apart.
          </p>
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Experienced Team</h3>
                <p class="text-gray-600">Our licensed professionals have decades of combined experience in mortgage lending.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Multiple Lender Options</h3>
                <p class="text-gray-600">We work with numerous lenders to find the best rates and terms for your situation.</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Fast, Efficient Process</h3>
                <p class="text-gray-600">Our streamlined process helps you close on your home quickly and efficiently.</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Right: Image -->
        <div class="h-full">
          <img 
            src="https://trae-api-us.mchost.guru/api/ide/v1/text_to_image?prompt=mortgage%20professional%20helping%20happy%20couple%2C%20modern%20office%2C%20smiling%2C%20documents%20on%20table%2C%20bright%20natural%20light%2C%20professional%20photography&image_size=landscape_4_3" 
            alt="Mortgage professional helping couple" 
            class="w-full h-full object-cover rounded-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <TestimonialsSection />

  <!-- Contact Section -->
  <Contact />

  <!-- Final CTA -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">
        Ready to work with a team that puts you first?
      </h2>
      <div class="flex items-center justify-center gap-4">
        <a href="https://pedrolira.my1003app.com/318973/register" target="_blank" rel="noopener noreferrer" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center justify-center">
          Get started
        </a>
        <a href="tel:8013070273" class="bg-white text-black border border-black px-6 py-3 rounded-[48px] font-semibold transition-colors inline-flex items-center justify-center hover:bg-black hover:text-white">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (801) 307-0273
        </a>
      </div>
    </div>
  </section>

  

  <!-- Legal disclaimer -->
  <ImportantLegal />

</Layout>