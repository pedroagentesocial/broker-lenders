---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import WaysHelp from '../components/WaysHelp.astro';
import ImportantLegal from '../components/ImportantLegal.astro';
---

<Layout title="Contact Us - Broker Lenders">
  <!-- Breadcrumb Section -->
  <div class="bg-white py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm">
        <a href="/" class="text-gray-700 hover:text-gray-900">Home</a>
        <span class="mx-2 text-gray-500">/</span>
        <span class="text-gray-700">Contact Us</span>
      </nav>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
        Contact Us
      </h1>
      <p class="text-lg text-gray-600 mb-8 max-w-3xl mx-auto">
        We're here to help you with all your mortgage needs. Get in touch with our experienced team today.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href="tel:8013070273" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center justify-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (801) 307-0273
        </a>
        <a id="heroSendBtn" href="#contact-form" class="bg-white text-black border border-black px-8 py-3 rounded-[48px] font-semibold hover:bg-black hover:text-white transition-colors inline-flex items-center justify-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Send Message
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Information Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Get in Touch</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          We offer multiple ways to reach us. Choose the method that's most convenient for you.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <!-- Phone Contact -->
        <div class="text-center p-6 bg-white rounded-lg border border-gray-200">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Call Us</h3>
          <p class="text-gray-600 mb-4">Speak with our mortgage experts directly</p>
          <a href="tel:8013070273" class="text-black hover:text-red-600 font-semibold text-lg">
            (801) 307-0273
          </a>
          <p class="text-sm text-gray-500 mt-2">Mon-Fri: 8AM-6PM MST</p>
        </div>

        <!-- Email Contact -->
        <div class="text-center p-6 bg-white rounded-lg border border-gray-200">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Email Us</h3>
          <p class="text-gray-600 mb-4">Send us your questions anytime</p>
          <a href="mailto:info@brokerlenders.com" class="text-black hover:text-red-600 font-semibold">
            info@brokerlenders.com
          </a>
          <p class="text-sm text-gray-500 mt-2">Response within 24 hours</p>
        </div>

        <!-- Office Location -->
        <div class="text-center p-6 bg-white rounded-lg border border-gray-200">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Visit Us</h3>
          <p class="text-gray-600 mb-4">Our office in Cottonwood Heights</p>
          <p class="text-gray-700 font-semibold">
            1515 East Fort Union Blvd<br>
            Cottonwood Heights, UT 84121
          </p>
          <p class="text-sm text-gray-500 mt-2">By appointment only</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section id="contact-form" class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Send Us a Message</h2>
        <p class="text-lg text-gray-600">
          Fill out the form below and we'll get back to you as soon as possible.
        </p>
      </div>

      <div class="bg-gray-50 rounded-2xl p-8">
        <form id="contactForm" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" data-webhook="https://hook.us1.make.com/yd95nje3piy9cyvq216re54x34uuh2ok" data-formsubmit-email="support@agentesocial.com">
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Don't fill this out if you're human: <input name="bot-field" /></label>
          </p>

          <!-- Hidden UTM fields for marketing attribution -->
          <input type="hidden" name="utm_source" />
          <input type="hidden" name="utm_campaign" />
          <input type="hidden" name="utm_medium" />
          <input type="hidden" name="utm_content" />
          <input type="hidden" name="utm_term" />

          <!-- Hidden extra analytics fields -->
          <input type="hidden" name="referrer" />
          <input type="hidden" name="landing_page" />
          <input type="hidden" name="submit_timestamp" />
          <input type="hidden" name="user_agent" />
          <input type="hidden" name="ip_address" />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
              <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">
                First Name *
              </label>
              <input type="text" id="firstName" name="firstName" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
            </div>
            <div>
              <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">
                Last Name *
              </label>
              <input type="text" id="lastName" name="lastName" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
            </div>
          </div>

          <div class="mb-6">
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              Email Address *
            </label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
          </div>

          <div class="mb-6">
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
              Phone Number
            </label>
            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
          </div>

          <div class="mb-6">
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">
              Subject *
            </label>
            <select id="subject" name="subject" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
              <option value="">Select a subject</option>
              <option value="general">General Inquiry</option>
              <option value="mortgage">Mortgage Questions</option>
              <option value="refinance">Refinancing</option>
              <option value="rates">Rate Information</option>
              <option value="application">Application Status</option>
              <option value="support">Technical Support</option>
            </select>
          </div>

          <div class="mb-6">
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
              Message *
            </label>
            <textarea id="message" name="message" rows="6" required placeholder="Please tell us how we can help you..." class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors resize-vertical"></textarea>
          </div>

          <div class="text-center flex flex-col items-center relative" id="submitContainer">
            <button id="submitBtn" type="submit" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
              Send Message
            </button>
            <div id="submitSuccess" class="hidden inline-flex items-center justify-center bg-green-100 text-green-800 px-4 py-3 rounded-[48px] font-semibold" style="display:none" aria-hidden="true">
              <svg class="w-5 h-5 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Datos enviados correctamente
            </div>
            <div id="submitError" class="hidden inline-flex items-center justify-center bg-red-100 text-red-800 px-4 py-3 rounded-[48px] font-semibold" style="display:none" aria-hidden="true">
              <svg class="w-5 h-5 mr-2 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              Error al enviar. Intenta nuevamente.
            </div>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Contact Component -->
  <Contact />
  
  <!-- Ways Help Component -->
  <WaysHelp />
  
  <!-- Important Legal Disclosures -->
  <ImportantLegal />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm');
    const submitBtn = document.getElementById('submitBtn');
    const successEl = document.getElementById('submitSuccess');
    const errorEl = document.getElementById('submitError');
    const submitContainer = document.getElementById('submitContainer');
    const heroBtn = document.getElementById('heroSendBtn');

    // Animations helpers
    function showAnimated(el) {
      if (!el) return;
      // Ensure element is displayed and visible
      el.style.display = 'inline-flex';
      el.classList.remove('hidden');
      el.classList.add('fade-in');
      el.classList.add('slide-in-up');
      el.addEventListener('animationend', () => {
        el.classList.remove('fade-in');
        el.classList.remove('slide-in-up');
      }, { once: true });
    }

    function hideButtonAnimated(btn) {
      if (!btn) return;
      btn.classList.add('fade-out');
      btn.addEventListener('animationend', () => {
        btn.classList.add('hidden');
        btn.classList.remove('fade-out');
      }, { once: true });
    }

    // Populate hidden UTM inputs from current URL query params
    (function populateUTM() {
      if (!form) return;
      const params = new URLSearchParams(window.location.search || '');
      const utmFields = ['utm_source', 'utm_campaign', 'utm_medium', 'utm_content', 'utm_term'];
      utmFields.forEach((name) => {
        const input = form.querySelector(`input[name="${name}"]`);
        if (input) {
          input.value = params.get(name) || '';
        }
      });
    })();

    // Populate extra analytics fields
    (async function populateExtra() {
      if (!form) return;
      const refInput = form.querySelector('input[name="referrer"]');
      const landInput = form.querySelector('input[name="landing_page"]');
      const uaInput = form.querySelector('input[name="user_agent"]');
      const ipInput = form.querySelector('input[name="ip_address"]');

      try {
        // Referrer
        if (refInput) refInput.value = document.referrer || '';
        // Landing page: first page in session
        const existingLanding = sessionStorage.getItem('landing_page');
        if (!existingLanding) {
          sessionStorage.setItem('landing_page', window.location.href);
        }
        if (landInput) landInput.value = sessionStorage.getItem('landing_page') || window.location.href;
        // User agent
        if (uaInput) uaInput.value = navigator.userAgent || '';
        // IP address (best-effort)
        try {
          const res = await fetch('https://api.ipify.org?format=json');
          const data = await res.json();
          if (ipInput) ipInput.value = data.ip || '';
        } catch (ipErr) {
          console.warn('No se pudo obtener IP:', ipErr);
        }
      } catch (err) {
        console.warn('Error poblando campos extra:', err);
      }
    })();

    async function sendWebhook(url, payload) {
      if (!url) return;
      await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
    }

    async function sendFormSubmit(email, payload) {
      if (!email) return;
      await fetch(`https://formsubmit.co/ajax/${encodeURIComponent(email)}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(payload)
      });
    }

    // Hero button: open mailto including UTM params and scroll to form
    heroBtn?.addEventListener('click', (evt) => {
      evt.preventDefault();
      const formSection = document.getElementById('contact-form');
      formSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });

      const email = 'info@brokerlenders.com';
      const subject = encodeURIComponent('Contact Request from website');

      // Read current UTM params from URL
      const params = new URLSearchParams(window.location.search || '');
      const utm_source = params.get('utm_source') || '';
      const utm_campaign = params.get('utm_campaign') || '';
      const utm_medium = params.get('utm_medium') || '';
      const utm_content = params.get('utm_content') || '';
      const utm_term = params.get('utm_term') || '';

      // Compose a readable body including UTM attribution
      const bodyText = `Hello Broker Lenders,\n\nI would like to get in touch.\n\nUTM Attribution:\n- Source: ${utm_source || '(none)'}\n- Campaign: ${utm_campaign || '(none)'}\n- Medium: ${utm_medium || '(none)'}\n- Content: ${utm_content || '(none)'}\n- Term: ${utm_term || '(none)'}\n\nThanks.`;
      const body = encodeURIComponent(bodyText);

      // Open default mail client
      window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Ocultar botón con animación
      hideButtonAnimated(submitBtn);
      // Reset messages before a new attempt
      errorEl?.classList.add('hidden');
      successEl?.classList.add('hidden');
      if (errorEl) errorEl.style.display = 'none';
      if (successEl) successEl.style.display = 'none';

      // Recolectar datos del formulario
      const fd = new FormData(form);
      // Timestamp del envío (ISO)
      const tsInput = form.querySelector('input[name="submit_timestamp"]');
      if (tsInput) tsInput.value = new Date().toISOString();
      // Reconstruir con timestamp
      const fdWithTs = new FormData(form);
      const payload = {};
      fdWithTs.forEach((value, key) => { payload[key] = value; });

      const webhookUrl = form.dataset.webhook || '';
      const formSubmitEmail = form.dataset.formsubmitEmail || '';

      try {
        await Promise.all([
          sendWebhook(webhookUrl, payload),
          sendFormSubmit(formSubmitEmail, payload)
        ]);
        // Mostrar mensaje éxito con animación
        // Ocultar mensaje de error si estuviera visible
        errorEl?.classList.add('hidden');
        if (errorEl) errorEl.style.display = 'none';
        showAnimated(successEl);
        // Auto-ocultar éxito y restaurar el botón tras 3.5s
        setTimeout(() => {
          // Ocultar éxito
          successEl?.classList.add('hidden');
          if (successEl) successEl.style.display = 'none';
          // Reaparecer botón con animación
          submitBtn?.classList.remove('hidden');
          submitBtn?.classList.add('fade-in');
          submitBtn?.classList.add('slide-in-up');
          submitBtn?.addEventListener('animationend', () => {
            submitBtn?.classList.remove('fade-in');
            submitBtn?.classList.remove('slide-in-up');
          }, { once: true });
        }, 3500);
      } catch (err) {
        console.warn('Error enviando el formulario:', err);
        // Ocultar mensaje de éxito si estuviera visible
        successEl?.classList.add('hidden');
        if (successEl) successEl.style.display = 'none';
        showAnimated(errorEl);
        // Reaparecer botón y auto-ocultar error después de unos segundos
        setTimeout(() => {
          submitBtn?.classList.remove('hidden');
          submitBtn?.classList.add('fade-in');
          submitBtn?.classList.add('slide-in-up');
          submitBtn?.addEventListener('animationend', () => {
            submitBtn?.classList.remove('fade-in');
            submitBtn?.classList.remove('slide-in-up');
          }, { once: true });
          errorEl?.classList.add('hidden');
          if (errorEl) errorEl.style.display = 'none';
        }, 4500);
      }
    });
  });
</script>

<style>
  /* Smooth, subtle animations */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }
  @keyframes slideInUp {
    from { transform: translateY(8px); }
    to { transform: translateY(0); }
  }
  .fade-in { animation: fadeIn 220ms ease-out forwards; }
  .fade-out { animation: fadeOut 180ms ease-in forwards; }
  .slide-in-up { animation: slideInUp 220ms ease-out forwards; }
</style>
