---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import WaysHelp from '../components/WaysHelp.astro';
import ImportantLegal from '../components/ImportantLegal.astro';
---


<Layout title="Contact Us - Broker Lenders">
  <!-- Breadcrumb Section -->
  <div class="bg-white py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm">
        <a href="/" class="text-gray-700 hover:text-gray-900" data-i18n="breadcrumb.home">Home</a>
        <span class="mx-2 text-gray-500">/</span>
        <span class="text-gray-700" data-i18n="breadcrumb.contact">Contact Us</span>
      </nav>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6" data-i18n="hero.title">
        Contact Us
      </h1>
      <p class="text-lg text-gray-600 mb-8 max-w-3xl mx-auto" data-i18n="hero.description">
        We're here to help you with all your mortgage needs. Get in touch with our experienced team today.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href="tel:8013070273" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center justify-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span data-i18n="hero.cta.callFull">Call (801) 307-0273</span>
        </a>
        <a id="heroSendBtn" href="#contact-form" class="bg-white text-black border border-black px-8 py-3 rounded-[48px] font-semibold hover:bg-black hover:text-white transition-colors inline-flex items-center justify-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span data-i18n="hero.cta.send">Send Message</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Information Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4" data-i18n="contact.title">Get in Touch</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto" data-i18n="contact.description">
          We offer multiple ways to reach us. Choose the method that's most convenient for you.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <!-- Phone Contact -->
        <div class="text-center p-6 bg-white rounded-lg border border-gray-200">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2" data-i18n="cards.phone.title">Call Us</h3>
          <p class="text-gray-600 mb-4" data-i18n="cards.phone.desc">Speak with our mortgage experts directly</p>
          <a href="tel:8013070273" class="text-black hover:text-red-600 font-semibold text-lg">
            (801) 307-0273
          </a>
          <p class="text-sm text-gray-500 mt-2" data-i18n="cards.phone.hours">Mon-Fri: 8AM-6PM MST</p>
        </div>

        <!-- Email Contact -->
        <div class="text-center p-6 bg-white rounded-lg border border-gray-200">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2" data-i18n="cards.email.title">Email Us</h3>
          <p class="text-gray-600 mb-4" data-i18n="cards.email.desc">Send us your questions anytime</p>
          <a href="mailto:info@brokerlenders.com" class="text-black hover:text-red-600 font-semibold">
            info@brokerlenders.com
          </a>
          <p class="text-sm text-gray-500 mt-2" data-i18n="cards.email.response">Response within 24 hours</p>
        </div>

        <!-- Office Location -->
        <div class="text-center p-6 bg-white rounded-lg border border-gray-200">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2" data-i18n="cards.visit.title">Visit Us</h3>
          <p class="text-gray-600 mb-4" data-i18n="cards.visit.desc">Our office in Cottonwood Heights</p>
          <p class="text-gray-700 font-semibold">
            1515 East Fort Union Blvd<br>
            Cottonwood Heights, UT 84121
          </p>
          <p class="text-sm text-gray-500 mt-2" data-i18n="cards.visit.hours">By appointment only</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section id="contact-form" class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4" data-i18n="form.title">Send Us a Message</h2>
        <p class="text-lg text-gray-600" data-i18n="form.description">
          Fill out the form below and we'll get back to you as soon as possible.
        </p>
      </div>

      <div class="bg-gray-50 rounded-2xl p-8">
        <form id="contactForm" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" data-webhook="https://hook.us1.make.com/yd95nje3piy9cyvq216re54x34uuh2ok" data-formsubmit-email="support@agentesocial.com">
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Don't fill this out if you're human: <input name="bot-field" /></label>
          </p>

          <!-- Hidden UTM fields for marketing attribution -->
          <input type="hidden" name="utm_source" />
          <input type="hidden" name="utm_campaign" />
          <input type="hidden" name="utm_medium" />
          <input type="hidden" name="utm_content" />
          <input type="hidden" name="utm_term" />

          <!-- Hidden extra analytics fields -->
          <input type="hidden" name="referrer" />
          <input type="hidden" name="landing_page" />
          <input type="hidden" name="submit_timestamp" />
          <input type="hidden" name="user_agent" />
          <input type="hidden" name="ip_address" />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
              <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.labels.firstName">
                First Name *
              </label>
              <input type="text" id="firstName" name="firstName" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
            </div>
            <div>
              <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.labels.lastName">
                Last Name *
              </label>
              <input type="text" id="lastName" name="lastName" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
            </div>
          </div>

          <div class="mb-6">
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.labels.email">
              Email Address *
            </label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
          </div>

          <div class="mb-6">
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.labels.phone">
              Phone Number
            </label>
            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
          </div>

          <div class="mb-6">
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.labels.subject">
              Subject *
            </label>
            <select id="subject" name="subject" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
              <option value="" data-i18n="form.subjectOptions.select">Select a subject</option>
              <option value="general" data-i18n="form.subjectOptions.general">General Inquiry</option>
              <option value="mortgage" data-i18n="form.subjectOptions.mortgage">Mortgage Questions</option>
              <option value="refinance" data-i18n="form.subjectOptions.refinance">Refinancing</option>
              <option value="rates" data-i18n="form.subjectOptions.rates">Rate Information</option>
              <option value="application" data-i18n="form.subjectOptions.application">Application Status</option>
              <option value="support" data-i18n="form.subjectOptions.support">Technical Support</option>
            </select>
          </div>

          <div class="mb-6">
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.labels.message">
              Message *
            </label>
            <textarea id="message" name="message" rows="6" required placeholder="Please tell us how we can help you..." data-i18n-placeholder="form.placeholders.message" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors resize-vertical"></textarea>
          </div>

          <div class="text-center flex flex-col items-center relative" id="submitContainer">
            <button id="submitBtn" type="submit" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
              <span data-i18n="form.submit">Send Message</span>
            </button>
            <div id="submitSuccess" class="hidden inline-flex items-center justify-center bg-green-100 text-green-800 px-4 py-3 rounded-[48px] font-semibold" style="display:none" aria-hidden="true">
              <svg class="w-5 h-5 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span data-i18n="submit.success">Data submitted successfully</span>
            </div>
            <div id="submitError" class="hidden inline-flex items-center justify-center bg-red-100 text-red-800 px-4 py-3 rounded-[48px] font-semibold" style="display:none" aria-hidden="true">
              <svg class="w-5 h-5 mr-2 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span data-i18n="submit.error">Submission failed. Please try again.</span>
            </div>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Contact Component -->
  <Contact />
  
  <!-- Ways Help Component -->
  <WaysHelp />
  
  <!-- Important Legal Disclosures -->
  <ImportantLegal />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- i18n dictionaries (inline, no fetch) ---
    const translations = {
      en: {
        title: 'Contact Us - Broker Lenders',
        breadcrumb: { home: 'Home', contact: 'Contact Us' },
        hero: {
          title: 'Contact Us',
          description: "We're here to help you with all your mortgage needs. Get in touch with our experienced team today.",
          cta: { callFull: 'Call (801) 307-0273', send: 'Send Message' },
          mailtoSubject: 'Contact Request from website',
          mailtoIntro: 'Hello Broker Lenders,\n\nI would like to get in touch.',
          mailtoUtm: 'UTM Attribution',
          mailtoSession: 'Session Context',
          mailtoLabels: { source: 'Source', campaign: 'Campaign', medium: 'Medium', content: 'Content', term: 'Term', landing: 'Landing Page', referrer: 'Referrer' },
        },
        contact: {
          title: 'Get in Touch',
          description: "We offer multiple ways to reach us. Choose the method that's most convenient for you.",
        },
        cards: {
          phone: { title: 'Call Us', desc: 'Speak with our mortgage experts directly', hours: 'Mon-Fri: 8AM-6PM MST' },
          email: { title: 'Email Us', desc: 'Send us your questions anytime', response: 'Response within 24 hours' },
          visit: { title: 'Visit Us', desc: 'Our office in Cottonwood Heights', hours: 'By appointment only' }
        },
        form: {
          title: 'Send Us a Message',
          description: "Fill out the form below and we'll get back to you as soon as possible.",
          labels: { firstName: 'First Name *', lastName: 'Last Name *', email: 'Email Address *', phone: 'Phone Number', subject: 'Subject *', message: 'Message *' },
          subjectOptions: {
            select: 'Select a subject',
            general: 'General Inquiry',
            mortgage: 'Mortgage Questions',
            refinance: 'Refinancing',
            rates: 'Rate Information',
            application: 'Application Status',
            support: 'Technical Support'
          },
          placeholders: { message: 'Please tell us how we can help you...' },
          submit: 'Send Message'
        },
        submit: { success: 'Data submitted successfully', error: 'Submission failed. Please try again.' }
      },
      es: {
        title: 'Contáctanos - Broker Lenders',
        breadcrumb: { home: 'Inicio', contact: 'Contáctanos' },
        hero: {
          title: 'Contáctanos',
          description: 'Estamos aquí para ayudarte con todas tus necesidades hipotecarias. Ponte en contacto con nuestro equipo experimentado hoy mismo.',
          cta: { callFull: 'Llamar (801) 307-0273', send: 'Enviar mensaje' },
          mailtoSubject: 'Solicitud de contacto desde el sitio web',
          mailtoIntro: 'Hola Broker Lenders,\n\nMe gustaría ponerme en contacto.',
          mailtoUtm: 'Atribución UTM',
          mailtoSession: 'Contexto de sesión',
          mailtoLabels: { source: 'Fuente', campaign: 'Campaña', medium: 'Medio', content: 'Contenido', term: 'Término', landing: 'Página de aterrizaje', referrer: 'Referente' },
        },
        contact: {
          title: 'Ponte en contacto',
          description: 'Ofrecemos múltiples formas de comunicarse con nosotros. Elige el método más conveniente para ti.'
        },
        cards: {
          phone: { title: 'Llámanos', desc: 'Habla directamente con nuestros expertos hipotecarios', hours: 'Lun-Vie: 8AM-6PM MST' },
          email: { title: 'Envíanos un correo', desc: 'Envíanos tus preguntas en cualquier momento', response: 'Respuesta dentro de 24 horas' },
          visit: { title: 'Visítanos', desc: 'Nuestra oficina en Cottonwood Heights', hours: 'Solo con cita previa' }
        },
        form: {
          title: 'Envíanos un mensaje',
          description: 'Completa el siguiente formulario y te responderemos lo antes posible.',
          labels: { firstName: 'Nombre *', lastName: 'Apellido *', email: 'Correo electrónico *', phone: 'Teléfono', subject: 'Asunto *', message: 'Mensaje *' },
          subjectOptions: {
            select: 'Selecciona un asunto',
            general: 'Consulta general',
            mortgage: 'Preguntas sobre hipotecas',
            refinance: 'Refinanciamiento',
            rates: 'Información de tasas',
            application: 'Estado de solicitud',
            support: 'Soporte técnico'
          },
          placeholders: { message: 'Cuéntanos cómo podemos ayudarte...' },
          submit: 'Enviar mensaje'
        },
        submit: { success: 'Datos enviados correctamente', error: 'Error al enviar. Intenta nuevamente.' }
      }
    };

    const resolvePath = (obj, path) => {
      if (!obj || !path) return null;
      const parts = path.split('.');
      let cur = obj;
      for (const p of parts) { if (cur && (p in cur)) cur = cur[p]; else return null; }
      return cur;
    };
    const getInitialLang = () => {
      const urlLang = new URLSearchParams(window.location.search).get('lang');
      let cookieLang = null;
      try {
        const m = document.cookie.match(/(?:^|;\s*)lang=([^;]+)/);
        cookieLang = m && m[1] ? m[1].toLowerCase() : null;
      } catch {}
      const stored = localStorage.getItem('lang');
      const htmlLang = document.documentElement.getAttribute('lang');
      const raw = (urlLang || cookieLang || stored || htmlLang || 'en').toLowerCase();
      return raw === 'es' ? 'es' : 'en';
    };
    const applyTranslations = (lang) => {
      const dict = translations[lang] || translations.en;
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        const val = resolvePath(dict, key);
        if (typeof val === 'string') {
          if (val.includes('<')) el.innerHTML = val; else el.textContent = val;
        }
      });
      document.querySelectorAll('[data-i18n-aria]').forEach(el => {
        const key = el.getAttribute('data-i18n-aria');
        const val = resolvePath(dict, key);
        if (typeof val === 'string') el.setAttribute('aria-label', val);
      });
      document.querySelectorAll('[data-i18n-alt]').forEach(el => {
        const key = el.getAttribute('data-i18n-alt');
        const val = resolvePath(dict, key);
        if (typeof val === 'string') el.setAttribute('alt', val);
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
        const key = el.getAttribute('data-i18n-placeholder');
        const val = resolvePath(dict, key);
        if (typeof val === 'string') el.setAttribute('placeholder', val);
      });
      if (typeof dict.title === 'string') document.title = dict.title;
    };
    const setLanguage = (lang) => {
      const next = (lang === 'es') ? 'es' : 'en';
      try { localStorage.setItem('lang', next); } catch {}
      try { document.cookie = `lang=${next};path=/;max-age=31536000;SameSite=Lax`; } catch {}
      try { document.documentElement.setAttribute('lang', next); } catch {}
      const url = new URL(window.location.href);
      url.searchParams.set('lang', next);
      const newUrl = url.toString();
      if (newUrl !== window.location.href) window.history.replaceState({}, '', newUrl);
      applyTranslations(next);
    };
    // Initialize
    setLanguage(getInitialLang());
    // React to language menu clicks
    document.addEventListener('click', (e) => {
      const a = e.target.closest('a[href*="?lang="]');
      if (!a) return;
      let href; try { href = new URL(a.href, window.location.origin); } catch { return; }
      const newLang = href.searchParams.get('lang');
      if (newLang) setLanguage(newLang);
    });
    // Respond to storage events
    window.addEventListener('storage', (ev) => {
      if (ev.key === 'lang' && ev.newValue) applyTranslations(ev.newValue);
    });

    const form = document.getElementById('contactForm');
    const submitBtn = document.getElementById('submitBtn');
    const successEl = document.getElementById('submitSuccess');
    const errorEl = document.getElementById('submitError');
    const submitContainer = document.getElementById('submitContainer');
    const heroBtn = document.getElementById('heroSendBtn');

    // Animations helpers
    function showAnimated(el) {
      if (!el) return;
      // Ensure element is displayed and visible
      el.style.display = 'inline-flex';
      el.classList.remove('hidden');
      el.classList.add('fade-in');
      el.classList.add('slide-in-up');
      el.addEventListener('animationend', () => {
        el.classList.remove('fade-in');
        el.classList.remove('slide-in-up');
      }, { once: true });
    }

    function hideButtonAnimated(btn) {
      if (!btn) return;
      btn.classList.add('fade-out');
      btn.addEventListener('animationend', () => {
        btn.classList.add('hidden');
        btn.classList.remove('fade-out');
      }, { once: true });
    }

    // Populate hidden UTM inputs from current URL query params
    (function populateUTM() {
      if (!form) return;
      const params = new URLSearchParams(window.location.search || '');
      const utmFields = ['utm_source', 'utm_campaign', 'utm_medium', 'utm_content', 'utm_term'];
      utmFields.forEach((name) => {
        const input = form.querySelector(`input[name="${name}"]`);
        if (input) {
          input.value = params.get(name) || '';
        }
      });
    })();

    // Populate extra analytics fields
    (async function populateExtra() {
      if (!form) return;
      const refInput = form.querySelector('input[name="referrer"]');
      const landInput = form.querySelector('input[name="landing_page"]');
      const uaInput = form.querySelector('input[name="user_agent"]');
      const ipInput = form.querySelector('input[name="ip_address"]');

      try {
        // Referrer
        if (refInput) refInput.value = document.referrer || '';
        // Landing page: first page in session
        const existingLanding = sessionStorage.getItem('landing_page');
        if (!existingLanding) {
          sessionStorage.setItem('landing_page', window.location.href);
        }
        if (landInput) landInput.value = sessionStorage.getItem('landing_page') || window.location.href;
        // User agent
        if (uaInput) uaInput.value = navigator.userAgent || '';
        // IP address (best-effort)
        try {
          const res = await fetch('https://api.ipify.org?format=json');
          const data = await res.json();
          if (ipInput) ipInput.value = data.ip || '';
        } catch (ipErr) {
          console.warn('No se pudo obtener IP:', ipErr);
        }
      } catch (err) {
        console.warn('Error poblando campos extra:', err);
      }
    })();

    async function sendWebhook(url, payload) {
      if (!url) return;
      await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
    }

    async function sendFormSubmit(email, payload) {
      if (!email) return;
      await fetch(`https://formsubmit.co/ajax/${encodeURIComponent(email)}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(payload)
      });
    }

    // Hero button: open mailto including UTM params and scroll to form
    heroBtn?.addEventListener('click', (evt) => {
      evt.preventDefault();
      const formSection = document.getElementById('contact-form');
      formSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });

      const email = 'info@brokerlenders.com';
      const lang = (localStorage.getItem('lang') || document.documentElement.getAttribute('lang') || 'en');
      const dict = translations[lang] || translations.en;
      const subject = encodeURIComponent(dict.hero.mailtoSubject);

      // Read current UTM params from URL
      const params = new URLSearchParams(window.location.search || '');
      const utm_source = params.get('utm_source') || '';
      const utm_campaign = params.get('utm_campaign') || '';
      const utm_medium = params.get('utm_medium') || '';
      const utm_content = params.get('utm_content') || '';
      const utm_term = params.get('utm_term') || '';

      // First landing page in session and referrer
      const landing = sessionStorage.getItem('landing_page') || window.location.href;
      const referrer = document.referrer || '';

      // Compose a readable body including UTM attribution and session context
      const L = dict.hero.mailtoLabels;
      const bodyText = `${dict.hero.mailtoIntro}\n\n${dict.hero.mailtoUtm}:\n- ${L.source}: ${utm_source || '(none)'}\n- ${L.campaign}: ${utm_campaign || '(none)'}\n- ${L.medium}: ${utm_medium || '(none)'}\n- ${L.content}: ${utm_content || '(none)'}\n- ${L.term}: ${utm_term || '(none)'}\n\n${dict.hero.mailtoSession}:\n- ${L.landing}: ${landing}\n- ${L.referrer}: ${referrer || '(none)'}\n\n`;
      const body = encodeURIComponent(bodyText);

      // Open default mail client
      window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Ocultar botón con animación
      hideButtonAnimated(submitBtn);
      // Reset messages before a new attempt
      errorEl?.classList.add('hidden');
      successEl?.classList.add('hidden');
      if (errorEl) errorEl.style.display = 'none';
      if (successEl) successEl.style.display = 'none';

      // Recolectar datos del formulario
      const fd = new FormData(form);
      // Timestamp del envío (ISO)
      const tsInput = form.querySelector('input[name="submit_timestamp"]');
      if (tsInput) tsInput.value = new Date().toISOString();
      // Reconstruir con timestamp
      const fdWithTs = new FormData(form);
      const payload = {};
      fdWithTs.forEach((value, key) => { payload[key] = value; });

      const webhookUrl = form.dataset.webhook || '';
      const formSubmitEmail = form.dataset.formsubmitEmail || '';

      try {
        await Promise.all([
          sendWebhook(webhookUrl, payload),
          sendFormSubmit(formSubmitEmail, payload)
        ]);
        // Mostrar mensaje éxito con animación (texto ya controlado por i18n)
        // Ocultar mensaje de error si estuviera visible
        errorEl?.classList.add('hidden');
        if (errorEl) errorEl.style.display = 'none';
        showAnimated(successEl);
        // Auto-ocultar éxito y restaurar el botón tras 3.5s
        setTimeout(() => {
          // Ocultar éxito
          successEl?.classList.add('hidden');
          if (successEl) successEl.style.display = 'none';
          // Reaparecer botón con animación
          submitBtn?.classList.remove('hidden');
          submitBtn?.classList.add('fade-in');
          submitBtn?.classList.add('slide-in-up');
          submitBtn?.addEventListener('animationend', () => {
            submitBtn?.classList.remove('fade-in');
            submitBtn?.classList.remove('slide-in-up');
          }, { once: true });
        }, 3500);
      } catch (err) {
        console.warn('Error enviando el formulario:', err);
        // Ocultar mensaje de éxito si estuviera visible
        successEl?.classList.add('hidden');
        if (successEl) successEl.style.display = 'none';
        showAnimated(errorEl);
        // Reaparecer botón y auto-ocultar error después de unos segundos
        setTimeout(() => {
          submitBtn?.classList.remove('hidden');
          submitBtn?.classList.add('fade-in');
          submitBtn?.classList.add('slide-in-up');
          submitBtn?.addEventListener('animationend', () => {
            submitBtn?.classList.remove('fade-in');
            submitBtn?.classList.remove('slide-in-up');
          }, { once: true });
          errorEl?.classList.add('hidden');
          if (errorEl) errorEl.style.display = 'none';
        }, 4500);
      }
    });
  });
</script>

<style>
  /* Smooth, subtle animations */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }
  @keyframes slideInUp {
    from { transform: translateY(8px); }
    to { transform: translateY(0); }
  }
  .fade-in { animation: fadeIn 220ms ease-out forwards; }
  .fade-out { animation: fadeOut 180ms ease-in forwards; }
  .slide-in-up { animation: slideInUp 220ms ease-out forwards; }
</style>
