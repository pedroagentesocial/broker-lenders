        <!-- Right Sidebar - Legal Info -->
        <div class="lg:col-span-1 lg:order-2">
          <div class="bg-white p-6 sticky top-8">
            <h3 class="text-xl font-semibold text-gray-900 mb-4" data-i18n="sidebar.legal_info">Legal Info</h3>
            <nav class="space-y-3">
              <div class="flex items-center">
                <div class="w-2 h-2 bg-gray-300 rounded-full mr-3"></div>
                <a href={`/legal/terms-of-use?lang=${lang}`} class="text-base text-gray-600 hover:text-red-600 transition-colors" data-i18n="sidebar.terms_of_use">Terms Of Use</a>
              </div>
              <div class="flex items-center">
                <div class="w-2 h-2 bg-red-600 rounded-full mr-3"></div>
                <span class="text-base font-semibold text-red-600" data-i18n="sidebar.disclosures">Disclosures And Licenses</span>
              </div>
              <div class="flex items-center">
                <div class="w-2 h-2 bg-gray-300 rounded-full mr-3"></div>
                <a href={`/legal/privacy?lang=${lang}`} class="text-base text-gray-600 hover:text-red-600 transition-colors" data-i18n="sidebar.privacy_policy">Privacy Policy</a>
