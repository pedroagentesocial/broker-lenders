---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import CarouselRates from '../components/CarouselRates.astro';
import NextMoveSection from '../components/NextMoveSection.astro';
import UnderstandingSection from '../components/UnderstandingSection.astro';
import OnlineSection from '../components/OnlineSection.astro';
import RewardsCard from '../components/RewardsCard.astro';
import NeighborhoodStats from '../components/NeighborhoodStats.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import ImportantLegal from '../components/ImportantLegal.astro';
---

<Layout title="Broker Lenders - Home Loans Made for Your Lifestyle">
	<HeroSection />
	<CarouselRates />
	<NextMoveSection />
	<UnderstandingSection />
	<OnlineSection />
	<RewardsCard />
	<NeighborhoodStats />
	<TestimonialsSection />
	
	<!-- Final CTA Section -->
	<section class="py-18 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h2 class="text-3xl font-bold text-gray-900 mb-8">Thousands have made it home with us. You can too.</h2>
				<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
					<a href="https://pedrolira.my1003app.com/318973/register" target="_blank" class="bg-black text-white px-8 py-4 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors text-lg inline-block text-center">
						I'm ready to buy
					</a>
					<a href="tel:+1-801-307-0273" class="bg-white text-black px-8 py-4 rounded-[48px] font-semibold border-2 border-black hover:bg-gray-100 transition-colors text-lg inline-flex items-center justify-center text-center">
						<svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
						</svg>
						(801) 307-0273
					</a>
				</div>
			</div>
		</div>
	</section>
	
	<!-- Important Legal Disclosures -->
	<ImportantLegal />
</Layout>
