{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/aboutus/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/contact-submit/?$",
			"dest": "_render"
		},
		{
			"src": "^/contactus/?$",
			"dest": "_render"
		},
		{
			"src": "^/faqs/?$",
			"dest": "_render"
		},
		{
			"src": "^/feedback/?$",
			"dest": "_render"
		},
		{
			"src": "^/form/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}