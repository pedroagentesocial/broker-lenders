---
import Layout from '../../layouts/Layout.astro';
import Contact from '../../components/Contact.astro';
import ImportantLegal from '../../components/ImportantLegal.astro';
import NextMoveSection from '../../components/NextMoveSection.astro';
import enDict from '../../translations/mortgage-calculator/en.json';
import esDict from '../../translations/mortgage-calculator/es.json';
const enB64 = Buffer.from(JSON.stringify(enDict)).toString('base64');
const esB64 = Buffer.from(JSON.stringify(esDict)).toString('base64');
 

export const prerender = false;
// Ensure UTF-8 response to avoid corrupted accented characters on first load
Astro.response.headers.set('Content-Type', 'text/html; charset=UTF-8');

// Use Astro.request.url for reliable SSR query parsing; fallback cookie
const reqUrl = new URL(Astro.request.url);
const qsLang = (reqUrl.searchParams.get('lang') || '').toLowerCase();
const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookieLangMatch = cookieHeader.match(/(?:^|;\s*)lang=([^;]+)/);
const cookieLang = (cookieLangMatch?.[1] || '').toLowerCase();
const langParam = (qsLang || cookieLang || 'en');
const lang = ['en', 'es'].includes(langParam) ? langParam : 'en';
console.log('[i18n][mortgage-calculator][SSR]', { href: reqUrl.href, qsLang, cookieLang, lang });
const dict = lang === 'es' ? esDict : enDict;
---

<!-- i18n dynamic translations for Mortgage Calculator -->
<div id="i18n-mc" data-en={enB64} data-es={esB64} style="display:none"></div>
<script is:inline>
  (() => {
    const payloadEl = document.getElementById('i18n-mc');
    const decode = (val) => {
      try {
        const b64 = val || '';
        const bin = atob(b64);
        // Build byte array from binary string
        const bytes = Uint8Array.from({ length: bin.length }, (_, i) => bin.charCodeAt(i) & 0xff);
        let jsonText = '';
        // Primary UTF-8 decode
        try {
          jsonText = new TextDecoder('utf-8', { fatal: false }).decode(bytes);
        } catch {
          // Fallback: percent-decode to handle UTF-8 sequences
          try {
            const percent = Array.from(bin, c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join('');
            jsonText = decodeURIComponent(percent);
          } catch {
            jsonText = bin; // Last resort
          }
        }
        try {
          return JSON.parse(jsonText);
        } catch {
          return {};
        }
      } catch { return {}; }
    };
    const translations = {
      en: decode(payloadEl?.getAttribute('data-en') || ''),
      es: decode(payloadEl?.getAttribute('data-es') || ''),
    };
    const getInitialLang = () => {
      const urlLang = new URLSearchParams(window.location.search).get('lang');
      const stored = localStorage.getItem('lang');
      return (urlLang || stored || 'en');
    };
    const resolvePath = (obj, path) => {
      try {
        const parts = (path || '').split('.');
        let cur = obj;
        for (const p of parts) {
          if (cur && typeof cur === 'object' && p in cur) cur = cur[p]; else return null;
        }
        return typeof cur === 'string' ? cur : null;
      } catch { return null; }
    };
    const preserveLangOnLocalLinks = (lang) => {
      try {
        const containers = [document.body];
        containers.forEach(container => {
          const localLinks = container ? container.querySelectorAll('a[href^="/"]') : [];
          localLinks.forEach(a => {
            const raw = a.getAttribute('href') || '';
            if (!raw || raw.startsWith('#') || raw.startsWith('tel:') || raw.startsWith('mailto:') || /([?&])lang=/.test(raw)) return;
            let href;
            try { href = new URL(a.href, window.location.origin); } catch { return; }
            if (href.origin !== window.location.origin) return;
            if (lang) {
              href.searchParams.set('lang', lang);
              a.setAttribute('href', href.pathname + href.search + href.hash);
            }
          });
        });
      } catch {}
    };
    const applyTranslations = (lang) => {
      const dict = translations[lang] || translations.en;
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        const val = resolvePath(dict, key);
        if (typeof val === 'string') {
          if (val.includes('<')) {
            el.innerHTML = val;
          } else {
            el.textContent = val;
          }
        }
      });
      if (typeof dict.page_title === 'string') document.title = dict.page_title;
      preserveLangOnLocalLinks(lang);
    };
    const __initLang = getInitialLang();
    applyTranslations(__initLang);
    // React immediately to language menu clicks from Header (without full reload)
    document.addEventListener('click', (e) => {
      const a = e.target.closest('a[href*="?lang="]');
      if (!a) return;
      let href;
      try { href = new URL(a.href, window.location.origin); } catch { return; }
      const newLang = href.searchParams.get('lang');
      if (newLang) {
        applyTranslations(newLang);
        preserveLangOnLocalLinks(newLang);
      }
    });
    // Also respond when navigating history (back/forward) to pages with different ?lang
    window.addEventListener('popstate', () => {
      const urlLang = new URLSearchParams(window.location.search).get('lang');
      const lang = (urlLang || localStorage.getItem('lang') || 'en');
      applyTranslations(lang);
      preserveLangOnLocalLinks(lang);
    });
    window.addEventListener('storage', (ev) => {
      if (ev.key === 'lang' && ev.newValue) {
        applyTranslations(ev.newValue);
        preserveLangOnLocalLinks(ev.newValue);
      }
    });
  })();
</script>

<Layout title={dict.page_title} lang={lang}>
	<!-- Breadcrumb -->
	<section class="bg-white py-4">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<nav class="flex" aria-label="Breadcrumb">
				<ol class="flex items-center space-x-4">
					<li>
						<div>
							<a href={`/?lang=${lang}`} class="text-gray-400 hover:text-gray-500 text-sm font-medium" id="mc-breadcrumb-home" data-i18n="breadcrumb.home">
								{dict.breadcrumb.home}
							</a>
						</div>
					</li>
					<li>
						<div class="flex items-center">
							<svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
							</svg>
							<a href={`/calculators?lang=${lang}`} class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" id="mc-breadcrumb-calculators" data-i18n="breadcrumb.calculators">{dict.breadcrumb.calculators}</a>
						</div>
					</li>
					<li>
						<div class="flex items-center">
							<svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
								<path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
							</svg>
							<span class="ml-4 text-sm font-medium text-gray-500" id="mc-breadcrumb-current" data-i18n="breadcrumb.current">{dict.breadcrumb.current}</span>
						</div>
					</li>
				</ol>
			</nav>
		</div>
	</section>

	<!-- Main Calculator Section -->
	<section class="py-8 bg-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8">
				<h1 id="mc-hero-title" class="text-2xl font-bold text-gray-900 mb-3" data-i18n="hero.title">{dict.hero.title}</h1>
				<p id="mc-hero-subtitle" class="text-base text-gray-600 max-w-2xl mx-auto" data-i18n="hero.subtitle">
					{dict.hero.subtitle}
				</p>
			</div>

			<!-- 2-Column Layout Container -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
				<!-- Left Column: Calculator Form -->
				<div class="bg-gray-100 p-4 rounded-xl shadow-lg border border-gray-200">
					<form id="mortgage-form" class="space-y-4">
						<!-- Home Price -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
						<div class="flex justify-start px-1.5 mb-0.5">
							<span id="mc-label-home-price" class="text-xs font-medium text-gray-700" data-i18n="form.labels.home_price">{dict.form.labels.home_price}</span>
						</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="homePrice" 
									name="homePrice"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
								placeholder={dict.form.placeholders.value}
							>
						</div>
					</div>

						<!-- Down Payment -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
						<div class="flex justify-start px-1.5 mb-0.5">
							<span id="mc-label-down-payment" class="text-xs font-medium text-gray-700" data-i18n="form.labels.down_payment">{dict.form.labels.down_payment}</span>
						</div>
							<!-- Input Field with Toggle Buttons -->
							<div class="flex space-x-2">
								<div class="relative flex-1">
									<span id="downPaymentSymbol" class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
									<input 
										type="text" 
										id="downPayment" 
										name="downPayment"
										class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
										placeholder="0"
									>
								</div>
								<!-- Toggle Button -->
								<div class="flex space-x-1">
									<button 
										type="button" 
										id="toggleDollar" 
										class="px-2 py-1.5 text-xs font-medium rounded-md transition-all duration-200 bg-gray-900 border border-gray-900 text-white hover:bg-gray-800"
									>
										$
									</button>
									<button 
										type="button" 
										id="togglePercent" 
										class="px-2 py-1.5 text-xs font-medium rounded-md transition-all duration-200 bg-white border border-gray-300 text-gray-600 hover:bg-gray-50"
									>
										%
									</button>
								</div>
							</div>
						</div>

						<!-- Loan Term and Interest Rate (Same Row) -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
							<!-- Loan Term -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
								<span id="mc-label-loan-term" class="text-xs font-medium text-gray-700" data-i18n="form.labels.loan_term">{dict.form.labels.loan_term}</span>
									<!-- Info Icon with Tooltip -->
									<div class="relative ml-2 group">
										<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
											<span class="text-white text-xs font-bold">i</span>
										</div>
										<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-32 text-center leading-tight" id="mc-tooltip-loan-term" data-i18n="form.tooltips.loan_term">
										{dict.form.tooltips.loan_term}
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
									</div>
								</div>
								<!-- Select Field -->
								<select 
									id="loanTerm" 
									name="loanTerm"
									class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
								>
								<option value="15">{dict.form.options.years_15}</option>
								<option value="20">{dict.form.options.years_20}</option>
								<option value="30" selected>{dict.form.options.years_30}</option>
							</select>
						</div>

							<!-- Interest Rate -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
								<span id="mc-label-interest-rate" class="text-xs font-medium text-gray-700" data-i18n="form.labels.interest_rate">{dict.form.labels.interest_rate}</span>
									<!-- Info Icon with Tooltip -->
									<div class="relative ml-2 group">
										<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
											<span class="text-white text-xs font-bold">i</span>
										</div>
										<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-10 w-32 text-center leading-tight" id="mc-tooltip-interest-rate" data-i18n="form.tooltips.interest_rate">
										{dict.form.tooltips.interest_rate}
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
									</div>
								</div>
								<!-- Input Field -->
								<div class="relative">
									<input 
										type="text" 
										id="interestRate" 
										name="interestRate"
										value="5.99"
										maxlength="4"
										class="w-full pl-1.5 pr-5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder={dict.form.placeholders.interest_example}
								>
								<span class="absolute right-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">%</span>
							</div>
						</div>
					</div>

						<!-- ZIP Code Container -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
						<div class="flex justify-start px-1.5 mb-0.5">
							<span id="mc-label-zip" class="text-xs font-medium text-gray-700" data-i18n="form.labels.zip_code">{dict.form.labels.zip_code}</span>
						</div>
							<!-- Input Field -->
							<input 
								type="text" 
								id="zipCode" 
								name="zipCode"
								value=""
								class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
							placeholder={dict.form.placeholders.zip_value}
						>
					</div>

						<!-- Optional Collapsible Section -->
						<div class="pt-3">
							<button 
								type="button"
								id="optionalToggle"
								class="flex items-center justify-between w-full text-left text-sm font-medium text-gray-600 hover:text-gray-800 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 rounded-lg p-1.5"
								aria-expanded="false"
								aria-controls="optionalFields"
							>
						<span id="mc-optional-toggle" data-i18n="form.optional_toggle">{dict.form.optional_toggle}</span>
								<svg 
									id="chevronIcon"
									class="w-5 h-5 transform transition-transform duration-200" 
									fill="none" 
									stroke="currentColor" 
									viewBox="0 0 24 24"
								>
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
								</svg>
							</button>
							
							<div 
								id="optionalFields" 
								class="overflow-hidden transition-all duration-300 ease-in-out"
								style="max-height: 0;"
								aria-hidden="true"
							>
								<div class="pt-3 space-y-4">
									<!-- Yearly Property Tax -->
									<div class="bg-white p-1.5 rounded-lg">
										<!-- Label positioned above input, aligned with placeholder text -->
										<div class="flex justify-start items-center px-1.5 mb-0.5">
								<span id="mc-label-property-tax" class="text-xs font-medium text-gray-700" data-i18n="form.labels.yearly_property_tax">{dict.form.labels.yearly_property_tax}</span>
											<!-- Info Icon with Tooltip -->
											<div class="relative ml-2 group">
												<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
													<span class="text-white text-xs font-bold">i</span>
												</div>
												<!-- Tooltip -->
									<div class="absolute top-full left-1/2 transform -translate-x-1/2 mt-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-32 text-center leading-tight" id="mc-tooltip-property-tax" data-i18n="form.tooltips.property_tax">
										{dict.form.tooltips.property_tax}
										<!-- Arrow pointing up -->
										<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-b-2 border-transparent border-b-black"></div>
									</div>
											</div>
										</div>
										<!-- Input Field -->
										<div class="relative">
											<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
											<input 
												type="text" 
												id="propertyTax" 
												name="propertyTax"
												class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
												placeholder="0"
											>
										</div>
									</div>

									<!-- Yearly Home Insurance -->
									<div class="bg-white p-1.5 rounded-lg">
										<!-- Label positioned above input, aligned with placeholder text -->
										<div class="flex justify-start items-center px-1.5 mb-0.5">
								<span id="mc-label-home-insurance" class="text-xs font-medium text-gray-700" data-i18n="form.labels.yearly_home_insurance">{dict.form.labels.yearly_home_insurance}</span>
											<!-- Info Icon with Tooltip -->
											<div class="relative ml-2 group">
												<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
													<span class="text-white text-xs font-bold">i</span>
												</div>
												<!-- Tooltip -->
									<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-32 text-center leading-tight" id="mc-tooltip-home-insurance" data-i18n="form.tooltips.home_insurance">
										{dict.form.tooltips.home_insurance}
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
											</div>
										</div>
										<!-- Input Field -->
										<div class="relative">
											<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
											<input 
												type="text" 
												id="homeInsurance" 
												name="homeInsurance"
												class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
												placeholder="0"
											>
										</div>
									</div>
								</div>
							</div>
						</div>
					</form>
					
					<!-- Calculate Button -->
					<div class="mt-4">
						<button 
							id="calculateButton"
							type="button"
							class="w-full bg-black text-white py-3 px-4 rounded-[48px] text-base font-semibold hover:bg-gray-800 transition-colors duration-200"
						>
							{dict.form.buttons.calculate}
						</button>
					</div>
					
					<!-- Logo and Legal Disclosures -->
					<div class="mt-4 flex items-center justify-center space-x-2 text-xs text-gray-500">
                        <img 
                            src="/logo.png" 
                            alt="Broker Lenders Logo" 
                            class="h-6 w-auto"
                        >
						<span>|</span>
						<button 
							id="legalDisclosuresBtn"
							class="underline hover:text-gray-700 transition-colors cursor-pointer"
						>
							{dict.form.buttons.legal_disclosures}
						</button>
