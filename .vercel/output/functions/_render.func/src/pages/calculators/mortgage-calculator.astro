							<div class="text-center">
								<div class="text-xl font-bold mb-0.5" id="principalInterest">$0</div>
								<div id="mc-label-principal-interest" class="text-[10px] text-gray-600" data-i18n="results.principal_interest">{dict.results.principal_interest}</div>
							</div>
							<div class="text-center">
								<div class="text-xl font-bold mb-0.5" id="monthlyPropertyTax">$0</div>
								<div id="mc-label-property-tax-result" class="text-[10px] text-gray-600" data-i18n="results.property_tax">{dict.results.property_tax}</div>
							</div>
							<div class="text-center">
								<div class="text-xl font-bold mb-0.5" id="monthlyHomeInsurance">$0</div>
