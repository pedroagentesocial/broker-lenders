						<!-- Button -->
						<div class="text-left">
							<button id="mc-btn-real-number" class="mt-2 mb-2 px-6 py-3 border border-gray-400 text-gray-700 bg-transparent rounded-full hover:bg-gray-100 transition-colors text-xs font-bold" data-i18n="results.real_number">
								{dict.results.real_number}
							</button>
						</div>
					</div>

					<!-- Message Card -->
					<div id="messageCard" class="bg-gray-100 p-4 rounded-xl shadow-lg">
						<div class="text-center">
						<p id="mc-cta-message" class="text-gray-700 text-base mb-4" data-i18n="cta.message">{dict.cta.message}</p>
