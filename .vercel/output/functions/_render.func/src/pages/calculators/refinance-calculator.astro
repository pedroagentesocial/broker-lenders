---
import Layout from '../../layouts/Layout.astro';
import Contact from '../../components/Contact.astro';
import ImportantLegal from '../../components/ImportantLegal.astro';
import NextMoveSection from '../../components/NextMoveSection.astro';
import enDict from '../../translations/refinance-calculator/en.json';
import esDict from '../../translations/refinance-calculator/es.json';
const enB64 = Buffer.from(JSON.stringify(enDict)).toString('base64');
const esB64 = Buffer.from(JSON.stringify(esDict)).toString('base64');

export const prerender = false;
// Ensure UTF-8 response to avoid corrupted accented characters on first load
Astro.response.headers.set('Content-Type', 'text/html; charset=UTF-8');
// SSR language detection for i18n
const reqUrl = new URL(Astro.request.url);
const qsLang = (reqUrl.searchParams.get('lang') || '').toLowerCase();
const cookieHeader = Astro.request.headers.get('cookie') || '';
const cookieLangMatch = cookieHeader.match(/(?:^|;\s*)lang=([^;]+)/);
const cookieLang = (cookieLangMatch?.[1] || '').toLowerCase();
const langParam = (qsLang || cookieLang || 'en');
const lang = ['en', 'es'].includes(langParam) ? langParam : 'en';
const dict = lang === 'es' ? esDict : enDict;
---
<!-- i18n payload for Refinance Calculator -->
<div id="i18n-rc" data-en={enB64} data-es={esB64} style="display:none"></div>
<script is:inline>
  (() => {
    const payloadEl = document.getElementById('i18n-rc');
    const decode = (val) => {
      try {
        const b64 = val || '';
        const bin = atob(b64);
        const bytes = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
        const jsonText = new TextDecoder('utf-8').decode(bytes);
        return JSON.parse(jsonText);
      } catch { return {}; }
    };
    const translations = {
      en: decode(payloadEl?.getAttribute('data-en') || ''),
      es: decode(payloadEl?.getAttribute('data-es') || ''),
    };
    const getInitialLang = () => {
      const urlLang = new URLSearchParams(window.location.search).get('lang');
      const stored = localStorage.getItem('lang');
      return (urlLang || stored || 'en');
    };
    const resolvePath = (obj, path) => {
      try {
        const parts = (path || '').split('.');
        let cur = obj;
        for (const p of parts) {
          if (cur && typeof cur === 'object' && p in cur) cur = cur[p]; else return null;
        }
        return typeof cur === 'string' ? cur : null;
      } catch { return null; }
    };
    const preserveLangOnLocalLinks = (lang) => {
      try {
        const localLinks = document.querySelectorAll('a[href^="/"]');
        localLinks.forEach(a => {
          const raw = a.getAttribute('href') || '';
          if (!raw || raw.startsWith('#') || raw.startsWith('tel:') || raw.startsWith('mailto:') || /([?&])lang=/.test(raw)) return;
          let href;
          try { href = new URL(a.href, window.location.origin); } catch { return; }
          if (href.origin !== window.location.origin) return;
          if (lang) {
            href.searchParams.set('lang', lang);
            a.setAttribute('href', href.pathname + href.search + href.hash);
          }
        });
      } catch {}
    };
    const applyTranslations = (lang) => {
      const dict = translations[lang] || translations.en;
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        const val = resolvePath(dict, key);
        if (typeof val === 'string') {
          if (val.includes('<')) { el.innerHTML = val; } else { el.textContent = val; }
        }
      });
      // Apply attribute-based translations (e.g., placeholders, titles)
      document.querySelectorAll('[data-i18n-attr]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        const attrs = (el.getAttribute('data-i18n-attr') || '').split(',').map(s => s.trim()).filter(Boolean);
        const val = resolvePath(dict, key);
        if (typeof val === 'string' && attrs.length) {
          attrs.forEach(attr => {
            try { el.setAttribute(attr, val); } catch {}
          });
        }
      });
      if (typeof dict.page_title === 'string') document.title = dict.page_title;
      preserveLangOnLocalLinks(lang);
    };
    const __initLang = getInitialLang();
    applyTranslations(__initLang);
    document.addEventListener('click', (e) => {
      const a = e.target.closest('a[href*="?lang="]');
      if (!a) return;
      let href;
      try { href = new URL(a.href, window.location.origin); } catch { return; }
      const newLang = href.searchParams.get('lang');
      if (newLang) {
        applyTranslations(newLang);
        preserveLangOnLocalLinks(newLang);
      }
    });
    window.addEventListener('popstate', () => {
      const urlLang = new URLSearchParams(window.location.search).get('lang');
      const lang = (urlLang || localStorage.getItem('lang') || 'en');
      applyTranslations(lang);
      preserveLangOnLocalLinks(lang);
    });
    window.addEventListener('storage', (ev) => {
      if (ev.key === 'lang' && ev.newValue) {
        applyTranslations(ev.newValue);
        preserveLangOnLocalLinks(ev.newValue);
      }
    });
  })();
</script>

<Layout title={dict.page_title} lang={lang}>
	<!-- Breadcrumb -->
	<section class="bg-white py-4">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <nav class="flex" aria-label="Breadcrumb">
              <ol class="flex items-center space-x-4">
                <li>
                  <div>
                      <a href={`/?lang=${lang}`} class="text-gray-400 hover:text-gray-500 text-sm font-medium" id="rc-breadcrumb-home" data-i18n="breadcrumb.home">
                        {dict.breadcrumb.home}
                      </a>
                  </div>
                </li>
                <li>
                  <div class="flex items-center">
                    <svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                    </svg>
                      <a href={`/calculators?lang=${lang}`} class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700" id="rc-breadcrumb-calculators" data-i18n="breadcrumb.calculators">{dict.breadcrumb.calculators}</a>
                  </div>
                </li>
                <li>
                  <div class="flex items-center">
                    <svg class="flex-shrink-0 h-5 w-5 text-gray-300" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                    </svg>
                      <span class="ml-4 text-sm font-medium text-gray-500" id="rc-breadcrumb-current" data-i18n="breadcrumb.current">{dict.breadcrumb.current}</span>
                  </div>
                </li>
              </ol>
            </nav>
		</div>
	</section>

	<!-- Main Calculator Section -->
	<section class="py-8 bg-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-8">
                <h1 id="rc-hero-title" class="text-2xl font-bold text-gray-900 mb-3" data-i18n="hero.title">{dict.hero.title}</h1>
                <p id="rc-hero-subtitle" class="text-base text-gray-600 max-w-2xl mx-auto" data-i18n="hero.subtitle">
                    {dict.hero.subtitle}
                </p>
            </div>

			<!-- 2-Column Layout Container -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
				<!-- Left Column: Calculator Form -->
				<div class="bg-gray-100 p-4 rounded-xl shadow-lg border border-gray-200">
					<form id="mortgage-form" class="space-y-4">
						<!-- Current Mortgage Balance -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
                            <span class="text-xs font-medium text-gray-700" id="rc-label-current-mortgage-balance" data-i18n="form.labels.current_mortgage_balance">{dict.form.labels.current_mortgage_balance}</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
                                    <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight" id="rc-tooltip-current-mortgage-balance" data-i18n="form.tooltips.current_mortgage_balance">
                                        {dict.form.tooltips.current_mortgage_balance}
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="currentMortgageBalance" 
									name="currentMortgageBalance"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
                                    placeholder="0"
                                >
							</div>
						</div>

						<!-- Current Monthly Payment -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
                            <span class="text-xs font-medium text-gray-700" id="rc-label-current-monthly-payment" data-i18n="form.labels.current_monthly_payment">{dict.form.labels.current_monthly_payment}</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
                                    <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight" id="rc-tooltip-current-monthly-payment" data-i18n="form.tooltips.current_monthly_payment">
                                        {dict.form.tooltips.current_monthly_payment}
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="currentMonthlyPayment" 
									name="currentMonthlyPayment"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
                                    placeholder="0"
                                >
							</div>
						</div>

						<!-- Current Home Value -->
						<div class="bg-white p-1.5 rounded-lg">
							<!-- Label positioned above input, aligned with placeholder text -->
							<div class="flex justify-start items-center px-1.5 mb-0.5">
                            <span class="text-xs font-medium text-gray-700" id="rc-label-current-home-value" data-i18n="form.labels.current_home_value">{dict.form.labels.current_home_value}</span>
								<!-- Info Icon with Tooltip -->
								<div class="relative ml-2 group">
									<div class="w-4 h-4 bg-black hover:bg-gray-800 rounded-full flex items-center justify-center cursor-help transition-colors">
										<span class="text-white text-xs font-bold">i</span>
									</div>
									<!-- Tooltip -->
                                    <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-1 px-2 py-1 bg-black text-white text-[9px] rounded opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 w-48 text-center leading-tight" id="rc-tooltip-current-home-value" data-i18n="form.tooltips.current_home_value">
                                        {dict.form.tooltips.current_home_value}
										<!-- Arrow pointing down -->
										<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-2 border-r-2 border-t-2 border-transparent border-t-black"></div>
									</div>
								</div>
							</div>
							<!-- Input Field -->
							<div class="relative">
								<span class="absolute left-1.5 top-1/2 transform -translate-y-1/2 text-gray-500 text-sm">$</span>
								<input 
									type="text" 
									id="currentHomeValue" 
									name="currentHomeValue"
									class="w-full pl-5 pr-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
									placeholder="0"
								>
							</div>
						</div>

						<!-- Credit Profile and ZIP Code (Same Row) -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
							<!-- Credit Profile -->
                            <div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
								<div class="flex justify-start px-1.5 mb-0.5">
                                    <span class="text-xs font-medium text-gray-700" id="rc-label-credit-profile" data-i18n="form.labels.credit_profile">{dict.form.labels.credit_profile}</span>
								</div>
								<!-- Select Field -->
								<select 
									id="creditProfile" 
									name="creditProfile"
									class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm credit-profile-select"
								>
                                    <option value="" selected disabled class="text-gray-400" id="rc-opt-select-range" data-i18n="form.options.select_range">{dict.form.options.select_range}</option>
                                    <option value="less-than-580" class="text-gray-900" id="rc-opt-less-580" data-i18n="form.options.less_than_580">{dict.form.options.less_than_580}</option>
                                    <option value="580-619" class="text-gray-900" id="rc-opt-580-619" data-i18n="form.options.580_619">{dict.form.options['580_619']}</option>
                                    <option value="620-659" class="text-gray-900" id="rc-opt-620-659" data-i18n="form.options.620_659">{dict.form.options['620_659']}</option>
                                    <option value="660-719" class="text-gray-900" id="rc-opt-660-719" data-i18n="form.options.660_719">{dict.form.options['660_719']}</option>
                                    <option value="720-plus" class="text-gray-900" id="rc-opt-720-plus" data-i18n="form.options.720_plus">{dict.form.options['720_plus']}</option>
								</select>
							</div>

							<!-- ZIP Code -->
							<div class="bg-white p-1.5 rounded-lg">
								<!-- Label positioned above input, aligned with placeholder text -->
								<div class="flex justify-start px-1.5 mb-0.5">
                                    <span class="text-xs font-medium text-gray-700" id="rc-label-zip-code" data-i18n="form.labels.zip_code">{dict.form.labels.zip_code}</span>
								</div>
								<!-- Input Field -->
								<input 
									type="text" 
									id="zipCode" 
									name="zipCode"
									value=""
									class="w-full px-1.5 py-1.5 bg-transparent border-0 focus:outline-none text-sm"
                                    placeholder={dict.form.placeholders.zip_value}
                                    data-i18n="form.placeholders.zip_value" data-i18n-attr="placeholder"
                                >
							</div>
						</div>


					</form>
					
					<!-- Calculate Button -->
					<div class="mt-4">
                        <button 
                            id="calculateButton"
                            type="button"
                            class="w-full bg-black text-white py-3 px-4 rounded-[48px] text-base font-semibold hover:bg-gray-800 transition-colors duration-200"
                        >
                            <span id="rc-btn-calc" data-i18n="form.buttons.calculate">{dict.form.buttons.calculate}</span>
                        </button>
					</div>
					
					<!-- Logo and Legal Disclosures -->
					<div class="mt-4 flex items-center justify-center space-x-2 text-xs text-gray-500">
                        <img 
                            src="/logo.png" 
                            alt="Broker Lenders Logo" 
                            class="h-6 w-auto"
                        >
						<span>|</span>
                        <button 
                            id="legalDisclosuresBtn"
                            class="underline hover:text-gray-700 transition-colors cursor-pointer"
                        >
                            <span id="rc-btn-legal" data-i18n="form.buttons.legal_disclosures">{dict.form.buttons.legal_disclosures}</span>
                        </button>
					</div>
				</div>

				<!-- Right Column: Results and Message Cards -->
				<div class="space-y-4">
					<!-- Results Card -->
                    <div id="resultsCard" class="bg-purple-600/10 px-8 py-8 rounded-xl shadow-lg text-gray-900 min-h-80 flex flex-col justify-between">
                    <div class="text-left space-y-4">
                        <div class="text-sm font-bold text-gray-700" id="rc-results-heading" data-i18n="results.heading">{dict.results.heading}</div>
                        <div class="text-8xl font-bold speedometer-value" id="monthlySavings">$0</div>
                        <div class="text-sm font-medium text-gray-600 opacity-0 transition-opacity duration-500" id="eachMonthLabel" data-i18n="results.each_month">{dict.results.each_month}</div>
                    </div>

						<!-- Button -->
						<div class="text-left mt-2">
                            <button class="px-8 py-4 border border-gray-400 text-gray-700 bg-transparent rounded-full hover:bg-gray-100 transition-colors text-sm font-bold">
                                <span id="rc-cta-apply" data-i18n="cta.apply_now">{dict.cta.apply_now}</span>
                            </button>
                        </div>
                    </div>


				</div>
			</div>
		</div>
	</section>

	<!-- Legal Disclosures Modal -->
	<div id="legalModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
		<div class="bg-white rounded-[48px] max-w-4xl w-full max-h-[80vh] overflow-y-auto p-8 relative">
			<!-- Close Button -->
			<button 
				id="closeModal" 
				class="absolute top-6 right-6 text-gray-400 hover:text-gray-600 transition-colors"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>
			
			<!-- Modal Content -->
			<div class="pr-8">
                <h2 class="text-2xl font-bold text-gray-900 mb-6" id="rc-legal-title" data-i18n="modal.title">{dict.modal.title}</h2>
				
				<div class="space-y-6 text-gray-700 leading-relaxed">
                    <p id="rc-legal-p1" data-i18n="modal.paragraph1">
                        {dict.modal.paragraph1}
                    </p>
					
					<div>
                        <h3 class="text-lg font-semibold text-gray-900 mb-3" id="rc-legal-payment-title" data-i18n="modal.payment_example_title">{dict.modal.payment_example_title}</h3>
                        <p class="mb-3" id="rc-legal-payment-intro" data-i18n="modal.payment_example_intro">{dict.modal.payment_example_intro}</p>
						
						<div class="bg-gray-50 p-4 rounded-lg space-y-2">
                            <p><strong id="rc-legal-label-loan-amount" data-i18n="modal.labels.loan_amount">{dict.modal.labels.loan_amount}</strong> $300,000</p>
                            <p><strong id="rc-legal-label-loan-type" data-i18n="modal.labels.loan_type">{dict.modal.labels.loan_type}</strong> 30-year Fixed-Rate Loan</p>
                            <p><strong id="rc-legal-label-interest-apr" data-i18n="modal.labels.interest_apr">{dict.modal.labels.interest_apr}</strong> 7.375% (7.692% APR)</p>
                            <p><strong id="rc-legal-label-monthly-payment" data-i18n="modal.labels.monthly_payment">{dict.modal.labels.monthly_payment}</strong> $2,072.03</p>
                            <p><strong id="rc-legal-label-points" data-i18n="modal.labels.points">{dict.modal.labels.points}</strong> 1.875 points, costs due at closing</p>
                            <p><strong id="rc-legal-label-ltv" data-i18n="modal.labels.ltv">{dict.modal.labels.ltv}</strong> 80.00%</p>
						</div>
					</div>
					
					<div class="space-y-3">
                        <p id="rc-legal-p2" data-i18n="modal.paragraph2">
                            {dict.modal.paragraph2}
                        </p>
						
                        <p class="text-sm" id="rc-legal-footer-note" data-i18n="modal.footer.note">
                            {dict.modal.footer.note}
                        </p>
					</div>
				</div>
			</div>
		</div>
