<script>
	
	// Mortgage Calculator Logic
	class MortgageCalculator {
		isPercentMode;
		lastCalculation;
		
		constructor() {
			this.isPercentMode = false;
			this.initializeEventListeners();
			// Cards are visible by default - no need to clear results on init
		}

		initializeEventListeners() {
			// Remove automatic calculation - only format inputs on change
			const inputs = document.querySelectorAll('#mortgage-form input, #mortgage-form select');
			inputs.forEach(input => {
				input.addEventListener('input', () => {
					this.clearFieldValidation(input.id);
					this.formatInputs();
				});
				input.addEventListener('change', () => {
					this.clearFieldValidation(input.id);
					this.formatInputs();
				});
			});

			// No toggle buttons needed for refinance calculator

			// Calculate button event listener - now with validation
			const calculateButton = document.getElementById('calculateButton');
			console.log('Calculate button found:', calculateButton);
			if (calculateButton) {
				calculateButton.addEventListener('click', () => this.handleCalculateClick());
			}

			// Current monthly payment input listener
			const currentMonthlyPaymentInput = document.getElementById('currentMonthlyPayment');
			if (currentMonthlyPaymentInput) {
				currentMonthlyPaymentInput.addEventListener('input', () => this.formatInputs());
			}

			// Current home value input listener
			const currentHomeValueInput = document.getElementById('currentHomeValue');
			if (currentHomeValueInput) {
				currentHomeValueInput.addEventListener('input', () => this.formatInputs());
			}

			// ZIP code validation
			const zipCodeInput = document.getElementById('zipCode');
			if (zipCodeInput) {
				zipCodeInput.addEventListener('input', (e) => this.validateZipCode(e));
				zipCodeInput.addEventListener('blur', (e) => this.validateZipCodeExists(e));
			}

			// Optional section toggle
			const optionalToggle = document.getElementById('optionalToggle');
			if (optionalToggle) {
				optionalToggle.addEventListener('click', () => this.toggleOptionalSection());
			}

			// Legal disclosures modal event listeners
			const legalDisclosuresBtn = document.getElementById('legalDisclosuresBtn');
			const legalModal = document.getElementById('legalModal');
			const closeModal = document.getElementById('closeModal');

			if (legalDisclosuresBtn && legalModal) {
				legalDisclosuresBtn.addEventListener('click', () => {
					legalModal.classList.remove('hidden');
				});
			}

			if (closeModal && legalModal) {
				closeModal.addEventListener('click', () => {
					legalModal.classList.add('hidden');
				});
			}

			// Close modal when clicking outside
			if (legalModal) {
				legalModal.addEventListener('click', (e) => {
					if (e.target === legalModal) {
						legalModal.classList.add('hidden');
					}
				});
			}

			// Call Now button event listener
			const callNowBtn = document.getElementById('callNowBtn');
			if (callNowBtn) {
				callNowBtn.addEventListener('click', () => {
					window.location.href = 'tel:+1234567890'; // Replace with actual phone number
				});
			}
		}

		// Methods removed - not needed for refinance calculator

		validateInterestRate(e) {
			const input = e.target;
			let value = input.value;
			
			// Remove any non-numeric characters except decimal point
			value = value.replace(/[^0-9.]/g, '');
			
			// Ensure only one decimal point
			const parts = value.split('.');
			if (parts.length > 2) {
				value = parts[0] + '.' + parts.slice(1).join('');
			}
			
			// Limit to 4 characters total (e.g., 5.99, 12.5, 99.9)
			if (value.length > 4) {
				value = value.substring(0, 4);
			}
			
			// Update the input value
			input.value = value;
		}

		validateZipCode(e) {
			const input = e.target;
			let value = input.value;
			
			// Remove any non-numeric characters
			value = value.replace(/[^0-9]/g, '');
			
			// Limit to 5 digits for US ZIP codes
			if (value.length > 5) {
				value = value.substring(0, 5);
			}
			
			// Update the input value
			input.value = value;
		}

		async validateZipCodeExists(e) {
			const input = e.target;
			const zipCode = input.value;
			
			// Reset border color
			input.classList.remove('border-red-500');
			input.classList.add('border-gray-300');
			
			if (zipCode.length === 5) {
				try {
					// Use a free ZIP code API to validate
					const response = await fetch(`https://api.zippopotam.us/us/${zipCode}`);
					if (!response.ok) {
						// ZIP code doesn't exist
						input.classList.remove('border-gray-300');
						input.classList.add('border-red-500');
						input.title = 'ZIP code not found';
					} else {
						input.title = '';
					}
				} catch (error) {
					// If API fails, don't show error (graceful degradation)
					console.log('ZIP code validation API unavailable');
				}
			}
		}

		toggleOptionalSection() {
			const optionalFields = document.getElementById('optionalFields');
			const chevronIcon = document.getElementById('chevronIcon');
			const toggleButton = document.getElementById('optionalToggle');
			
			if (optionalFields && chevronIcon && toggleButton) {
				const isExpanded = toggleButton.getAttribute('aria-expanded') === 'true';
				
				if (isExpanded) {
					// Close the section
					optionalFields.style.maxHeight = '0px';
					optionalFields.setAttribute('aria-hidden', 'true');
					toggleButton.setAttribute('aria-expanded', 'false');
					chevronIcon.style.transform = 'rotate(0deg)';
				} else {
					// Open the section
					optionalFields.style.maxHeight = optionalFields.scrollHeight + 'px';
					optionalFields.setAttribute('aria-hidden', 'false');
					toggleButton.setAttribute('aria-expanded', 'true');
					chevronIcon.style.transform = 'rotate(180deg)';
				}
			}
		}

		formatNumber(num) {
			return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
		}

		parseNumber(str) {
			return parseFloat(str.replace(/,/g, '')) || 0;
		}

		// Method removed - not needed for refinance calculator

		// New method to handle calculate button click with validation
		handleCalculateClick() {
			console.log('handleCalculateClick called');
			
			// Clear previous validation errors
			this.clearAllValidationErrors();
			
			// Validate all required fields
			if (!this.validateAllFields()) {
				console.log('Validation failed, not calculating');
				return;
			}
			
			// Clear previous results and calculate
			this.clearResults();
			this.calculate();
		}

		// Clear field validation styling and messages
		clearFieldValidation(fieldId: string) {
			const field = document.getElementById(fieldId);
			if (field) {
				// Remove red border from container
				const container = field.closest('.bg-white');
				if (container) {
					// Special handling for credit profile
					if (fieldId === 'creditProfile') {
						container.classList.remove('credit-profile-error');
					} else {
						container.classList.remove('border-red-500', 'border-2');
					}
				}
				
				// Remove error message
				const errorMsg = document.getElementById(`${fieldId}-error`);
				if (errorMsg) {
					errorMsg.remove();
				}
			}
		}

		// Clear all validation errors
		clearAllValidationErrors() {
			const requiredFields = ['currentMortgageBalance', 'currentMonthlyPayment', 'currentHomeValue', 'creditProfile', 'zipCode'];
			requiredFields.forEach(fieldId => {
				this.clearFieldValidation(fieldId);
			});
		}

		// Validate all required fields
		validateAllFields(): boolean {
			let isValid = true;
			const requiredFields = [
				{ id: 'currentMortgageBalance', name: 'Current mortgage balance', type: 'currency' },
				{ id: 'currentMonthlyPayment', name: 'Current monthly payment', type: 'currency' },
				{ id: 'currentHomeValue', name: 'Current home value', type: 'currency' },
				{ id: 'creditProfile', name: 'Credit profile', type: 'select' },
				{ id: 'zipCode', name: 'ZIP code', type: 'zipcode' }
			];

			requiredFields.forEach(field => {
				const element = document.getElementById(field.id) as HTMLInputElement | HTMLSelectElement;
				if (element) {
					const value = element.value.trim();
					let fieldValid = true;
					let errorMessage = '';

					// Check if field is empty or invalid
					if (!value || (field.type !== 'select' && field.type !== 'zipcode' && (value === '0' || value === '$0'))) {
						fieldValid = false;
						errorMessage = `${field.name} is required`;
					} else {
						// Additional validation based on field type
						switch (field.type) {
							case 'currency':
								const numValue = this.parseNumber(value);
								if ((field.id === 'currentMortgageBalance' || field.id === 'currentMonthlyPayment' || field.id === 'currentHomeValue') && numValue <= 0) {
									fieldValid = false;
									errorMessage = `${field.name} must be greater than $0`;
								}
								break;
							case 'select':
								if (!value || value === '') {
									fieldValid = false;
									errorMessage = `Please select ${field.name.toLowerCase()}`;
								}
								break;
							case 'zipcode':
								if (!value || value.length !== 5 || !/^\d{5}$/.test(value)) {
									fieldValid = false;
									errorMessage = 'Please enter a valid 5-digit ZIP code';
								}
								break;
						}
					}

					if (!fieldValid) {
						this.showFieldError(field.id, errorMessage);
						isValid = false;
					}
				}
			});

			return isValid;
		}

		// Show error for specific field
		showFieldError(fieldId: string, message: string) {
			const field = document.getElementById(fieldId);
			if (field) {
				// Add red border to the container instead of just the input
				const container = field.closest('.bg-white');
				if (container) {
					// Special handling for credit profile
					if (fieldId === 'creditProfile') {
						container.classList.add('credit-profile-error');
					} else {
						container.classList.add('border-red-500', 'border-2');
					}
				}
				
				// Add error message
				const errorDiv = document.createElement('div');
				errorDiv.id = `${fieldId}-error`;
				errorDiv.className = 'text-red-500 text-sm mt-1 px-2';
				errorDiv.textContent = message;
				
				// Insert error message after the field's parent container
				if (container && container.parentNode) {
					container.parentNode.insertBefore(errorDiv, container.nextSibling);
				}
			}
		}

		// Clear results display (but keep cards visible)
		clearResults() {
			const monthlySavingsEl = document.getElementById('monthlySavings');
			const eachMonthLabelEl = document.getElementById('eachMonthLabel');

			// Reset to placeholder values instead of hiding cards
			if (monthlySavingsEl) monthlySavingsEl.textContent = '$0';

			// Hide the "each month" label
			if (eachMonthLabelEl) {
				eachMonthLabelEl.classList.remove('opacity-100');
				eachMonthLabelEl.classList.add('opacity-0');
			}

			// Cards remain visible - no hiding logic needed
		}



		calculate() {
			console.log('Starting professional refinance calculation...');
			
			// Get input values for refinance calculator
			const currentMortgageBalance = this.parseNumber((document.getElementById('currentMortgageBalance') as HTMLInputElement)?.value || '0');
			const currentMonthlyPayment = this.parseNumber((document.getElementById('currentMonthlyPayment') as HTMLInputElement)?.value || '0');
			const currentHomeValue = this.parseNumber((document.getElementById('currentHomeValue') as HTMLInputElement)?.value || '0');
			const creditProfile = (document.getElementById('creditProfile') as HTMLSelectElement)?.value || '';
			
			console.log('Refinance input values:', { currentMortgageBalance, currentMonthlyPayment, currentHomeValue, creditProfile });

			// Professional validation according to industry standards
			if (currentMortgageBalance <= 0) {
				this.showFieldError('currentMortgageBalance', 'Please enter a valid mortgage balance');
				return;
			}
			
			if (currentMonthlyPayment <= 0) {
				this.showFieldError('currentMonthlyPayment', 'Please enter a valid monthly payment');
				return;
			}
			
			if (currentHomeValue <= 0) {
				this.showFieldError('currentHomeValue', 'Please enter a valid home value');
				return;
			}
			
			if (!creditProfile) {
				this.showFieldError('creditProfile', 'Please select your credit profile');
				return;
			}

			// 1. Calculate Loan-to-Value (LTV) ratio - Industry standard calculation
			const loanToValueRatio = (currentMortgageBalance / currentHomeValue) * 100;
			
			// Validate LTV doesn't exceed 95% (industry standard)
			if (loanToValueRatio > 95) {
				this.showFieldError('currentMortgageBalance', 'Loan-to-value ratio exceeds 95%. Refinancing may not be available.');
				return;
			}
			
			// Validate mortgage balance is less than home value
			if (currentMortgageBalance >= currentHomeValue) {
				this.showFieldError('currentMortgageBalance', 'Mortgage balance must be less than home value');
				return;
			}

			// 2. Determine base rate - Current market rate
			const baseRate = 7.2; // Current market base rate
			
			// 3. Credit Profile adjustments - Professional industry standards
			let creditAdjustment = 0;
			switch(creditProfile) {
				case '720-plus':
					creditAdjustment = -1.5; // Best rates for 720+
					break;
				case '660-719':
					creditAdjustment = -0.8; // Good rates for 660-719
					break;
				case '620-659':
					creditAdjustment = -0.3; // Fair rates for 620-659
					break;
				case '580-619':
					creditAdjustment = 0.5; // Higher rates for 580-619
					break;
				case 'less-than-580':
					creditAdjustment = 1.8; // Highest rates for less than 580
					break;
				default:
					creditAdjustment = 0;
					break;
			}
			
			// 4. LTV-based risk adjustments - Industry standard risk pricing
			let ltvAdjustment = 0;
			if (loanToValueRatio <= 60) {
				ltvAdjustment = -0.25; // Low risk - better rate
			} else if (loanToValueRatio <= 70) {
				ltvAdjustment = -0.125; // Moderate low risk
			} else if (loanToValueRatio <= 80) {
				ltvAdjustment = 0; // Standard risk
			} else if (loanToValueRatio <= 90) {
				ltvAdjustment = 0.25; // Higher risk
			} else {
				ltvAdjustment = 0.75; // High risk
			}
			
			// Calculate final interest rate
			const estimatedNewRate = Math.max(3.0, baseRate + creditAdjustment + ltvAdjustment);

			// 5. Calculate new monthly payment using standard amortization formula
			// M = P * [r(1+r)^n] / [(1+r)^n - 1]
			const monthlyInterestRate = (estimatedNewRate / 100) / 12;
			const numberOfPayments = 30 * 12; // 30-year term (360 payments)
			
			let newMonthlyPrincipalAndInterest = 0;
			if (currentMortgageBalance > 0 && monthlyInterestRate > 0) {
				const numerator = currentMortgageBalance * (monthlyInterestRate * Math.pow(1 + monthlyInterestRate, numberOfPayments));
				const denominator = Math.pow(1 + monthlyInterestRate, numberOfPayments) - 1;
				newMonthlyPrincipalAndInterest = numerator / denominator;
			}

			// 6. Calculate monthly savings
			let monthlySavings = currentMonthlyPayment - newMonthlyPrincipalAndInterest;
			
			console.log('Professional refinance calculations:', {
				loanToValueRatio: loanToValueRatio.toFixed(2) + '%',
				baseRate: baseRate + '%',
				creditAdjustment: creditAdjustment + '%',
				ltvAdjustment: ltvAdjustment + '%',
				estimatedNewRate: estimatedNewRate.toFixed(3) + '%',
				newMonthlyPrincipalAndInterest: newMonthlyPrincipalAndInterest.toFixed(2),
				monthlySavings: monthlySavings.toFixed(2)
			});

			// Update display elements
			const monthlySavingsEl = document.getElementById('monthlySavings');
			const eachMonthLabelEl = document.getElementById('eachMonthLabel');

			// Check if there are positive savings
			if (monthlySavings > 0) {
				// Format and display results with proper currency formatting
				if (monthlySavingsEl) {
					// Animate the monthly savings with speedometer effect
					this.animateValue(monthlySavingsEl, 0, Math.round(monthlySavings), 1500);
				}

				// Show the "each month" label with animation
				if (eachMonthLabelEl) {
					setTimeout(() => {
						eachMonthLabelEl.classList.remove('opacity-0');
						eachMonthLabelEl.classList.add('opacity-100');
					}, 800); // Show label after half the animation completes
				}
            } else {
                // No savings available - show message (i18n-aware)
                if (monthlySavingsEl) {
                    try {
                        const el = document.getElementById('i18n-rc');
                        const decode = (val) => { try { const bin = atob(val||''); const bytes = new Uint8Array(bin.length); for (let i=0;i<bin.length;i++) bytes[i]=bin.charCodeAt(i); return JSON.parse(new TextDecoder('utf-8').decode(bytes)); } catch { return {}; } };
                        const urlLang = new URLSearchParams(window.location.search).get('lang');
                        const stored = localStorage.getItem('lang');
                        const lang = (urlLang || stored || 'en');
                        const translations = { en: decode(el?.getAttribute('data-en')||''), es: decode(el?.getAttribute('data-es')||'') };
                        const dict = translations[lang] || translations.en;
        const msg = (dict && dict.results && dict.results.no_savings) ? dict.results.no_savings : 'No savings available';
                        monthlySavingsEl.textContent = msg;
                    } catch {
        // Default will be overridden by msg above; use dict when available
        monthlySavingsEl.textContent = msg;
                    }
                    monthlySavingsEl.classList.add('text-red-500');
                }
				
				// Hide the "each month" label
				if (eachMonthLabelEl) {
					eachMonthLabelEl.classList.add('opacity-0');
					eachMonthLabelEl.classList.remove('opacity-100');
				}
			}
			
			// Store calculation results for potential future use
			this.lastCalculation = {
				currentMortgageBalance,
				currentMonthlyPayment,
				currentHomeValue,
				creditProfile,
				estimatedNewRate,
				newMonthlyPrincipalAndInterest,
				monthlySavings,
				loanToValueRatio
			};

			console.log('Calculation completed successfully');

			// Format input values for better user experience
			this.formatInputs();
		}

		formatInputs() {
			const moneyInputs = ['currentMortgageBalance', 'currentMonthlyPayment', 'currentHomeValue'];
			moneyInputs.forEach(id => {
				const input = document.getElementById(id) as HTMLInputElement;
				if (input) {
					const value = this.parseNumber(input.value);
					if (value > 0) {
						input.value = this.formatNumber(value);
					}
				}
			});

			// No additional formatting needed for refinance calculator
		}

		// Animate value from start to end with speedometer effect
		animateValue(element: HTMLElement, start: number, end: number, duration: number) {
			const startTime = performance.now();
			const startValue = start;
			const endValue = end;
			
			// Add animating class for CSS animation
			element.classList.add('animating');
			
			const animate = (currentTime: number) => {
				const elapsed = currentTime - startTime;
				const progress = Math.min(elapsed / duration, 1);
				
				// Easing function for speedometer effect (ease-out)
				const easeOut = 1 - Math.pow(1 - progress, 3);
				
				const currentValue = Math.round(startValue + (endValue - startValue) * easeOut);
				element.textContent = '$' + this.formatNumber(currentValue);
				
				if (progress < 1) {
					requestAnimationFrame(animate);
				} else {
					// Remove animating class when done
					element.classList.remove('animating');
				}
			};
			
			requestAnimationFrame(animate);
		}
	}

	// Initialize calculator when DOM is loaded
	document.addEventListener('DOMContentLoaded', () => {
		console.log('DOM loaded, creating calculator');
		new MortgageCalculator();

		// FAQ Accordion functionality
		const faqButtons = document.querySelectorAll('.faq-button');
		faqButtons.forEach((button) => {
			const btn = button as HTMLButtonElement;
			btn.addEventListener('click', function(this: HTMLButtonElement) {
				const content = this.nextElementSibling as HTMLElement;
				const icon = this.querySelector('.faq-icon') as HTMLElement;
				
				if (content && icon) {
					if (content.classList.contains('hidden')) {
						content.classList.remove('hidden');
						icon.style.transform = 'rotate(180deg)';
					} else {
						content.classList.add('hidden');
						icon.style.transform = 'rotate(0deg)';
					}
				}
			});
		});
	});
</script>

