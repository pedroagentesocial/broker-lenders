---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';
import WaysHelp from '../components/WaysHelp.astro';
import ImportantLegal from '../components/ImportantLegal.astro';
---

<Layout title="Feedback - Broker Lenders">
  <!-- Breadcrumb Section -->
  <div class="bg-white py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm">
        <a href="/" class="text-gray-700 hover:text-gray-900" data-i18n="breadcrumb.home">Home</a>
        <span class="mx-2 text-gray-500">/</span>
        <span class="text-gray-700" data-i18n="breadcrumb.feedback">Feedback</span>
      </nav>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6" data-i18n="hero.title">
        We Value Your Feedback
      </h1>
      <p class="text-lg text-gray-600 mb-8 max-w-3xl mx-auto" data-i18n="hero.description">
        Your opinion matters to us. Help us improve our services by sharing your experience and suggestions.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href="#feedback-form" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center justify-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
          </svg>
          <span data-i18n="hero.cta.share">Share Feedback</span>
        </a>
        <a href="tel:8013070273" class="bg-white text-black border border-black px-8 py-3 rounded-[48px] font-semibold hover:bg-black hover:text-white transition-colors inline-flex items-center justify-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span data-i18n="hero.cta.call">Call Us</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Your Feedback Matters Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4" data-i18n="why.title">Why Your Feedback Matters</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto" data-i18n="why.description">
          Your insights help us serve you better and improve our mortgage services for everyone.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6 bg-white rounded-lg border border-gray-200">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2" data-i18n="why.cards.improve.title">Improve Services</h3>
          <p class="text-gray-600" data-i18n="why.cards.improve.desc">
            Your feedback helps us identify areas where we can enhance our mortgage products and services.
          </p>
        </div>

        <div class="text-center p-6 bg-white rounded-lg border border-gray-200">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2" data-i18n="why.cards.response.title">Faster Response</h3>
          <p class="text-gray-600" data-i18n="why.cards.response.desc">
            We use your input to streamline our processes and respond to your needs more quickly.
          </p>
        </div>

        <div class="text-center p-6 bg-white rounded-lg border border-gray-200">
          <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1.01M15 10h1.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2" data-i18n="why.cards.experience.title">Better Experience</h3>
          <p class="text-gray-600" data-i18n="why.cards.experience.desc">
            Your suggestions help us create a more personalized and satisfying mortgage experience.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Feedback Form Section -->
  <section id="feedback-form" class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4" data-i18n="form.title">Share Your Experience</h2>
        <p class="text-lg text-gray-600" data-i18n="form.description">
          We appreciate you taking the time to provide feedback about your experience with Broker Lenders.
        </p>
      </div>

      <div class="bg-gray-50 rounded-2xl p-8">
        <form name="feedback" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="feedback" />
          <p class="hidden">
            <label>Don't fill this out if you're human: <input name="bot-field" /></label>
          </p>

          <!-- Personal Information -->
          <div class="mb-8">
            <h3 class="text-lg font-semibold text-gray-900 mb-4" data-i18n="form.info.title">Your Information</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.labels.firstName">
                  First Name *
                </label>
                <input type="text" id="firstName" name="firstName" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.labels.lastName">
                  Last Name *
                </label>
                <input type="text" id="lastName" name="lastName" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
              </div>
            </div>
          </div>

          <!-- Experience Rating -->
          <div class="mb-8">
            <h3 class="text-lg font-semibold text-gray-900 mb-4" data-i18n="form.rating.title">Rate Your Experience</h3>
            <div class="flex items-center space-x-4">
              <label class="flex items-center">
                <input type="radio" name="rating" value="excellent" class="w-4 h-4 text-black border-gray-300 focus:ring-black">
                <span class="ml-2 text-gray-700" data-i18n="form.rating.options.excellent">Excellent</span>
              </label>
              <label class="flex items-center">
                <input type="radio" name="rating" value="good" class="w-4 h-4 text-black border-gray-300 focus:ring-black">
                <span class="ml-2 text-gray-700" data-i18n="form.rating.options.good">Good</span>
              </label>
              <label class="flex items-center">
                <input type="radio" name="rating" value="average" class="w-4 h-4 text-black border-gray-300 focus:ring-black">
                <span class="ml-2 text-gray-700" data-i18n="form.rating.options.average">Average</span>
              </label>
              <label class="flex items-center">
                <input type="radio" name="rating" value="poor" class="w-4 h-4 text-black border-gray-300 focus:ring-black">
                <span class="ml-2 text-gray-700" data-i18n="form.rating.options.poor">Poor</span>
              </label>
            </div>
          </div>

          <!-- Service Type -->
          <div class="mb-6">
            <label for="serviceType" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.service.label">
              Which service did you use? *
            </label>
            <select id="serviceType" name="serviceType" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
              <option value="" data-i18n="form.service.options.select">Select a service</option>
              <option value="new-mortgage" data-i18n="form.service.options.newMortgage">New Mortgage</option>
              <option value="refinance" data-i18n="form.service.options.refinance">Refinancing</option>
              <option value="rate-quote" data-i18n="form.service.options.rateQuote">Rate Quote</option>
              <option value="consultation" data-i18n="form.service.options.consultation">Consultation</option>
              <option value="other" data-i18n="form.service.options.other">Other</option>
            </select>
          </div>

          <!-- Feedback Type -->
          <div class="mb-6">
            <label for="feedbackType" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.feedback.label">
              What type of feedback are you providing? *
            </label>
            <select id="feedbackType" name="feedbackType" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors">
              <option value="" data-i18n="form.feedback.options.select">Select feedback type</option>
              <option value="compliment" data-i18n="form.feedback.options.compliment">Compliment</option>
              <option value="suggestion" data-i18n="form.feedback.options.suggestion">Suggestion</option>
              <option value="complaint" data-i18n="form.feedback.options.complaint">Complaint</option>
              <option value="question" data-i18n="form.feedback.options.question">Question</option>
              <option value="other" data-i18n="form.feedback.options.other">Other</option>
            </select>
          </div>

          <!-- Detailed Feedback -->
          <div class="mb-6">
            <label for="feedback" class="block text-sm font-medium text-gray-700 mb-2" data-i18n="form.details.label">
              Please share your detailed feedback *
            </label>
            <textarea id="feedback" name="feedback" rows="6" required placeholder="Please provide specific details about your experience, suggestions, or concerns..." data-i18n-placeholder="form.details.placeholder" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-transparent transition-colors resize-vertical"></textarea>
          </div>

          <!-- Contact Permission -->
          <div class="mb-6">
            <label class="flex items-center">
              <input type="checkbox" name="contactPermission" class="w-4 h-4 text-black border-gray-300 rounded focus:ring-black">
              <span class="ml-2 text-sm text-gray-700" data-i18n="form.contactPermission.text">
                I would like to be contacted about my feedback
              </span>
            </label>
          </div>

          <div class="text-center">
            <button type="submit" class="bg-black text-white px-8 py-3 rounded-[48px] font-semibold hover:bg-red-600 hover:text-white transition-colors inline-flex items-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
              </svg>
              <span data-i18n="form.submit">Submit Feedback</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Contact Component -->
  <Contact />
  
  <!-- Ways Help Component -->
  <WaysHelp />
  
  <!-- Important Legal Disclosures -->
  <ImportantLegal />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const translations = {
      en: {
        title: 'Feedback - Broker Lenders',
        breadcrumb: { home: 'Home', feedback: 'Feedback' },
        hero: {
          title: 'We Value Your Feedback',
          description: 'Your opinion matters to us. Help us improve our services by sharing your experience and suggestions.',
          cta: { share: 'Share Feedback', call: 'Call Us' }
        },
        why: {
          title: 'Why Your Feedback Matters',
          description: 'Your insights help us serve you better and improve our mortgage services for everyone.',
          cards: {
            improve: { title: 'Improve Services', desc: 'Your feedback helps us identify areas where we can enhance our mortgage products and services.' },
            response: { title: 'Faster Response', desc: 'We use your input to streamline our processes and respond to your needs more quickly.' },
            experience: { title: 'Better Experience', desc: 'Your suggestions help us create a more personalized and satisfying mortgage experience.' }
          }
        },
        form: {
          title: 'Share Your Experience',
          description: 'We appreciate you taking the time to provide feedback about your experience with Broker Lenders.',
          info: { title: 'Your Information' },
          labels: { firstName: 'First Name *', lastName: 'Last Name *' },
          rating: { title: 'Rate Your Experience', options: { excellent: 'Excellent', good: 'Good', average: 'Average', poor: 'Poor' } },
          service: {
            label: 'Which service did you use? *',
            options: { select: 'Select a service', newMortgage: 'New Mortgage', refinance: 'Refinancing', rateQuote: 'Rate Quote', consultation: 'Consultation', other: 'Other' }
          },
          feedback: {
            label: 'What type of feedback are you providing? *',
            options: { select: 'Select feedback type', compliment: 'Compliment', suggestion: 'Suggestion', complaint: 'Complaint', question: 'Question', other: 'Other' }
          },
          details: { label: 'Please share your detailed feedback *', placeholder: 'Please provide specific details about your experience, suggestions, or concerns...' },
          contactPermission: { text: 'I would like to be contacted about my feedback' },
          submit: 'Submit Feedback'
        }
      },
      es: {
        title: 'Comentarios - Broker Lenders',
        breadcrumb: { home: 'Inicio', feedback: 'Comentarios' },
        hero: {
          title: 'Valoramos tus comentarios',
          description: 'Tu opinión es importante para nosotros. Ayúdanos a mejorar nuestros servicios compartiendo tu experiencia y sugerencias.',
          cta: { share: 'Enviar comentarios', call: 'Llámanos' }
        },
        why: {
          title: 'Por qué tus comentarios importan',
          description: 'Tus ideas nos ayudan a servirte mejor y mejorar nuestros servicios hipotecarios para todos.',
          cards: {
            improve: { title: 'Mejorar servicios', desc: 'Tus comentarios nos ayudan a identificar áreas donde podemos mejorar nuestros productos y servicios hipotecarios.' },
            response: { title: 'Respuesta más rápida', desc: 'Usamos tus aportes para optimizar nuestros procesos y responder más rápido a tus necesidades.' },
            experience: { title: 'Mejor experiencia', desc: 'Tus sugerencias nos ayudan a crear una experiencia hipotecaria más personalizada y satisfactoria.' }
          }
        },
        form: {
          title: 'Comparte tu experiencia',
          description: 'Agradecemos que te tomes el tiempo para brindar comentarios sobre tu experiencia con Broker Lenders.',
          info: { title: 'Tu información' },
          labels: { firstName: 'Nombre *', lastName: 'Apellido *' },
          rating: { title: 'Califica tu experiencia', options: { excellent: 'Excelente', good: 'Buena', average: 'Regular', poor: 'Mala' } },
          service: {
            label: '¿Qué servicio utilizaste? *',
            options: { select: 'Selecciona un servicio', newMortgage: 'Hipoteca nueva', refinance: 'Refinanciamiento', rateQuote: 'Cotización de tasa', consultation: 'Consulta', other: 'Otro' }
          },
          feedback: {
            label: '¿Qué tipo de comentario estás proporcionando? *',
            options: { select: 'Selecciona el tipo', compliment: 'Elogio', suggestion: 'Sugerencia', complaint: 'Queja', question: 'Pregunta', other: 'Otro' }
          },
          details: { label: 'Comparte tu comentario detallado *', placeholder: 'Por favor proporciona detalles específicos sobre tu experiencia, sugerencias o inquietudes...' },
          contactPermission: { text: 'Me gustaría ser contactado sobre mi comentario' },
          submit: 'Enviar comentarios'
        }
      }
    };
    const resolvePath = (obj, path) => {
      if (!obj || !path) return null;
      const parts = path.split('.');
      let cur = obj;
      for (const p of parts) { if (cur && (p in cur)) cur = cur[p]; else return null; }
      return cur;
    };
    const getInitialLang = () => {
      const urlLang = new URLSearchParams(window.location.search).get('lang');
      let cookieLang = null;
      try {
        const m = document.cookie.match(/(?:^|;\s*)lang=([^;]+)/);
        cookieLang = m && m[1] ? m[1].toLowerCase() : null;
      } catch {}
      const stored = localStorage.getItem('lang');
      const htmlLang = document.documentElement.getAttribute('lang');
      const raw = (urlLang || cookieLang || stored || htmlLang || 'en').toLowerCase();
      return raw === 'es' ? 'es' : 'en';
    };
    const applyTranslations = (lang) => {
      const dict = translations[lang] || translations.en;
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        const val = resolvePath(dict, key);
        if (typeof val === 'string') {
          if (val.includes('<')) el.innerHTML = val; else el.textContent = val;
        }
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
        const key = el.getAttribute('data-i18n-placeholder');
        const val = resolvePath(dict, key);
        if (typeof val === 'string') el.setAttribute('placeholder', val);
      });
      if (typeof dict.title === 'string') document.title = dict.title;
    };
    const setLanguage = (lang) => {
      const next = (lang === 'es') ? 'es' : 'en';
      try { localStorage.setItem('lang', next); } catch {}
      try { document.cookie = `lang=${next};path=/;max-age=31536000;SameSite=Lax`; } catch {}
      try { document.documentElement.setAttribute('lang', next); } catch {}
      const url = new URL(window.location.href);
      url.searchParams.set('lang', next);
      const newUrl = url.toString();
      if (newUrl !== window.location.href) window.history.replaceState({}, '', newUrl);
      applyTranslations(next);
    };
    // Initialize
    setLanguage(getInitialLang());
    // React to language menu clicks
    document.addEventListener('click', (e) => {
      const a = e.target.closest('a[href*="?lang="]');
      if (!a) return;
      let href; try { href = new URL(a.href, window.location.origin); } catch { return; }
      const newLang = href.searchParams.get('lang');
      if (newLang) setLanguage(newLang);
    });
    // Respond to storage events
    window.addEventListener('storage', (ev) => {
      if (ev.key === 'lang' && ev.newValue) applyTranslations(ev.newValue);
    });
  });
</script>