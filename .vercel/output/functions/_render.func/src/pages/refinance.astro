<!-- i18n payload for Refinance page -->
<div id="i18n-refi" data-en={enB64} data-es={esB64} style="display:none"></div>
<script is:inline>
(() => {
  const payloadEl = document.getElementById('i18n-refi');
  const decode = (val) => {
    try {
      const b64 = val || '';
      const bin = atob(b64);
      const bytes = new Uint8Array(bin.length);
      for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
      const jsonText = new TextDecoder('utf-8').decode(bytes);
      return JSON.parse(jsonText);
    } catch { return {}; }
  };
  const translations = {
    en: decode(payloadEl?.getAttribute('data-en') || ''),
    es: decode(payloadEl?.getAttribute('data-es') || ''),
  };
  const getInitialLang = () => {
    const urlLang = new URLSearchParams(window.location.search).get('lang');
    const htmlLang = document.documentElement.getAttribute('lang');
    let cookieLang = null;
    try {
      const m = document.cookie.match(/(?:^|;\s*)lang=([^;]+)/);
      cookieLang = m && m[1] ? m[1].toLowerCase() : null;
    } catch {}
    const stored = localStorage.getItem('lang');
    const raw = (urlLang || htmlLang || cookieLang || stored || 'en').toLowerCase();
    return raw === 'es' ? 'es' : 'en';
  };
  const setLanguage = (lang) => {
    const next = lang === 'es' ? 'es' : 'en';
    try { localStorage.setItem('lang', next); } catch {}
    try { document.cookie = `lang=${next}; path=/; max-age=${60*60*24*365}; SameSite=Lax`; } catch {}
    try { document.documentElement.setAttribute('lang', next); } catch {}
    const url = new URL(window.location.href);
    url.searchParams.set('lang', next);
    const newUrl = url.toString();
    if (newUrl !== window.location.href) {
      window.history.replaceState({}, '', newUrl);
    }
    return next;
  };
  const setText = (id, text) => {
    const el = document.getElementById(id);
    if (el && typeof text === 'string') el.textContent = text;
  };
  const preserveLangOnLinks = (lang) => {
    const ids = ['#refi-hero-cta-secondary', '#refi-newstart-card2-link', '#refi-newstart-card3-link'];
    ids.forEach(selector => {
      const a = document.querySelector(selector);
      if (!a) return;
      try {
        const href = new URL(a.href, window.location.origin);
        if (href.origin === window.location.origin) {
          href.searchParams.set('lang', lang);
          a.href = href.pathname + href.search + href.hash;
        }
      } catch {}
    });
  };
  const applyRefiTranslations = (lang) => {
    const dict = translations[lang] || translations.en;
    // Hero
    setText('refi-hero-title', dict.hero?.title);
    setText('refi-hero-subtitle', dict.hero?.subtitle);
    setText('refi-hero-cta-primary', dict.hero?.ctaPrimary);
    setText('refi-hero-cta-secondary', dict.hero?.ctaSecondary);
    // New Start
    setText('refi-newstart-title', dict.newStart?.title);
    setText('refi-newstart-card1-title', dict.newStart?.card1?.title);
    setText('refi-newstart-card1-desc', dict.newStart?.card1?.description);
    setText('refi-newstart-card2-title', dict.newStart?.card2?.title);
    setText('refi-newstart-card2-desc', dict.newStart?.card2?.description);
    setText('refi-newstart-card3-title', dict.newStart?.card3?.title);
    setText('refi-newstart-card3-desc', dict.newStart?.card3?.description);
    // Steps
    setText('refi-steps-title', dict.steps?.title);
    setText('refi-step1-title', dict.steps?.step1?.title);
    setText('refi-step1-desc', dict.steps?.step1?.description);
    setText('refi-step2-title', dict.steps?.step2?.title);
    setText('refi-step2-desc', dict.steps?.step2?.description);
    setText('refi-step3-title', dict.steps?.step3?.title);
    setText('refi-step3-desc', dict.steps?.step3?.description);
    setText('refi-steps-cta', dict.steps?.cta);
    // Options
    setText('refi-options-title', dict.options?.title);
    setText('refi-options-subtitle', dict.options?.subtitle);
    setText('refi-options-cta-primary', dict.options?.ctaPrimary);
    setText('refi-options-cta-secondary', dict.options?.ctaSecondary);
    // Document title
    if (dict?.meta?.title) {
      document.title = dict.meta.title;
    }
    // Preserve lang param on internal links
    preserveLangOnLinks(lang);
  };
  // Init
  applyRefiTranslations(setLanguage(getInitialLang()));
  // React to language menu clicks (Header intercepts click)
  document.addEventListener('click', (e) => {
    const a = e.target.closest('a[href*="?lang="]');
    if (!a) return;
    let href;
    try { href = new URL(a.href, window.location.origin); } catch { return; }
    const newLang = href.searchParams.get('lang');
    if (newLang) applyRefiTranslations(setLanguage(newLang));
  });
  // Also respond to storage events (Header sets lang)
  window.addEventListener('storage', (ev) => {
    if (ev.key === 'lang' && ev.newValue) applyRefiTranslations(ev.newValue);
  });
  // Handle history navigation where ?lang changes
  window.addEventListener('popstate', () => {
    const urlLang = new URLSearchParams(window.location.search).get('lang');
    const lang = (urlLang || localStorage.getItem('lang') || 'en');
    applyRefiTranslations(lang);
    preserveLangOnLinks(lang);
  });
})();
</script>

