  <script>
    async function hydrateRates() {
      try {
        const res = await fetch('/rates-data.json', { cache: 'no-store' });
        if (!res.ok) return;
        const data = await res.json();
        // Actualizar timestamp dinámico
        const footerTs = document.getElementById('rates-footer-ts-prefix');
        if (footerTs && data.timestamp) {
          const d = new Date(data.timestamp);
          const formatted = d.toLocaleString('en-US', { timeZone: 'UTC', hour: '2-digit', minute: '2-digit', hour12: true, month: 'long', day: 'numeric', year: 'numeric' }) + ' UTC';
          const prefix = (window.__dictRates && window.__dictRates.grid && window.__dictRates.grid.footer && window.__dictRates.grid.footer.timestampPrefix) || 'Rates are current as of';
          footerTs.textContent = `${prefix} ${formatted}`;
        }
        // Rehidratar stateRates usando data del archivo público
        window.__ratesData = data;
        if (typeof window.rebuildRates === 'function') {
          window.rebuildRates(data);
        }
      } catch (e) {
        console.warn('Failed to fetch static rates-data.json:', e);
        // Fallback to SSR-embedded payload
        try {
          const el = document.getElementById('rates-ssr-payload');
          const b64 = el?.getAttribute('data-b64') || '';
          if (b64) {
            const bin = atob(b64);
            const bytes = new Uint8Array(bin.length);
            for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
            const jsonText = new TextDecoder('utf-8').decode(bytes);
            const data = JSON.parse(jsonText);
            window.__ratesData = data;
            if (typeof window.rebuildRates === 'function') {
              window.rebuildRates(data);
            }
          }
        } catch {}
      }
    }
    document.addEventListener('DOMContentLoaded', hydrateRates);
  </script>
