    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm">
        <a id="rates-breadcrumb-home" href={`/?lang=${lang}`} class="text-gray-700 hover:text-gray-900">{dict.breadcrumb?.home || 'Home'}</a>
        <span class="mx-2 text-gray-500">/</span>
        <span id="rates-breadcrumb-rates" class="text-gray-700 underline">{dict.breadcrumb?.rates || 'Rates'}</span>
